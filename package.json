{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.52",
  "description": "AstroWind: A free template using Astro 5.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "generate:amplify-redirects": "node scripts/generate-amplify-redirects.mjs",
    "verify:amplify-redirects": "node scripts/generate-amplify-redirects.mjs --check",
    "verify:urls": "node scripts/verify-canonical-urls.mjs",
    "verify:publishing": "node scripts/verify-publishing.mjs",
    "verify:sitemap": "node scripts/verify-sitemap-hreflang.mjs",
    "verify:links": "node scripts/verify-internal-links.mjs",
    "verify:seo": "npm run verify:amplify-redirects && npm run verify:rss && npm run verify:urls && npm run verify:publishing && npm run verify:sitemap && npm run verify:links",
    "verify:seo:live": "node scripts/verify-live-indexing.mjs",
    "verify:rss": "node scripts/verify-rss.mjs --mode=dist",
    "verify:rss:live": "node scripts/verify-rss.mjs --mode=live --site=https://solutions.futurion.es",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w ."
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "astro": "^7.0.4",
    "astro-icon": "^1.1.5",
    "limax": "^4.2.3",
    "lodash.merge": "^4.6.2",
    "unpic": "^4.2.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "encoding-sniffer": "^1.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@eslint/js": "^10.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "astro-compress": "2.4.1",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "js-yaml": "^5.2.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "^0.35.3",
    "sitemap": "^9.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "unist-util-visit": "^5.0.0"
  }
}
