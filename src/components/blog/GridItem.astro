---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import Image from '~/components/common/Image.astro';

import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
  accent?: string;
}

const { post, accent = 'var(--fds-acc-blue, #2d7bf2)' } = Astro.props;
const image = await findImage(post.image);

const postPermalink = post.lang === 'es' ? `es/${post.permalink}` : post.permalink;
const link = APP_BLOG?.post?.isEnabled ? getPermalink(postPermalink, 'post') : '';
---

<article
  class="aurora-card mb-6 flex flex-col overflow-hidden transition intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  style={`--card-accent: ${accent}`}
>
  {
    image && (
      <div class="relative h-52 overflow-hidden">
        {link ? (
          <a href={link} class="block w-full h-full">
            <Image
              src={image}
              class="w-full h-full object-cover"
              widths={[400, 900]}
              width={400}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              aspectRatio="16:9"
              layout="cover"
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full h-full object-cover"
            widths={[400, 900]}
            width={400}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            aspectRatio="16:9"
            layout="cover"
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    )
  }

  <div class="flex flex-col flex-1 p-5">
    <!-- Accent eyebrow -->
    <div
      class="font-heading font-bold uppercase tracking-[0.12em] text-[11px] mb-3"
      style={`color: ${accent}`}
    >
      {post.category || 'Article'}
    </div>

    <h3 class="text-xl sm:text-2xl font-bold leading-tight mb-2 font-heading dark:text-white">
      {
        link ? (
          <a
            class="inline-block hover:text-primary transition ease-in duration-200"
            href={link}
          >
            {post.title}
          </a>
        ) : (
          post.title
        )
      }
    </h3>

    <p class="text-muted text-base flex-1">{post.excerpt}</p>

    {link && (
      <div class="mt-4">
        <a
          href={link}
          class="inline-flex items-center gap-2 font-heading font-semibold text-sm"
          style={`color: ${accent}`}
        >
          Read more
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </div>
</article>
