---
export interface Props {
  isDark?: boolean;
}

const { isDark = false } = Astro.props;
---

{isDark ? (
  <div class="absolute inset-0 bg-dark dark:bg-transparent">
    <slot />
  </div>
) : (
  <div
    class="absolute inset-0"
    style="background-image: var(--grad-lilac);"
    aria-hidden="true"
  >
    <slot />
  </div>
)}
