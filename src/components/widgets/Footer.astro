---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';
import logoSrc from '~/assets/favicons/favicon-96x96.png';
import type { ImageMetadata } from 'astro';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
  logo?: ImageMetadata;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer
  class:list={[{ dark: theme === 'dark' }, 'relative not-prose']}
  style="background-image: var(--grad-footer);"
>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 text-slate-300 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <div class="col-span-12 lg:col-span-4">
        <div class="mb-3">
          <a class="inline-flex items-center gap-2 font-bold text-xl text-white font-heading" href={getHomePermalink()}>
            <img src={logoSrc.src} alt={SITE?.name || ''} width="32" height="32" class="rounded-full" />
            {SITE?.name}
          </a>
        </div>
        <div class="text-sm text-slate-400 flex gap-1 flex-wrap">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span class="opacity-40">·</span> : ''}
                <a
                  class="text-slate-400 hover:text-white transition duration-150 ease-in-out"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="text-white font-heading font-semibold text-[13px] tracking-[0.08em] uppercase mb-3">{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm">
                {links.map(({ text, href, ariaLabel, logo }) => (
                  <li class="mb-2">
                    <a
                      class="flex items-center gap-2 text-slate-400 hover:text-white transition duration-150 ease-in-out"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      {logo && <img src={logo.src} width="18" height="18" class="object-contain opacity-75 flex-shrink-0" alt={text} aria-hidden="true" />}
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
    <div class="md:flex md:items-center md:justify-between pt-2 pb-6 md:pb-8 border-t border-white/10">
      {
        socialLinks?.length ? (
          <ul class="flex mb-4 md:order-1 -ml-2 md:ml-4 md:mb-0 rtl:ml-0 rtl:-mr-2 rtl:md:ml-0 rtl:md:mr-4">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-slate-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/20 rounded-lg text-sm p-2.5 inline-flex items-center transition-colors duration-150"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

    </div>
  </div>
  <!-- Coral ribbon at the bottom — mirrors Aurora footer-bottom -->
  <div
    class="text-white text-center text-[13px] font-medium py-3 px-4"
    style="background-image: var(--grad-ribbon);"
  >
    <Fragment set:html={footNote} />
  </div>
</footer>
