---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Pricing as Props } from '~/types';

// Aurora accent rotation for pricing tiers
const ACCENTS = [
  'var(--fds-acc-blue,   #2d7bf2)',
  'var(--fds-acc-pink,   #ff2f70)',
  'var(--fds-acc-purple, #a459ff)',
  'var(--fds-acc-lime,   #83e31e)',
  'var(--fds-acc-royal,  #0065fe)',
];

const {
  title = '',
  subtitle = '',
  tagline = '',
  prices = [],

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <div class="flex flex-wrap items-stretch justify-center gap-4 dark:text-white">
      {
        prices &&
          prices.map(({ title, subtitle, price, period, items, callToAction, hasRibbon = false, ribbonTitle }, i) => (
            <div class="flex w-full sm:w-[calc(50%-0.5rem)] lg:w-[calc(20%-0.8rem)] mx-auto intersect-once motion-safe:md:intersect:animate-fade motion-safe:md:opacity-0 intersect-quarter">
              {(price || price === 0) && period && (
                <div
                  class="aurora-card relative flex w-full mx-auto flex-col justify-between px-4 py-6"
                  style={`--card-accent: ${ACCENTS[i % ACCENTS.length]}`}
                >
                  {hasRibbon && ribbonTitle && (
                    <div class="absolute right-[-5px] 2xl:right-[-8px] rtl:right-auto rtl:left-[-8px] rtl:2xl:left-[-10px] top-[-5px] 2xl:top-[-10px] z-[1] h-[100px] w-[100px] overflow-hidden text-right">
                      <span
                        class="absolute top-[19px] right-[-21px] rtl:right-auto rtl:left-[-21px] block w-full rotate-45 rtl:-rotate-45 text-center text-[10px] font-bold uppercase leading-5 text-white shadow-[0_3px_10px_-5px_rgba(0,0,0,0.3)] before:absolute before:left-0 before:top-full before:z-[-1] before:border-[3px] before:border-r-transparent before:border-b-transparent before:border-l-green-800 before:border-t-green-800 before:content-[''] after:absolute after:right-0 after:top-full after:z-[-1] after:border-[3px] after:border-l-transparent after:border-b-transparent after:border-r-green-800 after:border-t-green-800 after:content-['']"
                        style="background-image: var(--grad-coral);"
                      >
                        {ribbonTitle}
                      </span>
                    </div>
                  )}
                  <div class="px-2 py-0">
                    {title && (
                      <h3
                        class="text-center text-xl font-heading font-bold uppercase leading-6 tracking-[0.06em] mb-2"
                        style={`color: ${ACCENTS[i % ACCENTS.length]}`}
                      >
                        {title}
                      </h3>
                    )}
                    {subtitle && <p class="font-light sm:text-lg text-muted dark:text-slate-400 text-center">{subtitle}</p>}
                    <div class="my-8">
                      <div class="flex items-center justify-center text-center mb-1">
                        {price === 0 || price === '0' ? (
                          <span class="text-5xl font-extrabold font-heading dark:text-white">Free</span>
                        ) : typeof price === 'number' || !isNaN(Number(String(price).replace(/,/g, ''))) ? (
                          <>
                            <span class="text-4xl font-heading dark:text-white">€</span>
                            <span class="text-5xl font-extrabold font-heading dark:text-white">{price}</span>
                          </>
                        ) : (
                          <span class="text-5xl font-extrabold font-heading dark:text-white">{price}</span>
                        )}
                      </div>
                      <span class="text-base leading-6 lowercase text-muted">{period}</span>
                    </div>
                    {items && (
                      <ul class="my-8 md:my-10 space-y-2 text-left">
                        {items.map(
                          ({ description, icon }) =>
                            description && (
                              <li class="mb-1.5 flex items-start space-x-3 leading-7">
                                <div
                                  class="rounded-full mt-1 flex-shrink-0"
                                  style={`background: ${ACCENTS[i % ACCENTS.length]}`}
                                >
                                  <Icon name={icon ? icon : 'tabler:check'} class="w-5 h-5 font-bold p-1 text-white" />
                                </div>
                                <span class="dark:text-slate-300">{description}</span>
                              </li>
                            )
                        )}
                      </ul>
                    )}
                  </div>
                  {callToAction && (
                    <div class="flex justify-center">
                      {typeof callToAction === 'string' ? (
                        <Fragment set:html={callToAction} />
                      ) : (
                        callToAction &&
                        callToAction.href && <Button {...(hasRibbon ? { variant: 'primary' } : {})} {...callToAction} />
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>
          ))
      }
  </div>
</WidgetWrapper>
