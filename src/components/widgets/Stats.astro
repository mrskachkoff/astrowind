---
import type { Stats as Props } from '~/types';
import { Icon } from 'astro-icon/components';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  stats = [],
  id,
} = Astro.props;
---

<!-- Aurora "numbers band" — dark gradient, oversized white Poppins stat figures -->
<section
  class="relative overflow-hidden not-prose scroll-mt-[72px] intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  style="background-image: var(--grad-numbers); padding: 70px 0 76px;"
  {...id ? { id } : {}}
>
  <!-- dot-texture overlay -->
  <div
    class="absolute inset-0 pointer-events-none opacity-30"
    style="background-image: var(--dot-texture); background-size: 30px 30px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 md:px-6 text-center">
    {(title || subtitle || tagline) && (
      <div class="mb-10">
        {tagline && (
          <p class="font-heading font-bold uppercase tracking-[0.12em] text-[11.5px] mb-3 text-white/70">
            {tagline}
          </p>
        )}
        {title && (
          <h2
            class="font-heading font-bold text-white text-2xl md:text-3xl leading-tight max-w-2xl mx-auto"
            style="letter-spacing: var(--fds-track-tight, -0.02em);"
            set:html={title}
          />
        )}
        {subtitle && <p class="mt-3 text-white/70 text-lg" set:html={subtitle} />}
      </div>
    )}

    <div class="flex flex-wrap justify-center gap-x-16 gap-y-10">
      {
        stats &&
          stats.map(({ amount, title: label, icon }) => (
            <div class="text-center min-w-[180px]">
              {icon && (
                <div class="flex items-center justify-center mx-auto mb-3 text-white/60">
                  <Icon name={icon} class="w-8 h-8" />
                </div>
              )}
              {amount && (
                <div
                  class="font-heading font-extrabold text-white leading-none whitespace-nowrap"
                  style="font-size: clamp(3.25rem, 2rem + 3.4vw, 4.75rem); letter-spacing: -0.03em;"
                >
                  {amount}
                </div>
              )}
              {label && (
                <div class="text-white/80 font-semibold text-base mt-3 leading-snug max-w-[14rem] mx-auto">
                  {label}
                </div>
              )}
            </div>
          ))
      }
    </div>
  </div>
</section>
