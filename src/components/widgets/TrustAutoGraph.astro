const payloadJson = JSON.stringify(payload);
---

<figure class="tag" data-tag data-brand={imgBrand.src} aria-label={t.aria}>
  <img class="tag-poster" src={imgPoster.src} alt="TrustAuto automation stack" aria-hidden="true" />
  <canvas class="tag-canvas" aria-hidden="true"></canvas>
  <div class="tag-labels" aria-hidden="true"></div>

  <div class="tag-status fds-card"><span class="tag-dot"></span><span class="tag-count"></span></div>
  <div class="tag-hint">{t.hint}</div>

  <aside class="tag-detail fds-card" hidden aria-hidden="true">
    <div class="tag-detail-head">
      <span class="tag-detail-title"></span>
      <button class="tag-detail-close" type="button" tabindex="-1" aria-label={t.close}>×</button>
    </div>
    <div class="tag-detail-body"></div>
  </aside>

  <script type="application/json" data-tag-data set:html={payloadJson} />
</figure>

<style>
  .tag {
    --acc: #2d7bf2;
    position: relative;
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--fds-r-card, 16px);
    overflow: hidden;
    background: radial-gradient(120% 120% at 50% 18%, #131a44 0%, #0a0f2e 62%, #070b22 100%);
    border: 1px solid rgba(45, 123, 242, 0.4);
    box-shadow: var(--fds-shadow-figure, 0 40px 80px -30px rgba(0, 0, 0, 0.6));
    font-family: 'Inter Variable', system-ui, sans-serif;
    user-select: none;
    touch-action: pan-y;
  }

  .tag-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.5;
    transition: opacity 0.4s ease;
  }
  .tag.is-ready .tag-poster {
    opacity: 0;
    pointer-events: none;
  }

  .tag-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }
  .tag-canvas.is-grabbing {
    cursor: grabbing;
  }

  .tag-labels {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* :global — these elements are created in JS, so they never receive Astro's
     data-astro-cid scoping attribute; scoped selectors would not match them. */
  :global(.tag-node-label) {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    padding: 2px 7px;
    border-radius: 9999px;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    white-space: nowrap;
    color: #eaf0ff;
    background: rgba(8, 12, 34, 0.62);
    border: 1px solid var(--acc);
    box-shadow: 0 0 10px -2px var(--acc);
    will-change: transform, opacity;
  }

  /* Shared surface for status / detail (the snapshot's .fds-card) */
  .fds-card {
    background: rgba(10, 15, 46, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    box-shadow: 0 8px 28px -10px rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .tag-status {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 11px;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #aab2e0;
  }
  .tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: #83e31e;
    box-shadow: 0 0 8px #83e31e;
  }

  .tag-hint {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    font-size: 10.5px;
    color: #5a6286;
    pointer-events: none;
    white-space: nowrap;
  }

  .tag-detail {
    position: absolute;
    top: 12px;
    right: 12px;
    width: min(240px, 64%);
    padding: 10px 12px 12px;
    z-index: 5;
  }
  .tag-detail[hidden] {
    display: none;
  }
  .tag-detail-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tag-detail-title {
    flex: 1;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 12.5px;
    font-weight: 700;
    color: #eaf0ff;
    line-height: 1.3;
  }
  .tag-detail-close {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border: none;
    background: transparent;
    color: #aab2e0;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
  }
  .tag-detail-close:hover {
    color: #fff;
  }
  .tag-detail-body {
    margin-top: 7px;
    font-size: 11px;
    color: #9aa2c4;
    line-height: 1.5;
  }
  /* :global — the detail panel body is filled via innerHTML, so these children
     also lack the scoping attribute. */
  :global(.tag-quote) {
    font-size: 11.5px;
    font-style: italic;
    color: #c8d8ff;
    line-height: 1.5;
    border-left: 2px solid var(--acc, #2d7bf2);
    padding-left: 8px;
    margin-bottom: 7px;
  }
  :global(.tag-detail-kv) {
    margin-top: 6px;
  }
  :global(.tag-detail-kv b) {
    display: block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #3d4468;
    margin-bottom: 2px;
  }
  :global(.tag-detail-chip) {
    display: inline-block;
    margin: 0 3px 3px 0;
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #c4c9e4;
    font-size: 10px;
  }

  @media (max-width: 600px) {
    .tag {
      aspect-ratio: 1 / 1;
    }
    .tag-hint {
      display: none;
    }
    :global(.tag-node-label) {
      font-size: 9px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-poster {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('[data-tag]').forEach((root) => {
      if (root.dataset.tagInit) return;
      root.dataset.tagInit = '1';
      initTrustAutoGraph(root);
    });
  });

  type GNode = {
    id: string;
    label: string;
    group: string;
    color: string;
    icon: string;
    src?: string;
    q?: string;
    x: number;
    y: number;
    z: number;
    vx: number;
    vy: number;
    vz: number;
    sx: number;
    sy: number;
    sz: number;
    r: number;
    rr: number;
    el: HTMLDivElement;
  };
  type GEdge = { s: string; t: string; r: string };

  function initTrustAutoGraph(root: HTMLElement) {
    const canvas = root.querySelector<HTMLCanvasElement>('.tag-canvas');
    const labelLayer = root.querySelector<HTMLElement>('.tag-labels');
    const dataEl = root.querySelector<HTMLElement>('[data-tag-data]');
    const countEl = root.querySelector<HTMLElement>('.tag-count');
    const detail = root.querySelector<HTMLElement>('.tag-detail');
    const detailTitle = root.querySelector<HTMLElement>('.tag-detail-title');
    const detailBody = root.querySelector<HTMLElement>('.tag-detail-body');
    const detailClose = root.querySelector<HTMLButtonElement>('.tag-detail-close');
    if (!canvas || !labelLayer || !dataEl || !countEl) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let data: { nodes: GNode[]; edges: GEdge[]; i18n: Record<string, string> };
    try {
      data = JSON.parse(dataEl.textContent || '{}');
    } catch {
      return;
    }
    if (!data.nodes || !data.nodes.length) return;

    const i18n = data.i18n || {
      connected: 'Connected',
      source: 'Role',
      passage: 'What it is',
      apps: 'apps',
      models: 'models',
    };
    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] || c);
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Icon + brand image preload ─────────────────────────────────────
    type Ico = { img: HTMLImageElement; ready: boolean };
    const icons = new Map<string, Ico>();
    function getIcon(url: string): Ico | null {
      if (!url) return null;
      let e = icons.get(url);
      if (!e) {
        const img = new Image();
        const rec: Ico = { img, ready: false };
        img.onload = () => {
          rec.ready = true;
          if (reduceMotion || !running) render();
        };
        img.src = url;
        if (img.complete && img.naturalWidth) rec.ready = true;
        icons.set(url, rec);
        e = rec;
      }
      return e;
    }
    const brand = getIcon(root.dataset.brand || '');

    // Deterministic Fibonacci-sphere seeding (no Math.random → stable across builds).
    const nodes: GNode[] = data.nodes as unknown as GNode[];
    const N = nodes.length;
    const golden = Math.PI * (3 - Math.sqrt(5));
    nodes.forEach((n, i) => {
      const yy = 1 - (i / (N - 1)) * 2;
      const rad = Math.sqrt(Math.max(0, 1 - yy * yy));
      const th = golden * i;
      n.x = Math.cos(th) * rad;
      n.y = yy;
      n.z = Math.sin(th) * rad;
      n.vx = n.vy = n.vz = 0;
      // Tile half-size in layout units; engines a touch larger.
      n.r = n.group === 'engine' ? 15 : 13;
      n.rr = n.r;
      getIcon(n.icon);
    });

    const byId: Record<string, GNode> = {};
    nodes.forEach((n) => (byId[n.id] = n));
    const edges = (data.edges || []).filter((e) => byId[e.s] && byId[e.t]);

    // Adjacency for highlight + detail.
    const adj: Record<string, Set<string>> = {};
    nodes.forEach((n) => (adj[n.id] = new Set()));
    edges.forEach((e) => {
      adj[e.s].add(e.t);
      adj[e.t].add(e.s);
    });

    const appsN = nodes.filter((n) => n.group === 'system').length;
    const modelsN = nodes.filter((n) => n.group === 'ai').length;
    countEl.textContent = `ON-PREM · ${appsN} ${i18n.apps} · ${modelsN} ${i18n.models}`;

    // Label divs (CSS2D overlay).
    nodes.forEach((n) => {
      const el = document.createElement('div');
      el.className = 'tag-node-label';
      el.style.setProperty('--acc', n.color);
      el.style.visibility = 'hidden'; // hidden by default; revealed on hover/click
      el.style.opacity = '0';
      el.textContent = n.label;
      labelLayer.appendChild(el);
      n.el = el;
    });

    // ── 3D spring layout (warmup then settle) ──────────────────────────
    function tick(dt: number) {
      const kRep = 1.1;
      const kSpring = 0.04;
      const rest = 1.8;
      const center = 0.012;
      for (let i = 0; i < N; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < N; j++) {
          const b = nodes[j];
          let dx = a.x - b.x,
            dy = a.y - b.y,
            dz = a.z - b.z;
          const d2 = dx * dx + dy * dy + dz * dz + 0.01;
          const f = (kRep / d2) * dt;
          const d = Math.sqrt(d2);
          dx /= d;
          dy /= d;
          dz /= d;
          a.vx += dx * f;
          a.vy += dy * f;
          a.vz += dz * f;
          b.vx -= dx * f;
          b.vy -= dy * f;
          b.vz -= dz * f;
        }
      }
      edges.forEach((e) => {
        const a = byId[e.s],
          b = byId[e.t];
        let dx = b.x - a.x,
          dy = b.y - a.y,
          dz = b.z - a.z;
        const d = Math.sqrt(dx * dx + dy * dy + dz * dz) + 0.001;
        const f = kSpring * (d - rest) * dt;
        dx /= d;
        dy /= d;
        dz /= d;
        a.vx += dx * f;
        a.vy += dy * f;
        a.vz += dz * f;
        b.vx -= dx * f;
        b.vy -= dy * f;
        b.vz -= dz * f;
      });
      nodes.forEach((n) => {
        n.vx -= n.x * center;
        n.vy -= n.y * center;
        n.vz -= n.z * center;
        n.x += n.vx;
        n.y += n.vy;
        n.z += n.vz;
        n.vx *= 0.82;
        n.vy *= 0.82;
        n.vz *= 0.82;
      });
    }
    for (let i = 0; i < 280; i++) tick(1);
    // Normalise to unit-ish radius.
    let maxR = 0.0001;
    nodes.forEach((n) => (maxR = Math.max(maxR, Math.hypot(n.x, n.y, n.z))));
    const norm = 1 / maxR;
    nodes.forEach((n) => {
      n.x *= norm;
      n.y *= norm;
      n.z *= norm;
    });

    // ── Render state ───────────────────────────────────────────────────
    let W = 0,
      H = 0,
      cx = 0,
      cy = 0,
      spread = 0,
      dpr = 1;
    let rotY = 0.6;
    const tiltX = -0.38;
    let autoSpin = !reduceMotion;
    let hoverId: string | null = null;
    let selectedId: string | null = null;
    let activeSet: Set<string> | null = null;

    function resize() {
      // getBoundingClientRect reflects the real laid-out size even inside the
      // two-column grid (clientWidth can read stale/half-size before layout settles).
      const rect = root.getBoundingClientRect();
      const w = Math.round(rect.width) || root.clientWidth || 1;
      const h = Math.round(rect.height) || root.clientHeight || 1;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = w;
      H = h;
      cx = w / 2;
      cy = h / 2 + h * 0.06; // nudge orbit down to clear the pinned brand logo
      spread = Math.min(w, h) * 0.36;
      canvas!.width = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function project(n: GNode) {
      const cosY = Math.cos(rotY),
        sinY = Math.sin(rotY);
      const x = n.x * cosY - n.z * sinY;
      let z = n.x * sinY + n.z * cosY;
      const cosX = Math.cos(tiltX),
        sinX = Math.sin(tiltX);
      const y = n.y * cosX - z * sinX;
      z = n.y * sinX + z * cosX;
      const persp = 2.4 / (2.4 - z);
      n.sx = cx + x * spread * persp;
      n.sy = cy + y * spread * persp;
      n.sz = z;
    }

    function roundRectPath(x: number, y: number, w: number, h: number, r: number) {
      const rr = Math.min(r, w / 2, h / 2);
      ctx!.beginPath();
      ctx!.moveTo(x + rr, y);
      ctx!.arcTo(x + w, y, x + w, y + h, rr);
      ctx!.arcTo(x + w, y + h, x, y + h, rr);
      ctx!.arcTo(x, y + h, x, y, rr);
      ctx!.arcTo(x, y, x + w, y, rr);
      ctx!.closePath();
    }

    function drawTile(n: GNode, hi: string | null, lit: boolean) {
      const persp = 2.4 / (2.4 - n.sz);
      const half = n.r * persp;
      const s = half * 2;
      const x = n.sx - half;
      const y = n.sy - half;
      const rad = half * 0.34;
      n.rr = half;
      ctx!.save();
      ctx!.globalAlpha = lit ? 1 : 0.25;
      // glassy tile background + colour glow
      ctx!.shadowBlur = lit ? (n.id === hi ? 22 : 15) : 6;
      ctx!.shadowColor = n.color;
      roundRectPath(x, y, s, s, rad);
      ctx!.fillStyle = 'rgba(233, 238, 252, 0.96)';
      ctx!.fill();
      ctx!.shadowBlur = 0;
      // border
      roundRectPath(x, y, s, s, rad);
      ctx!.lineWidth = n.id === hi ? 2.5 : 1.5;
      ctx!.strokeStyle = n.color;
      ctx!.stroke();
      // icon (clipped to the tile)
      const ic = getIcon(n.icon);
      if (ic && ic.ready) {
        const pad = s * 0.17;
        roundRectPath(x, y, s, s, rad);
        ctx!.clip();
        ctx!.drawImage(ic.img, x + pad, y + pad, s - 2 * pad, s - 2 * pad);
      }
      ctx!.restore();
    }

    function drawBrand() {
      if (!brand || !brand.ready) return;
      const h = Math.max(34, H * 0.15);
      const aspect = (brand.img.naturalWidth || 503) / (brand.img.naturalHeight || 587);
      const w = h * aspect;
      const x = cx - w / 2;
      const y = H * 0.05;
      ctx!.save();
      ctx!.shadowBlur = 18;
      ctx!.shadowColor = 'rgba(0, 101, 254, 0.6)';
      ctx!.drawImage(brand.img, x, y, w, h);
      ctx!.restore();
    }

    function render() {
      // Self-heal size on every render path (covers reduced-motion + detail renders,
      // not just the animation loop) so labels and tiles never drift out of sync.
      if (Math.abs((root.clientWidth || W) - W) > 1) resize();
      ctx!.clearRect(0, 0, W, H);
      nodes.forEach(project);
      const order = [...nodes].sort((a, b) => a.sz - b.sz);

      const hi = hoverId || selectedId;
      const lit = (id: string) => !hi || id === hi || adj[hi].has(id);

      // edges
      edges.forEach((e) => {
        const a = byId[e.s],
          b = byId[e.t];
        const on = !hi || e.s === hi || e.t === hi;
        ctx!.beginPath();
        ctx!.moveTo(a.sx, a.sy);
        ctx!.lineTo(b.sx, b.sy);
        ctx!.lineWidth = 1;
        ctx!.strokeStyle = `rgba(120, 150, 230, ${on ? 0.5 : 0.08})`;
        ctx!.stroke();
      });

      // tiles (painter's order: far → near)
      order.forEach((n) => {
        drawTile(n, hi, lit(n.id));
        const depth = (n.sz + 1) / 2;
        const el = n.el;
        el.style.transform = `translate(-50%,-50%) translate(${n.sx.toFixed(1)}px, ${(n.sy - n.rr - 9).toFixed(1)}px)`;
        el.style.zIndex = String(Math.round(depth * 100));
        const labelShown = (activeSet !== null && activeSet.has(n.id)) || n.id === hoverId;
        if (labelShown) {
          el.style.visibility = 'visible';
          el.style.opacity = lit(n.id) ? String(0.6 + depth * 0.4) : '0.4';
        } else {
          el.style.visibility = 'hidden';
          el.style.opacity = '0';
        }
      });
      ctx!.globalAlpha = 1;

      drawBrand();
    }

    // ── Animation loop ─────────────────────────────────────────────────
    let raf = 0;
    let running = false;
    function frame() {
      if (autoSpin) rotY += 0.0026;
      render();
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (running) return;
      resize();
      running = true;
      if (reduceMotion) {
        render();
      } else {
        raf = requestAnimationFrame(frame);
      }
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    // ── Interaction ────────────────────────────────────────────────────
    function pick(px: number, py: number): GNode | null {
      let best: GNode | null = null;
      let bd = Infinity;
      nodes.forEach((n) => {
        const reach = n.rr + 3;
        const dx = n.sx - px,
          dy = n.sy - py;
        const d = dx * dx + dy * dy;
        if (d < reach * reach && d < bd) {
          bd = d;
          best = n;
        }
      });
      return best;
    }

    let dragging = false;
    let moved = false;
    let lastX = 0,
      lastY = 0;

    canvas.addEventListener('pointerdown', (ev) => {
      dragging = true;
      moved = false;
      lastX = ev.clientX;
      lastY = ev.clientY;
      autoSpin = false;
      canvas.classList.add('is-grabbing');
      canvas.setPointerCapture(ev.pointerId);
    });
    canvas.addEventListener('pointermove', (ev) => {
      const rect = canvas.getBoundingClientRect();
      const px = ev.clientX - rect.left;
      const py = ev.clientY - rect.top;
      if (dragging) {
        const dx = ev.clientX - lastX;
        if (Math.abs(ev.clientX - lastX) + Math.abs(ev.clientY - lastY) > 3) moved = true;
        rotY += dx * 0.006;
        lastX = ev.clientX;
        lastY = ev.clientY;
        if (reduceMotion) render();
        return;
      }
      const hit = pick(px, py);
      const id = hit ? hit.id : null;
      if (id !== hoverId) {
        hoverId = id;
        canvas.style.cursor = id ? 'pointer' : 'grab';
        if (reduceMotion) render();
      }
    });
    function endDrag(ev: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      canvas!.classList.remove('is-grabbing');
      if (!moved) {
        const rect = canvas!.getBoundingClientRect();
        const hit = pick(ev.clientX - rect.left, ev.clientY - rect.top);
        if (hit) showDetail(hit);
        else hideDetail();
      }
      if (!reduceMotion && !selectedId) autoSpin = true;
    }
    canvas.addEventListener('pointerup', endDrag);
    canvas.addEventListener('pointercancel', endDrag);
    canvas.addEventListener('pointerleave', () => {
      if (!dragging && hoverId) {
        hoverId = null;
        if (reduceMotion) render();
      }
    });

    function showDetail(n: GNode) {
      selectedId = n.id;
      activeSet = new Set<string>([n.id, ...adj[n.id]]);
      autoSpin = false;
      if (detail && detailTitle && detailBody) {
        detailTitle.textContent = n.label;
        detail.style.setProperty('--acc', n.color);
        const neighbours = [...adj[n.id]].map((id) => byId[id].label);
        let html = '';
        if (n.q)
          html += `<div class="tag-detail-kv"><b>${i18n.passage}</b></div><div class="tag-quote">${esc(n.q)}</div>`;
        if (n.src) html += `<div class="tag-detail-kv"><b>${i18n.source}</b>${esc(n.src)}</div>`;
        if (neighbours.length)
          html +=
            `<div class="tag-detail-kv"><b>${i18n.connected}</b>` +
            neighbours.map((l) => `<span class="tag-detail-chip">${esc(l)}</span>`).join('') +
            `</div>`;
        detailBody.innerHTML = html;
        detail.hidden = false;
      }
      if (reduceMotion) render();
    }
    function hideDetail() {
      selectedId = null;
      activeSet = null;
      if (detail) detail.hidden = true;
      if (!reduceMotion) autoSpin = true;
      if (reduceMotion) render();
    }
    detailClose?.addEventListener('click', hideDetail);

    // ── Boot ───────────────────────────────────────────────────────────
    resize();
    root.classList.add('is-ready');
    render();
    // Re-measure after layout settles (two-column grid can still be reflowing at
    // init) so the static/reduced-motion first paint is not sized off a stale box.
    requestAnimationFrame(() => {
      resize();
      if (!running) render();
    });
    window.addEventListener('load', () => {
      resize();
      if (!running) render();
    });
    if ('ResizeObserver' in window) {
      const ro = new ResizeObserver(() => {
        resize();
        if (reduceMotion || !running) render();
      });
      ro.observe(root);
    }
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) start();
            else stop();
          });
        },
        { threshold: 0.05 }
      );
      io.observe(root);
    } else {
      start();
    }
  }
</script>
