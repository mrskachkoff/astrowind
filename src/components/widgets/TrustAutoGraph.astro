---
/**
 * TrustAutoGraph.astro
 * "Orbiting systems" map for TrustAuto — the same self-contained, dependency-free
 * pseudo-3D force graph engine as TrustCoreGraph.astro (Canvas 2D + an HTML label
 * overlay), re-skinned for business-process automation.
 *
 * A central automation ENGINE (Power Automate / self-hosted n8n) orbited by the
 * customer's connected systems, the workflow steps, a human checkpoint and the
 * governance concepts that surround every run. The dataset is SYNTHETIC and
 * PII-free (an invoice-intake example).
 *
 * The engine node renders the TrustAuto logo on the canvas instead of a plain
 * sphere. Pointer-only interactivity (drag to spin, hover to highlight, click for
 * detail, export the map as JSON). Controls are tabindex=-1 because the host
 * Content widget marks the image column aria-hidden.
 */

import imgPoster from '~/assets/images/ai-workflow-tablet.jpg';
import imgLogo from '~/assets/images/trustauto.png';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const STRINGS = {
  en: {
    aria: 'Interactive 3D automation map: the engine, your connected systems, workflow steps and human checkpoints, on your own infrastructure.',
    systems: 'systems',
    steps: 'steps',
    exportLabel: '⬇ Export workflow',
    connected: 'Connected',
    source: 'Runs on',
    passage: 'What it does',
    close: 'Close',
    hint: 'Drag to rotate · click a node',
  },
  es: {
    aria: 'Mapa de automatización 3D interactivo: el motor, tus sistemas conectados, los pasos del flujo y los puntos de control humanos, sobre tu propia infraestructura.',
    systems: 'sistemas',
    steps: 'pasos',
    exportLabel: '⬇ Exportar flujo',
    connected: 'Conexiones',
    source: 'Se ejecuta en',
    passage: 'Qué hace',
    close: 'Cerrar',
    hint: 'Arrastra para rotar · haz clic en un nodo',
  },
};

const t = STRINGS[lang] ?? STRINGS.en;

// Accent palette (mirrors --fds-acc-* tokens) — same hexes as TrustCoreGraph,
// remapped to the automation domain.
const C = {
  engine: '#0065fe', // the automation engine (Power Automate / n8n)
  system: '#2d7bf2', // connected systems: M365, ERP, CRM, files, inbox
  step: '#a459ff', // workflow actions: read, extract, draft, post
  checkpoint: '#ff2f70', // human-approval gate
  outcome: '#83e31e', // logged action / scoped access
  concept: '#96bdf9', // governance concepts: on-prem, systems left in place
};

// Synthetic, PII-free automation graph (EN + ES label sets).
const DATA = {
