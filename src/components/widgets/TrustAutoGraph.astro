const dataset = DATA[lang] ?? DATA.en;
// Attach colors server-side so the script needs no palette logic.
const payload = {
  nodes: dataset.nodes.map((n) => ({ ...n, color: C[n.group as keyof typeof C] })),
  edges: dataset.edges,
  i18n: { connected: t.connected, source: t.source, passage: t.passage, systems: t.systems, steps: t.steps },
};
const payloadJson = JSON.stringify(payload);
---

<figure class="tag" data-tag data-logo={imgLogo.src} aria-label={t.aria}>
  <img class="tag-poster" src={imgPoster.src} alt="TrustAuto automation map" aria-hidden="true" />
  <canvas class="tag-canvas" aria-hidden="true"></canvas>
  <div class="tag-labels" aria-hidden="true"></div>

  <div class="tag-status fds-card"><span class="tag-dot"></span><span class="tag-count"></span></div>
  <div class="tag-hint">{t.hint}</div>
  <button class="tag-export fds-card" type="button" tabindex="-1">{t.exportLabel}</button>

  <aside class="tag-detail fds-card" hidden aria-hidden="true">
    <div class="tag-detail-head">
      <span class="tag-detail-title"></span>
      <button class="tag-detail-close" type="button" tabindex="-1" aria-label={t.close}>×</button>
    </div>
    <div class="tag-detail-body"></div>
  </aside>

  <script type="application/json" data-tag-data set:html={payloadJson} />
</figure>

<style>
  .tag {
    --acc: #2d7bf2;
    position: relative;
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--fds-r-card, 16px);
    overflow: hidden;
    background: radial-gradient(120% 120% at 50% 18%, #131a44 0%, #0a0f2e 62%, #070b22 100%);
    border: 1px solid rgba(45, 123, 242, 0.4);
    box-shadow: var(--fds-shadow-figure, 0 40px 80px -30px rgba(0, 0, 0, 0.6));
    font-family: 'Inter Variable', system-ui, sans-serif;
    user-select: none;
    touch-action: pan-y;
  }

  .tag-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.5;
    transition: opacity 0.4s ease;
  }
  .tag.is-ready .tag-poster {
    opacity: 0;
    pointer-events: none;
  }

  .tag-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }
  .tag-canvas.is-grabbing {
    cursor: grabbing;
  }

  .tag-labels {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .fds-node-label {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    padding: 2px 7px;
    border-radius: 9999px;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    white-space: nowrap;
    color: #eaf0ff;
    background: rgba(8, 12, 34, 0.62);
    border: 1px solid var(--acc);
    box-shadow: 0 0 10px -2px var(--acc);
    will-change: transform, opacity;
  }

  /* Shared surface for status / export / detail (the snapshot's .fds-card) */
  .fds-card {
    background: rgba(10, 15, 46, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    box-shadow: 0 8px 28px -10px rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .tag-status {
    position: absolute;
    left: 12px;
    bottom: 12px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 11px;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #aab2e0;
  }
  .tag-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: #83e31e;
    box-shadow: 0 0 8px #83e31e;
  }

  .tag-hint {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    font-size: 10.5px;
    color: #5a6286;
    pointer-events: none;
    white-space: nowrap;
  }

  .tag-export {
    position: absolute;
    right: 12px;
    bottom: 12px;
    padding: 6px 12px;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #6fb0ff;
    cursor: pointer;
  }
  .tag-export:hover {
    color: #a0d0ff;
    border-color: rgba(45, 123, 242, 0.55);
  }

  .tag-detail {
    position: absolute;
    top: 12px;
    right: 12px;
    width: min(240px, 64%);
    padding: 10px 12px 12px;
    z-index: 5;
  }
  .tag-detail[hidden] {
    display: none;
  }
  .tag-detail-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tag-detail-title {
    flex: 1;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 12.5px;
    font-weight: 700;
    color: #eaf0ff;
    line-height: 1.3;
  }
  .tag-detail-close {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border: none;
    background: transparent;
    color: #aab2e0;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
  }
  .tag-detail-close:hover {
    color: #fff;
  }
  .tag-detail-body {
    margin-top: 7px;
    font-size: 11px;
    color: #9aa2c4;
    line-height: 1.5;
  }
  .tag-quote {
    font-size: 11.5px;
    font-style: italic;
    color: #c8d8ff;
    line-height: 1.5;
    border-left: 2px solid var(--acc, #2d7bf2);
    padding-left: 8px;
    margin-bottom: 7px;
  }
  .tag-detail-kv {
    margin-top: 6px;
  }
  .tag-detail-kv b {
    display: block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #3d4468;
    margin-bottom: 2px;
  }
  .tag-detail-chip {
    display: inline-block;
    margin: 0 3px 3px 0;
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #c4c9e4;
    font-size: 10px;
  }

  @media (max-width: 600px) {
    .tag {
      aspect-ratio: 1 / 1;
    }
    .tag-hint {
      display: none;
    }
    .fds-node-label {
      font-size: 9px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-poster {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('[data-tag]').forEach((root) => {
      if (root.dataset.tagInit) return;
      root.dataset.tagInit = '1';
      initTrustAutoGraph(root);
    });
  });

  type GNode = {
    id: string;
    label: string;
    group: string;
    color: string;
    src?: string;
    q?: string;
    x: number;
    y: number;
    z: number;
    vx: number;
    vy: number;
    vz: number;
    sx: number;
    sy: number;
    sz: number;
    r: number;
    rr: number;
    el: HTMLDivElement;
  };
  type GEdge = { s: string; t: string; r: string; kind?: string };

  function initTrustAutoGraph(root: HTMLElement) {
    const canvas = root.querySelector<HTMLCanvasElement>('.tag-canvas');
    const labelLayer = root.querySelector<HTMLElement>('.tag-labels');
    const dataEl = root.querySelector<HTMLElement>('[data-tag-data]');
    const countEl = root.querySelector<HTMLElement>('.tag-count');
    const exportBtn = root.querySelector<HTMLButtonElement>('.tag-export');
    const detail = root.querySelector<HTMLElement>('.tag-detail');
    const detailTitle = root.querySelector<HTMLElement>('.tag-detail-title');
    const detailBody = root.querySelector<HTMLElement>('.tag-detail-body');
    const detailClose = root.querySelector<HTMLButtonElement>('.tag-detail-close');
    if (!canvas || !labelLayer || !dataEl || !countEl) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let data: { nodes: GNode[]; edges: GEdge[]; i18n: Record<string, string> };
    try {
      data = JSON.parse(dataEl.textContent || '{}');
    } catch {
      return;
    }
    if (!data.nodes || !data.nodes.length) return;

    const i18n = data.i18n || {
      connected: 'Connected',
      source: 'Runs on',
      passage: 'What it does',
      systems: 'systems',
      steps: 'steps',
    };
    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] || c);
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // TrustAuto logo, drawn on the canvas for the central engine node.
    const logoImg = new Image();
    let logoReady = false;
    logoImg.onload = () => {
      logoReady = true;
      if (reduceMotion || !running) render();
    };
    logoImg.src = root.dataset.logo || '';
    if (logoImg.complete && logoImg.naturalWidth) logoReady = true;

    // Deterministic Fibonacci-sphere seeding (no Math.random → stable across builds).
    const nodes: GNode[] = data.nodes as unknown as GNode[];
    const N = nodes.length;
    const golden = Math.PI * (3 - Math.sqrt(5));
    nodes.forEach((n, i) => {
      const yy = 1 - (i / (N - 1)) * 2;
      const rad = Math.sqrt(Math.max(0, 1 - yy * yy));
      const th = golden * i;
      n.x = Math.cos(th) * rad;
      n.y = yy;
      n.z = Math.sin(th) * rad;
      n.vx = n.vy = n.vz = 0;
      n.r = n.group === 'engine' ? 8 : n.group === 'system' ? 6 : 4.2;
      n.rr = n.r;
    });

    const byId: Record<string, GNode> = {};
    nodes.forEach((n) => (byId[n.id] = n));
    const edges = (data.edges || []).filter((e) => byId[e.s] && byId[e.t]);

    // Adjacency for highlight + detail.
    const adj: Record<string, Set<string>> = {};
    nodes.forEach((n) => (adj[n.id] = new Set()));
    edges.forEach((e) => {
      adj[e.s].add(e.t);
      adj[e.t].add(e.s);
    });

    const systemsN = nodes.filter((n) => n.group === 'system').length;
    const stepsN = nodes.filter((n) => n.group === 'step').length;
    countEl.textContent = `ON-PREM · ${systemsN} ${i18n.systems} · ${stepsN} ${i18n.steps}`;

    // Label divs (CSS2D overlay).
    nodes.forEach((n) => {
      const el = document.createElement('div');
      el.className = 'fds-node-label';
      el.style.setProperty('--acc', n.color);
      el.style.visibility = 'hidden'; // hidden by default; revealed on hover/click
      el.style.opacity = '0';
      el.textContent = n.label;
      labelLayer.appendChild(el);
      n.el = el;
    });

    // ── 3D spring layout (warmup then settle) ──────────────────────────
    function tick(dt: number) {
      const kRep = 0.9;
      const kSpring = 0.04;
      const rest = 1.7;
      const center = 0.012;
      for (let i = 0; i < N; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < N; j++) {
          const b = nodes[j];
          let dx = a.x - b.x,
            dy = a.y - b.y,
            dz = a.z - b.z;
          const d2 = dx * dx + dy * dy + dz * dz + 0.01;
          const f = (kRep / d2) * dt;
          const d = Math.sqrt(d2);
          dx /= d;
          dy /= d;
          dz /= d;
          a.vx += dx * f;
          a.vy += dy * f;
          a.vz += dz * f;
          b.vx -= dx * f;
          b.vy -= dy * f;
          b.vz -= dz * f;
        }
      }
      edges.forEach((e) => {
        const a = byId[e.s],
          b = byId[e.t];
        let dx = b.x - a.x,
          dy = b.y - a.y,
          dz = b.z - a.z;
        const d = Math.sqrt(dx * dx + dy * dy + dz * dz) + 0.001;
        const f = kSpring * (d - rest) * dt;
        dx /= d;
        dy /= d;
        dz /= d;
        a.vx += dx * f;
        a.vy += dy * f;
        a.vz += dz * f;
        b.vx -= dx * f;
        b.vy -= dy * f;
        b.vz -= dz * f;
      });
      nodes.forEach((n) => {
        n.vx -= n.x * center;
        n.vy -= n.y * center;
        n.vz -= n.z * center;
        n.x += n.vx;
        n.y += n.vy;
        n.z += n.vz;
        n.vx *= 0.82;
        n.vy *= 0.82;
        n.vz *= 0.82;
      });
    }
    for (let i = 0; i < 260; i++) tick(1);
    // Pull the engine toward the centre so the logo sits in the middle.
    const eng = byId['ENG'];
    if (eng) {
      eng.x = 0;
      eng.y = 0;
      eng.z = 0;
    }
    // Normalise to unit-ish radius.
    let maxR = 0.0001;
    nodes.forEach((n) => (maxR = Math.max(maxR, Math.hypot(n.x, n.y, n.z))));
    const norm = 1 / maxR;
    nodes.forEach((n) => {
      n.x *= norm;
      n.y *= norm;
      n.z *= norm;
    });

    // ── Render state ───────────────────────────────────────────────────
    let W = 0,
      H = 0,
      cx = 0,
      cy = 0,
      spread = 0,
      dpr = 1;
    let rotY = 0.6;
    const tiltX = -0.42;
    let autoSpin = !reduceMotion;
    let hoverId: string | null = null;
    let selectedId: string | null = null;
    // Labels are hidden by default; this holds the ids whose labels are revealed
    // (a clicked node + its related entities). null = nothing revealed.
    let activeSet: Set<string> | null = null;

    function resize() {
      const w = root.clientWidth || 1;
      const h = root.clientHeight || 1;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = w;
      H = h;
      cx = w / 2;
      cy = h / 2;
      spread = Math.min(w, h) * 0.34;
      canvas!.width = Math.round(w * dpr);
      canvas!.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function project(n: GNode) {
      // rotate about Y then tilt about X
      const cosY = Math.cos(rotY),
        sinY = Math.sin(rotY);
      const x = n.x * cosY - n.z * sinY;
      let z = n.x * sinY + n.z * cosY;
      const cosX = Math.cos(tiltX),
        sinX = Math.sin(tiltX);
      const y = n.y * cosX - z * sinX;
      z = n.y * sinX + z * cosX;
      const persp = 2.4 / (2.4 - z); // z in [-1,1]
      n.sx = cx + x * spread * persp;
      n.sy = cy + y * spread * persp;
      n.sz = z;
    }

    function render() {
      ctx!.clearRect(0, 0, W, H);
      nodes.forEach(project);
      const order = [...nodes].sort((a, b) => a.sz - b.sz);

      const hi = hoverId || selectedId;
      const lit = (id: string) => !hi || id === hi || adj[hi].has(id);

      // edges
      edges.forEach((e) => {
        const a = byId[e.s],
          b = byId[e.t];
        const on = !hi || e.s === hi || e.t === hi;
        ctx!.beginPath();
        ctx!.moveTo(a.sx, a.sy);
        ctx!.lineTo(b.sx, b.sy);
        ctx!.lineWidth = 1;
        ctx!.strokeStyle = `rgba(120, 150, 230, ${on ? 0.5 : 0.08})`;
        ctx!.stroke();
      });

      // nodes
      order.forEach((n) => {
        const persp = 2.4 / (2.4 - n.sz);
        const rr = n.r * persp;
        const on = lit(n.id);
        ctx!.globalAlpha = on ? 1 : 0.22;

        if (n.group === 'engine' && logoReady) {
          // Draw the TrustAuto logo instead of a plain sphere.
          const logoH = spread * 0.62 * persp;
          const aspect = (logoImg.naturalWidth || 503) / (logoImg.naturalHeight || 587);
          const logoW = logoH * aspect;
          ctx!.shadowBlur = on ? 22 : 6;
          ctx!.shadowColor = n.color;
          ctx!.drawImage(logoImg, n.sx - logoW / 2, n.sy - logoH / 2, logoW, logoH);
          ctx!.shadowBlur = 0;
          n.rr = logoH / 2;
        } else {
          ctx!.beginPath();
          ctx!.arc(n.sx, n.sy, rr, 0, Math.PI * 2);
          ctx!.fillStyle = n.color;
          ctx!.shadowBlur = on ? 12 : 0;
          ctx!.shadowColor = n.color;
          ctx!.fill();
          ctx!.shadowBlur = 0;
          if (n.id === hi) {
            ctx!.lineWidth = 2;
            ctx!.strokeStyle = '#fff';
            ctx!.stroke();
          }
          n.rr = rr;
        }

        // label — hidden by default; shown only for the active set or the hovered node
        const depth = (n.sz + 1) / 2; // 0 back .. 1 front
        const el = n.el;
        el.style.transform = `translate(-50%,-50%) translate(${n.sx.toFixed(1)}px, ${(n.sy - n.rr - 8).toFixed(1)}px)`;
        el.style.zIndex = String(Math.round(depth * 100));
        const labelShown = (activeSet !== null && activeSet.has(n.id)) || n.id === hoverId;
        if (labelShown) {
          el.style.visibility = 'visible';
          el.style.opacity = on ? String(0.55 + depth * 0.45) : '0.4';
        } else {
          el.style.visibility = 'hidden';
          el.style.opacity = '0';
        }
      });
      ctx!.globalAlpha = 1;
    }

    // ── Animation loop ─────────────────────────────────────────────────
    let raf = 0;
    let running = false;
    function frame() {
      if (autoSpin) rotY += 0.0028;
      render();
      raf = requestAnimationFrame(frame);
    }
    function start() {
      if (running) return;
      running = true;
      if (reduceMotion) {
        render();
      } else {
        raf = requestAnimationFrame(frame);
      }
    }
    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    // ── Interaction ────────────────────────────────────────────────────
    function pick(px: number, py: number): GNode | null {
      let best: GNode | null = null;
      let bd = 18 * 18;
      nodes.forEach((n) => {
        const dx = n.sx - px,
          dy = n.sy - py;
        const reach = Math.max(18, n.rr + 6);
        const d = dx * dx + dy * dy;
        if (d < reach * reach && d < bd) {
          bd = d;
          best = n;
        }
      });
      return best;
    }

    let dragging = false;
    let moved = false;
    let lastX = 0,
      lastY = 0;

    canvas.addEventListener('pointerdown', (ev) => {
      dragging = true;
      moved = false;
      lastX = ev.clientX;
      lastY = ev.clientY;
      autoSpin = false;
      canvas.classList.add('is-grabbing');
      canvas.setPointerCapture(ev.pointerId);
    });
    canvas.addEventListener('pointermove', (ev) => {
      const rect = canvas.getBoundingClientRect();
      const px = ev.clientX - rect.left;
      const py = ev.clientY - rect.top;
      if (dragging) {
        const dx = ev.clientX - lastX;
        if (Math.abs(ev.clientX - lastX) + Math.abs(ev.clientY - lastY) > 3) moved = true;
        rotY += dx * 0.006;
        lastX = ev.clientX;
        lastY = ev.clientY;
        if (reduceMotion) render();
        return;
      }
      const hit = pick(px, py);
      const id = hit ? hit.id : null;
      if (id !== hoverId) {
        hoverId = id;
        canvas.style.cursor = id ? 'pointer' : 'grab';
        if (reduceMotion) render();
      }
    });
    function endDrag(ev: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      canvas!.classList.remove('is-grabbing');
      if (!moved) {
        const rect = canvas!.getBoundingClientRect();
        const hit = pick(ev.clientX - rect.left, ev.clientY - rect.top);
        if (hit) showDetail(hit);
        else hideDetail();
      }
      if (!reduceMotion && !selectedId) autoSpin = true;
    }
    canvas.addEventListener('pointerup', endDrag);
    canvas.addEventListener('pointercancel', endDrag);
    canvas.addEventListener('pointerleave', () => {
      if (!dragging && hoverId) {
        hoverId = null;
        if (reduceMotion) render();
      }
    });

    function showDetail(n: GNode) {
      selectedId = n.id;
      // Reveal this node + its related entities in the graph.
      activeSet = new Set<string>([n.id, ...adj[n.id]]);
      autoSpin = false;
      if (detail && detailTitle && detailBody) {
        detailTitle.textContent = n.label;
        detail.style.setProperty('--acc', n.color);
        const neighbours = [...adj[n.id]].map((id) => byId[id].label);
        let html = '';
        if (n.q)
          html += `<div class="tag-detail-kv"><b>${i18n.passage}</b></div><div class="tag-quote">${esc(n.q)}</div>`;
        if (n.src) html += `<div class="tag-detail-kv"><b>${i18n.source}</b>${esc(n.src)}</div>`;
        if (neighbours.length)
          html +=
            `<div class="tag-detail-kv"><b>${i18n.connected}</b>` +
            neighbours.map((l) => `<span class="tag-detail-chip">${esc(l)}</span>`).join('') +
            `</div>`;
        detailBody.innerHTML = html;
        detail.hidden = false;
      }
      if (reduceMotion) render();
    }
    function hideDetail() {
      selectedId = null;
      activeSet = null;
      if (detail) detail.hidden = true;
      if (!reduceMotion) autoSpin = true;
      if (reduceMotion) render();
    }
    detailClose?.addEventListener('click', hideDetail);

    // Export the automation map as a small JSON workflow file.
    exportBtn?.addEventListener('click', () => {
      const workflow = {
        name: 'TrustAuto — workflow map',
        generatedBy: 'TrustAuto',
        nodes: nodes.map((n) => ({ id: n.id, name: n.label, group: n.group })),
        connections: edges.map((e) => ({ from: byId[e.s].label, to: byId[e.t].label, rel: e.r })),
      };
      const blob = new Blob([JSON.stringify(workflow, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'trustauto-workflow.json';
      a.click();
      URL.revokeObjectURL(url);
    });

    // ── Boot ───────────────────────────────────────────────────────────
    resize();
    root.classList.add('is-ready');
    if ('ResizeObserver' in window) {
      const ro = new ResizeObserver(() => {
        resize();
        if (reduceMotion || !running) render();
      });
      ro.observe(root);
    }
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) start();
            else stop();
          });
        },
        { threshold: 0.05 }
      );
      io.observe(root);
    } else {
      start();
    }
  }
</script>
