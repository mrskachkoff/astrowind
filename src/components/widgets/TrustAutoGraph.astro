---
/**
 * TrustAutoGraph.astro
 * "Your automation stack" map for TrustAuto. It reuses ONLY the visual design of
 * the TrustCore "3D Map" (TrustCoreGraph.astro) — dark navy fds-card surface,
 * aurora accent palette, glow, pill labels, click-a-node → detail panel,
 * status/hint chrome, and the self-contained Canvas-2D pseudo-3D orbit with
 * drag-to-rotate. The content is a genuine automation stack: the Power Automate
 * and n8n engines orchestrating the customer's business apps and a local, on-prem
 * AI layer. Each node is a real product/tool logo drawn as an "app tile", not a
 * coloured dot. The TrustAuto logo is pinned at the top as the brand mark.
 *
 * The dataset is synthetic and PII-free. Pointer-only interactivity (drag to spin,
 * hover to highlight, click for detail). Controls are tabindex=-1 because the host
 * Content widget marks the image column aria-hidden.
 */

import imgPoster from '~/assets/images/ai-workflow-tablet.jpg';
import imgBrand from '~/assets/images/trustauto.png';

// Node logos (copied/rasterized into the committed asset tree — design/ is gitignored).
import icPowerAutomate from '~/assets/images/automation/power-automate.png';
import icN8n from '~/assets/images/automation/n8n.png';
import icM365 from '~/assets/images/automation/microsoft-365.png';
import icInbox from '~/assets/images/automation/inbox.png';
import icCrm from '~/assets/images/automation/crm.png';
import icErp from '~/assets/images/automation/erp.png';
import icFiles from '~/assets/images/automation/files.png';
import icRag from '~/assets/images/automation/rag.png';
import icMistral from '~/assets/images/automation/mistral.png';
import icOllama from '~/assets/images/automation/ollama.png';
import icGemma from '~/assets/images/automation/gemma.png';
import icDeepseek from '~/assets/images/automation/deepseek.png';
import icCheckpoint from '~/assets/images/automation/checkpoint.png';
import icOnPrem from '~/assets/images/automation/on-prem.png';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const STRINGS = {
  en: {
    aria: 'Interactive 3D automation map: the Power Automate and n8n engines orchestrating your business apps and a local AI layer, on your own infrastructure.',
    apps: 'apps',
    models: 'models',
    connected: 'Connected',
    source: 'Role',
    passage: 'What it is',
    close: 'Close',
    hint: 'Drag to rotate · click a node',
  },
  es: {
    aria: 'Mapa de automatización 3D interactivo: los motores Power Automate y n8n orquestando tus aplicaciones empresariales y una capa de IA local, sobre tu propia infraestructura.',
    apps: 'apps',
    models: 'modelos',
    connected: 'Conexiones',
    source: 'Función',
    passage: 'Qué es',
    close: 'Cerrar',
    hint: 'Arrastra para rotar · haz clic en un nodo',
  },
};

const t = STRINGS[lang] ?? STRINGS.en;

// Accent palette (mirrors --fds-acc-* tokens) — used for each tile's glow + border.
const C = {
  engine: '#0065fe', // Power Automate, n8n
  system: '#2d7bf2', // business apps: M365, Inbox, CRM, ERP, Files
  ai: '#a459ff', // local AI layer: RAG + open models
  checkpoint: '#ff2f70', // human-approval gate
  infra: '#83e31e', // on-prem infrastructure
};

const ICON = {
  PA: icPowerAutomate.src,
  N8: icN8n.src,
  M365: icM365.src,
  INB: icInbox.src,
  CRM: icCrm.src,
  ERP: icErp.src,
  FIL: icFiles.src,
  RAG: icRag.src,
  MIS: icMistral.src,
  OLL: icOllama.src,
  GEM: icGemma.src,
  DES: icDeepseek.src,
  CHK: icCheckpoint.src,
  ONP: icOnPrem.src,
