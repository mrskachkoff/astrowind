const dataset = DATA[lang] ?? DATA.en;
// Attach colours + icon URLs server-side so the script needs no palette/asset logic.
const payload = {
  nodes: dataset.nodes.map((n) => ({
    ...n,
    color: C[n.group as keyof typeof C],
    icon: ICON[n.id as keyof typeof ICON],
  })),
  edges: dataset.edges,
  i18n: { connected: t.connected, source: t.source, passage: t.passage, apps: t.apps, models: t.models },
