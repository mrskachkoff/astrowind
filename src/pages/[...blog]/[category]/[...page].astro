---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { blogCategoryRobots, getStaticPathsBlogCategory } from '~/utils/blog';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { useTranslations } from '~/i18n/utils';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogCategory({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths> & { category: Record<string, string> };

const { page, category } = Astro.props as Props;

const currentPage = page.currentPage ?? 1;
const t = useTranslations('en');

const categoryDescriptions: Record<string, string> = {
  'gdpr-and-compliance': 'Practical GDPR compliance guidance for healthcare practices in Spain and the EU — data processing requirements, patient rights, AI deployment under Article 35, and subprocessor management.',
  'healthcare-tech': 'Healthcare technology insights for independent practices — AI automation, clinical workflow optimization, and digital transformation for dental clinics, pharmacies, and medical practices.',
  'ai-automation': 'AI automation strategies for healthcare providers operating under GDPR — from quick-win workflow automations to full on-premise deployments with MedCore Private AI.',
};

const categoryDescription = categoryDescriptions[category.slug] || '';

const metadata = {
  title: `${t('blog.category')} '${category.title}'${currentPage > 1 ? ` — ${t('blog.page')} ${currentPage}` : ''}`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline>{category.title}</Headline>
    {categoryDescription && <p class="text-muted text-lg mb-8 max-w-3xl">{categoryDescription}</p>}
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</Layout>
