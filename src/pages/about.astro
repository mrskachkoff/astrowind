---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'About | Futurion Solutions',
  description:
    'Futurion Solutions is a software company in Valencia. We build TrustPrompt, TrustCore and TrustAuto for legal, compliance, finance and healthcare teams, so sensitive data stays on infrastructure they control.',
  openGraph: {
    images: [{ url: '~/assets/images/team-meeting.jpg' }],
  },
};

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': 'https://solutions.futurion.es/about/#webpage',
    url: 'https://solutions.futurion.es/about/',
    name: 'About Futurion Solutions',
    description:
      'Futurion Solutions builds private AI tools — TrustPrompt, TrustCore and TrustAuto — for legal, compliance, finance and healthcare teams, designed to run on infrastructure the customer controls rather than a shared cloud service.',
    inLanguage: 'en',
    publisher: { '@id': 'https://solutions.futurion.es/#organization' },
    mainEntity: { '@id': 'https://solutions.futurion.es/#organization' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Ivan Skachkov',
    jobTitle: 'Founder',
    worksFor: { '@id': 'https://solutions.futurion.es/#organization' },
    knowsAbout: ['GDPR', 'EU AI Act', 'ISO 27001', 'SOC 2', 'Data Protection', 'Private AI', 'Business Process Design'],
    url: 'https://solutions.futurion.es/about/',
  },
];
---

<Layout metadata={metadata}>
  {aboutSchema.map((s) => <JsonLd schema={s} />)}

  <!-- Hero -->

  <Hero
    tagline="About Futurion Solutions"
    image={{
      src: '~/assets/images/team-collaboration.jpg',
      alt: 'The Futurion Solutions team at work',
    }}
  >
    <Fragment slot="title">
      We build AI that stays<br />
      <span class="text-accent dark:text-white">inside your own boundary</span>
    </Fragment>

    <Fragment slot="subtitle">
      We build solutions for legal, compliance, finance and healthcare teams that care about customer privacy.
    </Fragment>
  </Hero>

  <!-- Why we exist -->

  <Content
    tagline="Why we exist"
    title="Using AI should not create a new place where your data lives"
    items={[
      {
        title: 'What we build',
        description:
          'TrustPrompt removes personal data in the browser before a prompt is sent to a public LLM. TrustCore answers questions about your own documents on your own hardware. TrustAuto is a non-SaaS, fully on-premises compliance control center that connects to your existing systems and continuously checks whether your organisation is meeting the security controls and privacy standards it is held to — SOC 2, ISO 27001, HIPAA and GDPR.',
      },
      {
        title: 'Where it runs',
        description:
          'On your own hardware or your own cloud account. There is no Futurion backend that holds your documents, and nothing is sent to us to make the software work.',
      },
      {
        title: 'How we work',
        description:
          'Each deployment is documented against the obligations you answer to — GDPR, the EU AI Act, ISO 27001 and SOC 2, plus HIPAA and AEPD requirements in healthcare.',
      },
    ]}
    image={{
      src: '~/assets/images/abstract-light.jpg',
      alt: 'Data kept within a defined boundary',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built to remove a data-protection problem, not add one
      </h3>
      Legal, clinical and financial work runs on documents that are privileged, confidential, or personal data under the GDPR. The moment that text is sent to a shared AI service, it lands with a third party that may log or retain it — and for many of these teams that alone is disqualifying. We build software so that using AI does not move the data anywhere new.
    </Fragment>
  </Content>

  <!-- How we build -->

  <Features2
    title="The same commitments in everything we ship"
    subtitle="These are properties of how the software is built, not promises layered on top."
    tagline="How we build"
    items={[
      {
        title: 'No backend to leak',
        description:
          'There is no hosted service that receives your data. The work runs in your browser or on your own machine, so there is no third party in the data path that could leak a document.',
        icon: 'tabler:server-off',
      },
      {
        title: 'On infrastructure you control',
        description:
          'Everything runs on your hardware or your cloud account. For heavier workloads you point the tools at endpoints you already run, rather than ones we introduce.',
        icon: 'tabler:lock',
      },
      {
        title: 'Evidence you can check',
        description:
          'Answers are tied to the exact passage and page they came from, and facts that conflict across documents are flagged with their sources — so a result can be verified, not just trusted.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Mapped to your obligations',
        description:
          'Each deployment is documented against the regulations you answer to, with the records kept inspection-ready.',
        icon: 'tabler:shield-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Features2>

  <!-- Who's behind it -->

  <Content
    isReversed
    tagline="Who's behind it"
    title="A compliance and process background, applied to software"
    items={[
      {
        title: 'Compliance, then code',
        description:
          'The products start from the obligations these teams carry — GDPR, the EU AI Act, ISO 27001, SOC 2 — and are built to satisfy them by design rather than documented around afterwards.',
      },
      {
        title: 'Process before automation',
        description:
          'We map how work actually flows before automating any of it, so the result removes effort instead of digitising a broken process.',
      },
      {
        title: 'Plain answers',
        description:
          'We explain what the software does with your data in clear terms — and what it deliberately does not do.',
      },
    ]}
    image={{
      src: '~/assets/images/business-meeting.jpg',
      alt: 'Working session at Futurion Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Founded by Ivan Skachkov</h3>
      Futurion Solutions was founded by Ivan Skachkov, who works in data protection and business-process design. The company is based in Valencia and works with organisations across Spain and the EU.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- Expertise (kept section, wording realigned) -->

  <Features
    title="Our expertise"
    subtitle="A combination of data-protection knowledge, process design, and applied AI engineering."
    columns={3}
    items={[
      {
        title: 'GDPR & Data Privacy',
        description:
          'EU data-protection law, Spanish AEPD requirements, and the handling obligations that come with confidential and special-category data.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'ISO 27001 & SOC 2',
        description:
          'Security-framework controls applied at a workable scale — proper safeguards without the overhead of a large enterprise programme.',
        icon: 'tabler:certificate',
      },
      {
        title: 'EU AI Act & AI Governance',
        description:
          'The obligations that apply to AI systems handling personal or sensitive data, mapped to each deployment so the use of AI stays accountable.',
        icon: 'tabler:scale',
      },
      {
        title: 'Process Design & Optimisation',
        description:
          'Years of analysing and redesigning workflows. We find the bottlenecks, remove the waste, and fix the process before anything is automated.',
        icon: 'tabler:arrows-sort',
      },
      {
        title: 'Private AI Architecture',
        description:
          'Designing AI systems that run on-premise or in a hybrid setup — local models, retrieval and embeddings on infrastructure you control.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Regulated-Sector Operations',
        description:
          'A working understanding of how legal, compliance, finance and healthcare teams operate, and the data rules each one answers to.',
        icon: 'tabler:building-bank',
      },
    ]}
  />

  <!-- CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Talk to us',
        href: '/contact/',
        icon: 'tabler:arrow-right',
      },
    ]}
    title="Work with data that can't leave your control?"
    subtitle="Tell us what you work with and the rules you operate under. We'll show you what can run on your own infrastructure."
  />
</Layout>
