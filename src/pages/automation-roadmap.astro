---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Free Automation Roadmap for Healthcare Clinics',
  description: 'Get a free 5-7 day AI compliance assessment for your healthcare practice. We map data flows, identify GDPR-safe automations, and deliver a roadmap.',
  openGraph: {
    images: [{ url: '~/assets/images/ai-workflow-tablet.jpg' }],
  },
};

const roadmapSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Free Automation Roadmap for Healthcare Clinics',
  description: 'A free 5-7 day AI compliance assessment for healthcare practices. Includes data flow mapping, GDPR compliance gap analysis, and a prioritised automation roadmap delivered at no cost.',
  inLanguage: 'en',
  provider: { '@id': 'https://solutions.futurion.es/#organization' },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    description: 'Free 5-7 day AI compliance assessment',
  },
  areaServed: [
    { '@type': 'Country', name: 'Spain' },
    { '@type': 'Place', name: 'European Union' },
  ],
  serviceType: 'AI Compliance Assessment',
  url: 'https://solutions.futurion.es/automation-roadmap/',
};
---

<Layout metadata={metadata}>
  <JsonLd schema={roadmapSchema} />

  <!-- Hero -->

  <Hero
    tagline="Automation Roadmap"
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Free Roadmap',
        href: 'https://outlook.office.com/book/FuturionSolutions@futurion.es/',
        target: '_blank',
        icon: 'tabler:clipboard-check',
      },
    ]}
    image={{
      src: '~/assets/images/business-planning.jpg',
      alt: 'Professional reviewing compliance documents',
    }}
  >
    <Fragment slot="title">
      Free 5-7 Day<br />
      <span class="text-accent dark:text-white">Automation Roadmap</span>
    </Fragment>

    <Fragment slot="subtitle">
      We assess your clinic's data handling, map compliance gaps, and identify where AI can safely automate tasks — completely free. You receive a detailed report with risk scores, safe automation recommendations, and a clear roadmap.
    </Fragment>
  </Hero>

  <!-- Value Prop: What You'll Receive -->

  <Features2
    title="What you'll receive"
    subtitle="A comprehensive compliance and automation assessment delivered in 5-7 business days."
    tagline="Deliverables"
    items={[
      {
        title: 'AI & Compliance Risk Score',
        description: 'A clear rating of your clinic\'s data handling practices and automation readiness, with specific risk areas identified.',
        icon: 'tabler:report-analytics',
      },
      {
        title: 'Data Flow Diagram',
        description: 'A visual map of how patient data moves through your clinic — where it\'s stored, who accesses it, and where gaps exist.',
        icon: 'tabler:hierarchy',
      },
      {
        title: 'Automation Feasibility Matrix',
        description: 'A scored analysis of every workflow — which tasks are safe to automate, which are risky, and which should never be automated.',
        icon: 'tabler:table',
      },
      {
        title: 'Implementation Roadmap',
        description: 'A phased plan: fix compliance gaps first, then implement safe automations, then establish ongoing monitoring.',
        icon: 'tabler:road',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Features2>

  <!-- Roadmap Coverage: 5 Blocks -->

  <Features
    title="What we assess"
    subtitle="Our roadmap covers five critical areas that most AI agencies ignore entirely."
    columns={3}
    items={[
      {
        title: 'Clinic Profile & Risk Context',
        description: 'We assess your clinic size, patient volume, digital maturity, and existing tools to determine your risk tier and automation readiness.',
        icon: 'tabler:building-hospital',
      },
      {
        title: 'Data Mapping & GDPR Compliance',
        description: 'We map every patient data flow — intake, records, imaging, billing, communications — and classify each by sensitivity and compliance exposure.',
        icon: 'tabler:database',
      },
      {
        title: 'Process Bottleneck Analysis',
        description: 'We identify admin-heavy workflows, score each by manual effort, error risk, and data sensitivity, then shortlist safe automation candidates.',
        icon: 'tabler:analyze',
      },
      {
        title: 'AI Risk & Architecture Assessment',
        description: 'For each automation candidate, we evaluate whether cloud, hybrid, or on-prem AI is appropriate — with GDPR article references for each decision.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Compliance Gap & Action Plan',
        description: 'We identify missing documentation, unsafe data handling, and governance gaps — then turn findings into a clear, prioritized implementation plan.',
        icon: 'tabler:checklist',
      },
    ]}
  />

  <!-- Process Timeline -->

  <Steps
    title="How the roadmap works"
    subtitle="A structured process that respects your time while delivering thorough results."
    items={[
      {
        title: 'Day 1: <span class="font-medium">Initial Consultation</span>',
        description: 'A 60-75 minute guided conversation about your clinic\'s operations, tools, data handling, and pain points. No technical jargon — we ask questions you can answer.',
        icon: 'tabler:messages',
      },
      {
        title: 'Days 2-3: <span class="font-medium">Data Mapping & Analysis</span>',
        description: 'We map your data flows, classify sensitive information, and analyze every workflow for automation potential and compliance exposure.',
        icon: 'tabler:search',
      },
      {
        title: 'Days 4-5: <span class="font-medium">Risk Assessment & Architecture</span>',
        description: 'We evaluate AI options for each process, determine safe architectures (on-prem vs. hybrid), and identify compliance gaps.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Days 6-7: <span class="font-medium">Report & Recommendations</span>',
        description: 'You receive a complete report: risk scores, data flow diagrams, automation matrix, and a clear implementation roadmap you can act on — with or without us.',
        icon: 'tabler:file-report',
      },
    ]}
    image={{
      src: '~/assets/images/strategy-session.jpg',
      alt: 'Structured planning process',
    }}
  />

  <!-- Who It's For -->

  <Content
    isReversed
    tagline="Is this for you?"
    title="Built for healthcare"
    items={[
      {
        title: 'Dental clinics with 1-10 employees',
        description: 'Solo practitioners to small group practices dealing with appointment management, patient communications, and billing.',
      },
      {
        title: 'Independent pharmacies',
        description: 'Pharmacies handling patient data, prescription workflows, and supplier communications that need compliance-safe automation.',
      },
      {
        title: 'Small medical clinics (2-5 practitioners)',
        description: 'Multi-practitioner clinics with high admin overhead, complex scheduling, and patient data compliance requirements.',
      },
      {
        title: 'Practice owners who are...',
        description: 'Overwhelmed by administrative tasks, concerned about data privacy with new technology, or considering hiring additional staff to handle the workload.',
      },
    ]}
    image={{
      src: '~/assets/images/medical-office.jpg',
      alt: 'Dental clinic environment',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">You don't need a big IT budget</h3>
      Our roadmap is designed for practices that don't have dedicated IT teams or compliance officers — that's exactly why it's valuable.
      Recent clinical AI availability issues, including <a href="/openevidence-eu-uk-withdrawal-private-on-prem-sovereign-cloud/" class="underline font-bold">OpenEvidence's EU/UK withdrawal</a>, are exactly the kind of architecture risk we assess before automation begins.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- Specific Deliverables -->

  <Features2
    title="What's in the report"
    subtitle="Every roadmap delivers these specific, actionable outputs."
    items={[
      {
        title: 'Executive Risk Summary',
        description: 'A 2-page overview for practice owners — clear language, no jargon, focused on what matters for your business.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Compliance Gap List',
        description: 'Every missing document, unsafe practice, and governance gap — prioritized by risk level and effort to fix.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Safe / Unsafe / Conditional AI List',
        description: 'Each workflow clearly rated: what\'s safe to automate, what requires conditions, and what should never be automated.',
        icon: 'tabler:traffic-lights',
      },
      {
        title: 'Approved Architecture Plan',
        description: 'For each safe automation, the recommended approach — on-prem, hybrid, or (rarely) cloud — with GDPR justification.',
        icon: 'tabler:server',
      },
      {
        title: 'Workflow Automation Matrix',
        description: 'Every admin process scored by manual effort, error risk, data sensitivity, automation potential, and compliance exposure.',
        icon: 'tabler:table',
      },
      {
        title: 'Phased Implementation Roadmap',
        description: 'Phase 1: Fix compliance risks. Phase 2: Implement safe automations. Phase 3: Establish ongoing monitoring and optimization.',
        icon: 'tabler:road',
      },
    ]}
  />

  <!-- Roadmap FAQs -->

  <FAQs
    title="Roadmap Questions"
    subtitle="Common questions about the free automation roadmap."
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How much of my time does it require?',
        description: 'About 2-3 short conversations totaling 60-75 minutes. We do the heavy analysis work. Your role is to answer questions about your current operations and tools.',
      },
      {
        title: 'Is there really no obligation?',
        description: 'None. You receive a complete report you can act on independently. About 40-60% of clinics that complete a roadmap choose to proceed with implementation, but there is no pressure or commitment required.',
      },
      {
        title: 'What if you find serious compliance issues?',
        description: 'We report them clearly and prioritize them in your roadmap. This happens frequently — most clinics have gaps they\'re unaware of. We never use findings to pressure you. We present facts and recommendations.',
      },
      {
        title: 'Can we implement the recommendations ourselves?',
        description: 'Yes. The report is designed to be actionable regardless of whether you work with us. We include specific steps, not vague suggestions. Many practices fix simple compliance gaps on their own.',
      },
      {
        title: 'Why do you offer this for free?',
        description: 'The roadmap builds trust and demonstrates our expertise. When practices see the depth of analysis and the quality of recommendations, many choose to work with us for implementation. It\'s our way of proving value before asking for a commitment.',
      },
      {
        title: 'What happens after the roadmap?',
        description: 'We present the report and walk you through the findings. If you want to proceed with implementation, we provide a fixed-price proposal based on the roadmap findings. If not, you keep the report with no strings attached.',
      },
    ]}
  />

  <!-- Urgency CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Free Roadmap Now',
        href: 'https://outlook.office.com/book/FuturionSolutions@futurion.es/',
        target: '_blank',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Limited to 8 Roadmaps Per Month</Fragment>

    <Fragment slot="subtitle">
      Each roadmap receives our full attention — thorough analysis, detailed reporting, and personalized recommendations. We limit capacity to maintain quality. Secure your spot today.
    </Fragment>
  </CallToAction>

  <!-- Hero -->

  <Hero
    tagline="Our Services"
    title="AI Automation That Puts Compliance First"
    subtitle="From your Automation Roadmap to ongoing support, we deliver AI solutions designed with healthcare data privacy at their core. Service pillars that work together to transform your practice safely — with enterprise-grade options for larger organizations."
    actions={[
      { variant: 'primary', text: 'Start with Automation Roadmap', href: '/automation-roadmap/', icon: 'tabler:clipboard-check' },
    ]}
    image={{
      src: '~/assets/images/team-working.jpg',
      alt: 'Professional team working together',
    }}
  />

  <!-- Service Overview: 3 Pillars -->

  <Features2
    title="Our service pillars"
    subtitle="Each service builds on the previous one, creating a complete compliance-first automation system for your practice — with enterprise options for larger organizations."
    columns={2}
    items={[
      {
        title: 'Free Automation Roadmap',
        description: 'A 5-7 day assessment of your data flows, compliance posture, and automation opportunities. You receive a detailed report with risk scores and a clear roadmap.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Compliant Implementation',
        description: 'We build and deploy AI automations using on-prem or hybrid architectures. Every solution is designed with GDPR principles from day one.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Ongoing Support & Monitoring',
        description: 'Continuous optimization, compliance updates as regulations evolve, and performance monitoring. Your long-term AI compliance partner.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'MedCore Private AI (Enterprise)',
        description: 'Fully on-premise, medical-grade AI infrastructure for medium healthcare organizations. Purpose-built LLMs, fine-tuning, and complete data sovereignty.',
        icon: 'tabler:server-2',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Features2>

  <!-- Service 1: Free Automation Roadmap (Detail) -->

  <Content
    isReversed
    tagline="Service 1"
    title="Free Automation Roadmap"
    items={[
      {
        title: 'Clinic profile & risk assessment',
        description: 'We evaluate your clinic size, patient volume, digital maturity, and existing tools to determine your risk tier.',
      },
      {
        title: 'Complete data flow mapping',
        description: 'Patient intake, records, imaging, billing, communications — every data flow mapped and classified by sensitivity.',
      },
      {
        title: 'Process bottleneck analysis',
        description: 'Each workflow scored by manual effort, error risk, data sensitivity, and automation potential.',
      },
      {
        title: 'AI architecture recommendations',
        description: 'Cloud, hybrid, or on-prem — we determine the safe approach for each process with GDPR justification.',
      },
    ]}
    image={{
      src: '~/assets/images/business-planning.jpg',
      alt: 'Professional analyzing documents',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Where it all starts</h3>
      A thorough risk and process assessment with AI feasibility overlay. Not a sales pitch — a genuine assessment you can act on independently. Delivered in 5-7 business days.
    </Fragment>
  </Content>

  <!-- Service 2: Implementation -->

  <Content
    isAfterContent
    tagline="Service 2"
    title="Compliant AI Implementation"
    items={[
      {
        title: 'Quick-win automations (€1,500-3,000)',
        description: '1-2 high-impact automations deployed in 2-4 weeks. Appointment reminders, patient follow-ups, or billing workflows.',
      },
      {
        title: 'Comprehensive packages (€5,000-15,000)',
        description: 'Full practice transformation over 6-12 weeks. Multiple workflow automations with integrated compliance controls.',
      },
      {
        title: 'On-prem & hybrid architecture',
        description: 'Patient data stays in your clinic. We design solutions that work locally, with external AI only for non-sensitive tasks.',
      },
      {
        title: 'Built-in compliance controls',
        description: 'Audit trails, data processing agreements, consent management, and documentation — all included from day one.',
      },
    ]}
    image={{
      src: '~/assets/images/data-analytics.jpg',
      alt: 'Technology implementation and dashboard',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">From roadmap to results</h3>
      We don't just digitize broken workflows — we fix them first, then automate them. You get efficiency gains that actually stick, with compliance built in from day one.
    </Fragment>
  </Content>

  <!-- Service 3: Ongoing Support -->

  <Content
    isReversed
    tagline="Service 3"
    title="Ongoing Support & Monitoring"
    items={[
      {
        title: 'Monthly support (from €200/month)',
        description: 'Dedicated support for your automations — troubleshooting, adjustments, and optimization as your practice evolves.',
      },
      {
        title: 'Compliance updates',
        description: 'Regulations change. We update your compliance controls and documentation as GDPR, AEPD, and AI Act requirements evolve.',
      },
      {
        title: 'Performance monitoring',
        description: 'Regular reviews of automation performance, time savings metrics, and opportunities for further optimization.',
      },
      {
        title: 'New automation opportunities',
        description: 'As your practice grows, we identify additional workflows that can be safely automated — building on the foundation already in place.',
      },
    ]}
    image={{
      src: '~/assets/images/team-meeting.jpg',
      alt: 'Team providing ongoing support',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Your long-term AI partner</h3>
      We're not interested in one-time projects. We build long-term partnerships with healthcare practices that want to modernize their operations while maintaining compliance.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>
</Layout>

<script>
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a[href*="outlook.office.com/book"]');
    if (!link) return;
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', {
        event_category: 'Roadmap',
        event_label: 'Automation Roadmap',
        language: 'en',
      });
    }
  });
</script>
