---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
  description: 'Get in touch with Futurion Solutions. Questions about compliance-first AI automation for your healthcare practice? We respond within 24 business hours.',
  openGraph: {
    images: [{ url: '~/assets/images/team-collaboration.jpg' }],
  },
};
---

<Layout metadata={metadata}>
  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://solutions.futurion.es/contact/",
    "url": "https://solutions.futurion.es/contact/",
    "name": "Contact Futurion Solutions",
    "description": "Get in touch with Futurion Solutions for compliance-first AI automation for your healthcare practice.",
    "inLanguage": "en",
    "publisher": { "@id": "https://solutions.futurion.es/#organization" }
  }} />

  <!-- HeroText -->

  <HeroText
    tagline="Contact Us"
    title="Let's Talk About Your Practice"
    subtitle="Have questions about compliance-first AI automation? Want to learn how we can help your healthcare practice save time while staying compliant? We'd love to hear from you."
  />

  <ContactUs
    id="form"
    title="Send us a message"
    subtitle="Whether you have a question about our services, want to discuss your practice's needs, or are ready to start your free Automation Roadmap — drop us a line."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Your Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email Address',
      },
      {
        type: 'text',
        name: 'practice_name',
        label: 'Practice Name (optional)',
      },
      {
        type: 'text',
        name: 'inquiry_type',
        label: 'Inquiry Type (e.g., Automation Roadmap, Services, General Question)',
      },
    ]}
    textarea={{
      label: 'Your Message',
      name: 'message',
      placeholder: 'Tell us about your practice and how we can help...',
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to the collection of your information for the purpose of responding to your inquiry. Your data is processed in accordance with our Privacy Policy and GDPR requirements.',
    }}
    button="Send Message"
    description="We respond within 24 business hours."
  />

  <!-- Contact Info -->

  <Features2
    title="Other ways to reach us"
    subtitle="Follow us for compliance insights and product updates."
    items={[
      {
        title: 'Facebook',
        description: 'Follow us on Facebook for updates and announcements.',
        icon: 'tabler:brand-facebook',
        callToAction: {
          text: 'Visit Facebook',
          href: 'https://www.facebook.com/solutions.futurion.es/',
          target: '_blank',
          variant: 'link',
        },
      },
      {
        title: 'LinkedIn',
        description: 'Connect with us on LinkedIn for compliance insights and updates.',
        icon: 'tabler:brand-linkedin',
        callToAction: {
          text: 'Visit LinkedIn',
          href: 'https://www.linkedin.com/company/111621147/',
          target: '_blank',
          variant: 'link',
        },
      },
      {
        title: 'Instagram',
        description: 'Follow us on Instagram for behind-the-scenes updates.',
        icon: 'tabler:brand-instagram',
        callToAction: {
          text: 'Visit Instagram',
          href: 'https://www.instagram.com/solutions.futurion.es/',
          target: '_blank',
          variant: 'link',
        },
      },
    ]}
  />
</Layout>
