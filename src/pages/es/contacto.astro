---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contacto',
  description: 'Ponte en contacto con Futurion Solutions. ¿Preguntas sobre automatización IA centrada en cumplimiento para tu consulta sanitaria? Respondemos en 24 horas laborables.',
  openGraph: {
    images: [{ url: '~/assets/images/team-collaboration.jpg' }],
  },
};
---

<Layout metadata={metadata}>
  <!-- HeroText -->

  <HeroText
    tagline="Contáctanos"
    title="Hablemos sobre tu consulta"
    subtitle="¿Tienes preguntas sobre automatización IA centrada en cumplimiento? ¿Quieres saber cómo podemos ayudar a tu consulta sanitaria a ahorrar tiempo manteniendo el cumplimiento normativo? Nos encantaría escucharte."
  />

  <ContactUs
    id="form"
    title="Envíanos un mensaje"
    subtitle="Tanto si tienes una pregunta sobre nuestros servicios, como si quieres hablar sobre las necesidades de tu consulta o ya estás listo para empezar con tu Hoja de Ruta de Automatización gratuita, déjanos un mensaje."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Tu nombre',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Dirección de Correo Electrónico',
      },
      {
        type: 'text',
        name: 'practice_name',
        label: 'Nombre de la Consulta (opcional)',
      },
      {
        type: 'text',
        name: 'inquiry_type',
        label: 'Tipo de consulta (p. ej., Hoja de Ruta de Automatización, Servicios, Pregunta general)',
      },
    ]}
    textarea={{
      label: 'Tu mensaje',
      name: 'message',
      placeholder: 'Cuéntanos sobre tu consulta y cómo podemos ayudar...',
    }}
    disclaimer={{
      label:
        'Al enviar este formulario, aceptas la recopilación de tu información con el propósito de responder a tu consulta. Tus datos se procesan de acuerdo con nuestra Política de Privacidad y los requisitos del RGPD.',
    }}
    button="Enviar mensaje"
    description="Respondemos en 24 horas laborables."
  />

  <!-- Información de Contacto -->

  <Features2
    title="Otras formas de contactarnos"
    items={[
      {
        title: 'Hoja de Ruta de Automatización',
        description:
          '¿Listo para comenzar? Comienza con tu hoja de ruta gratuita de automatización (5-7 días) directamente en nuestra página dedicada.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'LinkedIn',
        description: 'Conéctate con nosotros en LinkedIn para obtener información sobre cumplimiento normativo y estar al día de las novedades.',
        icon: 'tabler:brand-linkedin',
      },
      {
        title: 'Ubicación',
        description: 'Valencia, España — Trabajamos con consultas sanitarias de toda España y la UE.',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
