---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';

const metadata = {
  title: 'Hoja de Ruta de Automatización Sanitaria Gratuita',
  description: 'Hoja de ruta de automatización RGPD gratuita en 5-7 días para consultas sanitarias. Identificamos automatizaciones seguras y entregamos un plan de acción.',
  openGraph: {
    images: [{ url: '~/assets/images/ai-workflow-tablet.jpg' }],
  },
};

const roadmapSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Hoja de Ruta de Automatización Sanitaria Gratuita',
  description: 'Evaluación gratuita de automatización IA en 5-7 días para consultas sanitarias. Incluye mapeo de flujos de datos, análisis de brechas RGPD y una hoja de ruta de automatización priorizada sin coste.',
  inLanguage: 'es',
  provider: { '@id': 'https://solutions.futurion.es/#organization' },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    description: 'Evaluación de automatización IA gratuita en 5-7 días',
  },
  areaServed: [
    { '@type': 'Country', name: 'Spain' },
    { '@type': 'Place', name: 'European Union' },
  ],
  serviceType: 'Evaluación de Cumplimiento IA',
  url: 'https://solutions.futurion.es/es/hoja-de-ruta-de-automatizacion/',
};

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Precios de Servicios de Automatización IA — Futurion Solutions',
  description: 'Precios transparentes para automatización IA centrada en cumplimiento para proveedores sanitarios en España y la UE.',
  inLanguage: 'es',
  provider: { '@id': 'https://solutions.futurion.es/#organization' },
  url: 'https://solutions.futurion.es/es/hoja-de-ruta-de-automatizacion/',
  itemListElement: [
    {
      '@type': 'Offer',
      name: 'Hoja de Ruta de Automatización',
      description: 'Evaluación gratuita de automatización IA en 5-7 días con mapeo de flujos de datos, análisis de brechas y hoja de ruta priorizada.',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
      url: 'https://solutions.futurion.es/es/hoja-de-ruta-de-automatizacion/',
    },
    {
      '@type': 'Offer',
      name: 'Implementación Quick-Win',
      description: '1-2 automatizaciones de alto impacto entregadas en 2-4 semanas. Arquitectura local o híbrida con controles de cumplimiento RGPD.',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: '1500',
        priceCurrency: 'EUR',
      },
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'Paquete Integral',
      description: 'Transformación completa de la consulta en 6-12 semanas. Múltiples automatizaciones con marco de cumplimiento integrado y formación del personal.',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: '5000',
        priceCurrency: 'EUR',
      },
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'MedCore Private AI',
      description: 'Infraestructura IA de grado médico completamente local para organizaciones sanitarias medianas. Precio por proyecto.',
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: '25000',
        priceCurrency: 'EUR',
      },
      availability: 'https://schema.org/InStock',
      url: 'https://solutions.futurion.es/es/medcore-ia-privada/',
    },
  ],
};
---

<Layout metadata={metadata}>
  <JsonLd schema={roadmapSchema} />

  <!-- Hero -->

  <Hero
    tagline="Hoja de Ruta de Automatización"
    actions={[
      {
        variant: 'primary',
        text: 'Solicita tu hoja de ruta gratuita',
        href: 'https://outlook.office.com/book/FuturionSolutions@futurion.es/',
        target: '_blank',
        icon: 'tabler:arrow-right',
      },
    ]}
    image={{
      src: '~/assets/images/business-planning.jpg',
      alt: 'Profesional revisando documentos de cumplimiento',
    }}
  >
    <Fragment slot="title">
      5-7 Días Gratuitos<br />
      <span class="text-accent dark:text-white">Hoja de Ruta de Automatización</span>
    </Fragment>

    <Fragment slot="subtitle">
      Evaluamos el manejo de datos de tu clínica, mapeamos brechas de cumplimiento e identificamos dónde la IA puede automatizar tareas de forma segura — completamente gratis. Recibe un informe detallado con puntuaciones de riesgo, recomendaciones de automatización segura y una hoja de ruta clara.
    </Fragment>
  </Hero>

  <!-- Process Timeline -->

  <Steps
    title="Cómo funciona la hoja de ruta"
    subtitle="Un proceso estructurado de una semana que respeta tu tiempo y cubre las cinco áreas críticas de evaluación."
    items={[
      {
        title: 'Día 1: <span class="font-medium">Consulta Inicial</span>',
        description: 'Una conversación guiada de 60-75 minutos sobre las operaciones, herramientas, manejo de datos y puntos débiles de tu clínica, sin jerga técnica. Aquí evaluamos el <span class="font-medium">perfil de clínica y contexto de riesgo</span>: tamaño, madurez digital y herramientas existentes, para determinar tu nivel de riesgo y preparación para la automatización.',
        icon: 'tabler:messages',
      },
      {
        title: 'Días 2-3: <span class="font-medium">Mapeo de Datos y Análisis</span>',
        description: 'Mapeamos cada flujo de datos de pacientes — admisión, registros, imágenes, facturación, comunicaciones — clasificando cada uno por sensibilidad y exposición al <span class="font-medium">cumplimiento RGPD</span>. En paralelo, un <span class="font-medium">análisis de cuellos de botella en procesos</span> puntúa cada flujo de trabajo con alta carga administrativa por esfuerzo manual, riesgo de error y sensibilidad de datos, para preseleccionar los candidatos seguros a automatización.',
        icon: 'tabler:search',
      },
      {
        title: 'Días 4-5: <span class="font-medium">Evaluación de Riesgo y Arquitectura</span>',
        description: 'Para cada proceso candidato, una <span class="font-medium">evaluación de riesgo y arquitectura de IA</span> determina si la solución más adecuada es en la nube, híbrida o en local — reservando la IA externa exclusivamente para tareas no sensibles, con referencias al artículo del RGPD correspondiente a cada decisión.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Días 6-7: <span class="font-medium">Informe y Recomendaciones</span>',
        description: 'Convertimos los hallazgos en una <span class="font-medium">brecha de cumplimiento y plan de acción</span>: documentación faltante, manejo inseguro de datos y brechas de gobernanza, priorizados en un plan claro. Recibes un informe escrito completo sobre el que puedes actuar de inmediato, con nosotros o por tu cuenta. El apartado siguiente detalla exactamente qué contiene.',
        icon: 'tabler:file-report',
      },
    ]}
    image={{
      src: '~/assets/images/strategy-session.jpg',
      alt: 'Proceso de planificación estructurada',
    }}
  />

  <!-- Who It's For -->

  <Content
    isReversed
    tagline="¿Es esto para ti?"
    title="Diseñado para el sector sanitario"
    items={[
      {
        title: 'Clínicas dentales con 1-10 empleados',
        description: 'Desde profesionales individuales hasta pequeñas prácticas grupales que gestionan citas, comunicaciones con pacientes y facturación.',
      },
      {
        title: 'Farmacias independientes',
        description: 'Farmacias que manejan datos de pacientes, flujos de trabajo de prescripciones y comunicaciones con proveedores que necesitan automatización conforme al cumplimiento.',
      },
      {
        title: 'Pequeñas clínicas médicas (2-5 profesionales)',
        description: 'Clínicas multiprofesionales con alta carga administrativa, programación compleja y requisitos de cumplimiento de datos de pacientes.',
      },
      {
        title: 'Propietarios de prácticas que están...',
        description: 'Abrumados por tareas administrativas, preocupados por la privacidad de datos con nuevas tecnologías, o considerando contratar personal adicional para manejar la carga de trabajo.',
      },
    ]}
    image={{
      src: '~/assets/images/medical-office.jpg',
      alt: 'Ambiente de clínica dental',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">No necesitas un gran presupuesto de TI</h3>
      Nuestra hoja de ruta está diseñada para consultas que no tienen equipos de TI dedicados ni responsables de cumplimiento — eso es exactamente por qué es valiosa.
      Problemas recientes de disponibilidad de IA clínica, como la <a href="/es/es-retirada-openevidence-ue-reino-unido-sanidad-on-premise-nube-soberana/" class="underline font-bold">retirada de OpenEvidence de la UE y Reino Unido</a>, son precisamente el tipo de riesgo arquitectónico que evaluamos antes de automatizar.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- Specific Deliverables -->

  <FeaturesCarousel
    id="entregables"
    tagline="Entregables"
    title="Qué incluye el informe"
    subtitle="Cada hoja de ruta entrega estos resultados específicos y accionables — una evaluación integral de cumplimiento y automatización en 5-7 días laborables."
    items={[
      {
        title: 'Resumen Ejecutivo de Riesgo y Puntuación',
        description: 'Una visión general de 2 páginas en lenguaje claro — sin jerga — con una calificación clara de tu manejo de datos y tu preparación para la automatización que señala tus áreas de riesgo específicas.',
        icon: 'tabler:report-analytics',
      },
      {
        title: 'Diagrama de Flujo de Datos',
        description: 'Un mapa visual de cómo se mueven los datos de pacientes a través de tu clínica — dónde se almacenan, quién accede a ellos y dónde existen brechas.',
        icon: 'tabler:hierarchy',
      },
      {
        title: 'Lista de Brechas de Cumplimiento',
        description: 'Cada documento faltante, práctica insegura y brecha de gobernanza — priorizados por nivel de riesgo y esfuerzo para corregir.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Lista de IA Segura / Insegura / Condicional',
        description: 'Cada flujo de trabajo claramente calificado: qué es seguro automatizar, qué requiere condiciones y qué nunca debe automatizarse.',
        icon: 'tabler:traffic-lights',
      },
      {
        title: 'Matriz de Automatización de Flujos de Trabajo',
        description: 'Cada proceso administrativo puntuado por esfuerzo manual, riesgo de error, sensibilidad de datos, potencial de automatización y exposición al cumplimiento.',
        icon: 'tabler:table',
      },
      {
        title: 'Plan de Arquitectura Aprobado',
        description: 'Para cada automatización segura, el enfoque recomendado — local, híbrido o (raramente) nube — con justificación RGPD.',
        icon: 'tabler:server',
      },
      {
        title: 'Hoja de Ruta de Implementación por Fases',
        description: 'Fase 1: Corregir riesgos de cumplimiento. Fase 2: Implementar automatizaciones seguras. Fase 3: Establecer monitorización continua y optimización.',
        icon: 'tabler:road',
      },
    ]}
  />

  <!-- Precios -->

  <JsonLd schema={pricingSchema} />

  <HeroText
    tagline="Precios"
    title="Precios Transparentes, Sin Costes Ocultos"
    subtitle="Cada proceso empieza con una hoja de ruta gratuita. Los precios de implementación y soporte se basan en las necesidades específicas de tu consulta — sin sorpresas."
  />

  <!-- Niveles de servicio -->

  <Prices
    title="Nuestros niveles de servicio"
    subtitle="Comienza gratis, escala según necesites"
    prices={[
      {
        title: 'Hoja de Ruta de Automatización',
        subtitle: 'El mejor lugar para empezar',
        price: 0,
        period: 'única',
        items: [
          { description: 'Evaluación completa de 5-7 días' },
          { description: 'Mapeo y clasificación de flujos de datos' },
          { description: 'Análisis de brechas de cumplimiento' },
          { description: 'Matriz de viabilidad de automatización' },
          { description: 'Hoja de ruta de implementación' },
        ],
        callToAction: {
          text: 'Solicitar Hoja de Ruta Gratuita',
          href: '/es/hoja-de-ruta-de-automatizacion/',
        },
      },
      {
        title: 'Implementación de Mejora Inmediata',
        subtitle: '1-2 automatizaciones de alto impacto',
        price: '1.500',
        period: 'desde',
        items: [
          { description: '1-2 automatizaciones específicas' },
          { description: 'Entrega en 2-4 semanas' },
          { description: 'Arquitectura local o híbrida' },
          { description: 'Controles de cumplimiento RGPD incluidos' },
          { description: 'Registros de auditoría, acuerdos de tratamiento de datos y gestión del consentimiento' },
          { description: '30 días de soporte post-lanzamiento' },
        ],
        callToAction: {
          text: 'Comenzar con la Hoja de Ruta Gratuita',
          href: '/es/hoja-de-ruta-de-automatizacion/',
        },
        hasRibbon: true,
        ribbonTitle: 'más popular',
      },
      {
        title: 'Paquete Completo',
        subtitle: 'Transformación completa de la consulta',
        price: '5.000',
        period: 'desde',
        items: [
          { description: 'Múltiples automatizaciones de flujos' },
          { description: 'Entrega en 6-12 semanas' },
          { description: 'Marco de cumplimiento integrado' },
          { description: 'Formación del personal incluida' },
          { description: 'Documentación completa' },
          { description: '90 días de soporte post-lanzamiento' },
        ],
        callToAction: {
          text: 'Comenzar con la Hoja de Ruta Gratuita',
          href: '/es/hoja-de-ruta-de-automatizacion/',
        },
      },
      {
        title: 'MedCore Private AI',
        subtitle: 'Plataforma IA médica empresarial',
        price: 'Personalizado',
        period: 'Contacta para presupuesto',
        items: [
          { description: 'Despliegue IA local' },
          { description: 'Modelos de lenguaje de grado médico' },
          { description: 'Ajuste fino y pipelines RAG' },
          { description: 'Hardware de servidor incluido' },
          { description: 'Multicumplimiento (RGPD, HIPAA, SOC2)' },
          { description: 'Soporte multilingüe UE' },
          { description: 'Gestión de ciclo de vida completo' },
        ],
        callToAction: {
          text: 'Programar Consulta',
          href: '/es/contacto/',
        },
      },
    ]}
  />

  <!-- Roadmap FAQs -->

  <FAQs
    title="Preguntas sobre la Hoja de Ruta"
    subtitle="Preguntas comunes sobre la hoja de ruta de automatización."
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Cuánto tiempo requiere de mi parte?',
        description: 'Aproximadamente 2-3 conversaciones breves totalizando 60-75 minutos. Nosotros hacemos el trabajo de análisis pesado. Tu papel es responder preguntas sobre tus operaciones y herramientas actuales.',
      },
      {
        title: '¿Realmente no hay ninguna obligación?',
        description: 'Ninguna. Recibes un informe completo con el que puedes actuar de forma independiente. No hay ningún tipo de presión ni compromiso.',
      },
      {
        title: '¿Qué pasa si encuentran problemas graves de cumplimiento?',
        description: 'Los comunicamos claramente y los priorizamos en tu hoja de ruta. Esto sucede con frecuencia — la mayoría de las clínicas tienen brechas de las que no son conscientes. Nunca usamos los hallazgos para presionarte. Presentamos hechos y recomendaciones.',
      },
      {
        title: '¿Podemos implementar las recomendaciones nosotros mismos?',
        description: 'Sí. El informe está diseñado para ser accionable independientemente de si trabaja con nosotros. Incluimos pasos específicos, no sugerencias vagas. Muchas prácticas corrigen brechas simples de cumplimiento por su cuenta.',
      },
      {
        title: '¿Qué sucede después de la hoja de ruta?',
        description: 'Presentamos el informe y te guiamos a través de los hallazgos. Si deseas proceder con la implementación, proporcionamos una propuesta de precio fijo basada en los hallazgos de la hoja de ruta. Si no, conservas el informe sin compromiso.',
      },
      {
        title: '¿Por qué la hoja de ruta es gratuita?',
        description:
          'La hoja de ruta genera confianza y demuestra nuestra experiencia. Cuando las consultas ven la profundidad del análisis, muchas eligen proceder con la implementación. Es nuestra forma de demostrar valor antes de pedir un compromiso. Alrededor del 40-60% de las clínicas que completan la hoja de ruta proceden.',
      },
      {
        title: '¿Cómo se determinan los precios de implementación?',
        description:
          'Los precios se basan en los hallazgos de la hoja de ruta — número de flujos a automatizar, complejidad y requisitos de cumplimiento. Proporcionamos una propuesta a precio fijo después de la hoja de ruta para que no haya sorpresas. Las mejoras inmediatas suelen rondar entre 1.500 y 3.000 €; el paquete completo, entre 5.000 y 15.000 €.',
      },
      {
        title: '¿Es obligatorio el plan de soporte mensual?',
        description:
          'No. El soporte mensual es opcional pero recomendado. Las regulaciones cambian, las automatizaciones necesitan ajustes y surgen nuevas oportunidades. El plan de soporte garantiza que tus automatizaciones se mantengan conformes y optimizadas con el tiempo.',
      },
      {
        title: '¿Qué métodos de pago aceptáis?',
        description:
          'Aceptamos transferencias bancarias y métodos de pago principales comunes en España y la UE. Las condiciones de pago se acuerdan durante la fase de propuesta — normalmente un 50% por adelantado y un 50% a la entrega para proyectos de implementación.',
      },
      {
        title: '¿Podemos empezar pequeño y expandir después?',
        description:
          'Por supuesto. Ese es nuestro enfoque recomendado. Comienza con la hoja de ruta gratuita, implementa 1-2 mejoras inmediatas, ve los resultados y luego decide si un paquete completo tiene sentido. Sin presión para comprometerte con todo por adelantado.',
      },
      {
        title: '¿Cuánto cuesta MedCore Private AI?',
        description:
          'MedCore Private AI tiene un precio por proyecto basado en el alcance de infraestructura, requisitos de modelos y tamaño de organización. Los despliegues típicos van de €25.000 a €150.000+, con planes de soporte mensual disponibles. Esto incluye especificación y adquisición de hardware, despliegue de software, personalización de modelos, documentación de cumplimiento y formación. Contáctanos para una evaluación detallada y presupuesto.',
      },
    ]}
  />

  <!-- CTA de Precios -->

  <CallToAction
    title="Cada proceso empieza con una hoja de ruta gratuita"
    subtitle="Sin compromiso. Conoce con claridad tus oportunidades de automatización y tu situación de cumplimiento antes de tomar ninguna decisión."
    actions={[
      {
        variant: 'primary',
        text: 'Reserva tu hoja de ruta gratuita',
        href: '/es/hoja-de-ruta-de-automatizacion/',
        icon: 'tabler:arrow-right',
      },
    ]}
  />
</Layout>

<script>
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a[href*="outlook.office.com/book"]');
    if (!link) return;
    if (typeof window.gtag === 'function') {
      window.gtag('event', 'generate_lead', {
        event_category: 'Roadmap',
        event_label: 'Automation Roadmap',
        language: 'es',
      });
    }
  });
</script>
