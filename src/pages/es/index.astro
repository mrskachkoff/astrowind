---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { Image as AstroImage } from 'astro:assets';
import colab3Banner from '~/assets/images/colab3_banner.jpg';
import ComplianceAutomationMap from '~/components/widgets/ComplianceAutomationMap.astro';
import TrustCoreGraph from '~/components/widgets/TrustCoreGraph.astro';

const metadata = {
  title: 'Futurion Solutions — IA Privada para Organizaciones Reguladas',
  description: 'Herramientas de IA privada y automatización que mantienen los datos sensibles dentro de su propio perímetro — en su hardware o en su cuenta cloud. Mapeadas a RGPD, el Reglamento de IA de la UE, ISO 27001 y SOC 2.',
  ignoreTitleTemplate: true,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué hace Futurion Solutions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desarrollamos herramientas de IA privada — TrustPrompt y TrustCore — y gestionamos una práctica de automatización, TrustAuto, para organizaciones que trabajan con datos sensibles o regulados. Todo está diseñado para funcionar en infraestructura bajo su control, no en un servicio cloud compartido."
      }
    },
    {
      "@type": "Question",
      "name": "¿Salen los datos de nuestra propia infraestructura?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. TrustPrompt analiza el texto en el navegador, TrustCore responde a partir de documentos en su propia máquina, y las automatizaciones de TrustAuto se ejecutan en local o en una configuración híbrida. Los datos sensibles permanecen dentro de su perímetro."
      }
    },
    {
      "@type": "Question",
      "name": "¿A qué marcos de cumplimiento se mapean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "RGPD, el Reglamento de IA de la UE, ISO 27001 y SOC 2, además de HIPAA y los requisitos de la AEPD para el sector sanitario. Cada despliegue se documenta frente a las obligaciones que le aplican."
      }
    },
    {
      "@type": "Question",
      "name": "¿Pueden los productos funcionar completamente en local?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. TrustPrompt y TrustCore funcionan en local por defecto; para cargas de trabajo más intensas se apuntan a endpoints que ya gestiona usted mismo. MedCore se ejecuta íntegramente en sus instalaciones."
      }
    },
    {
      "@type": "Question",
      "name": "¿En qué se diferencia TrustPrompt de un proxy DLP de red?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un proxy necesita recibir el texto para inspeccionarlo, lo que añade una parte que ahora posee los datos y falla con el tráfico cifrado o desde dispositivos personales. TrustPrompt elimina los datos personales en el navegador antes de que se envíe el prompt, de modo que ningún elemento nuevo en la cadena llega a ver el texto original."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es la hoja de ruta de automatización gratuita?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Una evaluación breve de sus flujos de datos y su postura de cumplimiento. Recibirá un informe escrito con puntuaciones de riesgo y las automatizaciones más prioritarias. Es una hoja de ruta sobre la que puede actuar de forma independiente, sin ningún compromiso."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La hoja de ruta es gratuita. TrustPrompt y TrustCore se ofrecen en planes por puesto con un nivel local gratuito; los proyectos de automatización se dimensionan a partir de la hoja de ruta. Los planes siguen las bandas de tamaño de pyme de la UE."
      }
    },
    {
      "@type": "Question",
      "name": "¿Se integran con nuestros sistemas existentes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Las automatizaciones y herramientas funcionan junto al software y los registros actuales — incluidos FHIR y OpenEHR en sanidad — en lugar de reemplazarlos."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <JsonLd schema={faqSchema} />

  <!-- Hero Banner -->
  <div class="relative w-full overflow-hidden" style="height: 480px;">
    <AstroImage
      src={colab3Banner}
      alt="IA privada para organizaciones reguladas"
      class="absolute inset-0 w-full h-full object-cover"
      widths={[768, 1024, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/0 flex items-center justify-center">
      <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter text-white text-center px-8">
        IA Privada para<br />Organizaciones Reguladas
      </h1>
    </div>
  </div>

  <!-- Hero Subtitle -->
  <div class="max-w-3xl mx-auto text-center px-6 py-6 text-muted">
    <p class="text-xl">
      Futurion Solutions desarrolla herramientas de IA y automatización que mantienen los datos sensibles dentro del propio perímetro — en el hardware de la organización o en su cuenta cloud. Trabajamos con equipos legales, de cumplimiento, finanzas y sanidad en España y la UE, mapeando cada despliegue a RGPD, el Reglamento de IA de la UE, ISO 27001 y SOC&nbsp;2.
    </p>
  </div>

  <!-- Mapa de Automatización del Cumplimiento -->

  <ComplianceAutomationMap
    heroTitle="Sus servicios de automatización del cumplimiento"
    servicesLabel="Nuestros servicios"
    frameworks={[
      {
        badge: 'GDPR',
        name: 'GDPR',
        accent: 'var(--fds-acc-blue)',
        items: [
          { text: 'Art. 46 - Salvaguardas adecuadas - PII / datos sensibles', tip: 'Exige salvaguardas como SCCs, BCRs, códigos de conducta o certificación cuando no existe una decisión de adecuación.' },
          { text: 'Art. 35 - Evaluación de impacto relativa a la protección de datos - Datos de alto riesgo / datos sensibles', tip: 'Las EIPD son obligatorias en actividades de compartición de alto riesgo, especialmente cuando se trate de datos sensibles.' },
          { text: 'Art. 32(1)(b) - Confidencialidad, integridad, disponibilidad y resiliencia - PII / datos sensibles', tip: 'Exige controles de seguridad para prevenir la compartición o filtración no autorizadas.' },
          { text: 'Art. 32(1)(a) - Seudonimización y cifrado - PII / datos sensibles', tip: 'Los datos compartidos deben protegerse mediante medidas técnicas adecuadas.' },
          { text: 'Art. 9 - Categorías especiales de datos personales - Datos sensibles', tip: 'La compartición de datos sensibles está prohibida salvo que sea aplicable alguna de las excepciones previstas en el Art. 9, como el consentimiento explícito o el interés público sustancial.' },
          { text: 'Art. 5(1)(c) - Minimización de datos - PII', tip: 'Solo podrán compartirse los datos personales estrictamente necesarios.' },
        ],
      },
      {
        badge: 'HIPAA',
        name: 'HIPAA',
        accent: 'var(--fds-acc-pink)',
        items: [
          { text: '45 CFR § 164.502(b) - Estándar del mínimo necesario - PHI / información sanitaria sensible', tip: 'Exige que las entidades cubiertas y sus socios comerciales realicen esfuerzos razonables para limitar los usos, divulgaciones y solicitudes de PHI al mínimo necesario para cumplir la finalidad prevista.' },
          { text: '45 CFR § 164.530(c) - Salvaguardas - PHI', tip: 'Exige salvaguardas administrativas, técnicas y físicas adecuadas para proteger la PHI frente al uso o la divulgación no autorizados, ya sean intencionados o accidentales.' },
          { text: '45 CFR § 164.312(a) - Control de acceso - ePHI', tip: 'Exige controles técnicos que permitan el acceso únicamente a usuarios y sistemas autorizados.' },
          { text: '45 CFR § 164.312(b) - Controles de auditoría - ePHI', tip: 'Exige mecanismos para registrar y examinar la actividad en los sistemas que contienen o utilizan ePHI.' },
        ],
      },
      {
        badge: 'AI',
        name: 'AI Act',
        accent: 'var(--fds-acc-lime)',
        items: [
          { text: 'Art. 10(5) - Tratamiento de categorías especiales de datos personales para la detección y corrección de sesgos - Datos sensibles', tip: 'Permite el tratamiento de datos de categoría especial únicamente cuando sea estrictamente necesario, con salvaguardas como restricciones de reutilización, medidas de seguridad y privacidad, limitaciones de acceso y obligaciones de confidencialidad.' },
          { text: 'Art. 15 - Exactitud, robustez y ciberseguridad - PII / datos sensibles', tip: 'Exige que los sistemas de IA de alto riesgo sean resilientes frente al acceso no autorizado, el uso indebido o la manipulación que pudiera exponer o comprometer información sensible.' },
          { text: 'Art. 78 - Confidencialidad - PII / datos sensibles / información confidencial', tip: 'Exige que las autoridades y los organismos implicados protejan la información confidencial y soliciten únicamente los datos estrictamente necesarios para la evaluación de riesgos y el ejercicio de las competencias regulatorias.' },
        ],
      },
      {
        badge: 'ISO',
        name: 'ISO 27001',
        accent: 'var(--fds-acc-purple)',
        items: [
          { text: 'Annex A 5.14 - Transferencia de información - PII / datos sensibles', tip: 'Exige normas, procedimientos y acuerdos para proteger la información transferida por medios electrónicos, físicos o verbales.' },
          { text: 'Annex A 8.12 - Prevención de fuga de datos - PII / datos sensibles', tip: 'Exige medidas para detectar y prevenir la divulgación, transmisión o extracción no autorizada de información sensible.' },
          { text: 'Annex A 8.11 - Enmascaramiento de datos - PII / datos sensibles', tip: 'Exige técnicas de enmascaramiento como la seudonimización, la anonimización o la redacción para limitar la exposición de información sensible.' },
          { text: 'Annex A 5.15 - Control de acceso - PII / datos sensibles', tip: 'Exige que el acceso a la información y los sistemas esté restringido conforme a los requisitos de negocio y seguridad.' },
        ],
      },
      {
        badge: 'SOC2',
        name: 'SOC2',
        accent: 'var(--fds-acc-royal)',
        items: [
          { text: 'CC6.6 - Prevención del acceso no autorizado - PII / datos sensibles', tip: 'Exige controles para prevenir o detectar el acceso no autorizado a sistemas, datos e información protegida.' },
          { text: 'CC6.7 - Restricción de la transmisión, el movimiento y la eliminación de datos - PII / datos sensibles', tip: 'Exige controles sobre la transmisión, el movimiento y la eliminación de información para prevenir la compartición o filtración no autorizadas.' },
          { text: 'CC7.2 - Supervisión de eventos de seguridad - PII / datos sensibles', tip: 'Exige supervisión para detectar eventos que pudieran resultar en la divulgación no autorizada o el compromiso de información protegida.' },
          { text: 'C1.1 - Identificación y protección de información confidencial - Información confidencial / datos sensibles', tip: 'Exige que la información confidencial sea identificada, clasificada, conservada y protegida conforme a los compromisos y requisitos de confidencialidad.' },
          { text: 'P4.1 - Limitación del uso de información personal - PII', tip: 'Exige que la información personal se utilice únicamente para los fines identificados en los avisos o autorizados de otro modo.' },
          { text: 'P6.1 - Divulgación a terceros - PII', tip: 'Exige que la información personal divulgada a terceros se limite a los fines autorizados y sea coherente con los compromisos de privacidad.' },
        ],
      },
    ]}
    services={[
      { name: 'TrustPrompt', logo: 'trustprompt' },
      { name: 'TrustCore',   logo: 'trustcore' },
      { name: 'TrustAuto',   logo: 'trustauto' },
    ]}
    rows={[
      {
        label: 'Proteja la información sensible',
        pills: [
          { mini: 'DLP',  label: 'DLP',  sub: 'Prevención de pérdida de datos' },
          { mini: 'GRC',  label: 'GRC',  sub: 'Gobernanza, riesgo y cumplimiento' },
          { mini: 'PII',  label: 'PII',  sub: 'Información de identificación personal' },
          { mini: 'PHI',  label: 'PHI',  sub: 'Información sanitaria protegida' },
          { mini: 'AIG',  label: 'AIG',  sub: 'Gobernanza de la IA' },
        ],
      },
      {
        label: 'Su infraestructura, sus normas',
        pills: [
          { mini: 'On', label: 'On-Prem', logo: 'onprem' },
          { mini: 'Cl', label: 'Cloud',   logo: 'cloud' },
        ],
      },
      {
        label: 'Nuestro stack',
        pills: [
          { mini: 'RAG',  label: 'RAG + embeddings', logo: 'rag' },
          { mini: 'VDB',  label: 'Base de datos vectorial' },
          { mini: 'OC',   label: 'OCR', logo: 'ocr' },
          { mini: 'TP',   label: 'TrustPrompt', logo: 'trustprompt' },
          { mini: 'OW',   label: 'Open WebUI',  logo: 'openwebui' },
          { mini: 'FHIR', label: 'HAPI FHIR',   logo: 'hapifhir', break: true },
          { mini: 'EHR',  label: 'OpenEHR',     logo: 'openehr' },
        ],
      },
      {
        label: 'LLMs locales',
        pills: [
          { mini: 'OL', label: 'OLLAMA', logo: 'ollama' },
          { mini: 'G',  label: 'GEMMA',    logo: 'gemma' },
          { mini: 'MG', label: 'MEDGEMMA' },
          { mini: 'M',  label: 'MISTRAL',  logo: 'mistral' },
          { mini: 'DS', label: 'DEEPSEEK', logo: 'deepseek' },
        ],
      },
    ]}
  />

  <!-- TrustPrompt -->

  <Content
    id="trustprompt"
    tagline="TrustPrompt"
    title="Elimine los Datos Personales Antes de que Lleguen a un LLM Público"
    items={[
      {
        title: 'Detección en el dispositivo',
        description:
          'Un modelo NER de 560 millones de parámetros y 40 reglas validadas por suma de verificación se ejecutan en el navegador. La detección funciona sin conexión tras la instalación — no hay ningún servidor de detección al que enviar el texto.',
      },
      {
        title: 'Reglas propias para sus identificadores',
        description:
          'Añada reglas regex para los identificadores que solo usa su organización — números de empleado, números de ticket internos, identificadores de paciente. Las reglas de la organización se ejecutan en un worker aislado con tiempo límite, de modo que un patrón defectuoso nunca puede bloquear la página.',
      },
      {
        title: 'Control centralizado para equipos',
        description:
          'Distribución de políticas mediante Group Policy, Intune o Jamf, con registro de auditoría que almacena únicamente metadatos — nunca el texto del prompt.',
      },
    ]}
    image={{
      src: '~/assets/images/trustprompt.png',
      alt: 'Extensión de navegador TrustPrompt',
    }}
    callToAction={{
      text: 'Conocer TrustPrompt',
      href: '/es/productos/trustprompt/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      Una extensión para Chrome y Edge que detecta y elimina datos personales en el navegador, antes de que un prompt se envíe a ChatGPT, Claude, Gemini y otros seis servicios. El texto que se escribe se analiza en la propia máquina del usuario; el modelo de detección se distribuye dentro de la extensión.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- TrustCore -->

  <Content
    id="trustcore"
    isReversed
    tagline="TrustCore"
    title="Responda Preguntas Sobre sus Propios Documentos, en su Propio Hardware"
    items={[
      {
        title: 'Graph RAG, no solo similitud',
        description:
          'TrustCore construye un grafo de las entidades y relaciones de sus documentos y razona sobre él, aflorando conexiones que ningún documento individual expresa por sí solo.',
      },
      {
        title: 'Respuestas trazables',
        description:
          'Cada respuesta está vinculada al fragmento exacto y a la página de origen, y las cláusulas que entran en conflicto entre documentos se señalan con ambas fuentes.',
      },
      {
        title: 'Soberanía por defecto',
        description:
          'Los documentos, el índice y el grafo permanecen en su dispositivo o en infraestructura bajo su control. Sin SaaS ni subprocesador en la ruta local.',
      },
    ]}
    callToAction={{
      text: 'Conocer TrustCore',
      href: '/es/productos/trustcore/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="image">
      <TrustCoreGraph lang="es" />
    </Fragment>
    <Fragment slot="content">
      Una extensión de navegador con un acompañante local opcional que indexa sus documentos y responde preguntas sobre ellos en su máquina. Las preguntas se responden a partir de sus documentos indexados y no salen de su máquina — no existe ninguna nube de TrustCore por la que pasen.
    </Fragment>
  </Content>

  <!-- TrustAuto -->

  <Content
    id="trustauto"
    tagline="TrustAuto"
    title="Automatización del Cumplimiento, Construida sobre Infraestructura Bajo su Control"
    items={[
      {
        title: 'Comience con una hoja de ruta',
        description:
          'Una evaluación breve de sus flujos de datos y su postura de cumplimiento, con un informe escrito que incluye puntuaciones de riesgo y las automatizaciones más prioritarias.',
      },
      {
        title: 'Implementación conforme',
        description:
          'Flujos de trabajo de gestión documental, planificación, comunicaciones y facturación, diseñados desde el principio con minimización de datos y pistas de auditoría — no añadidas a posteriori. En local o híbrido, para que los datos sensibles permanezcan dentro de su perímetro.',
      },
      {
        title: 'Supervisión continua',
        description:
          'Mantenemos las automatizaciones y actualizamos los controles a medida que evolucionan el RGPD, el Reglamento de IA de la UE y las normas sectoriales.',
      },
    ]}
    image={{
      src: '~/assets/images/team-collaboration.jpg',
      alt: 'Equipo revisando flujos de trabajo de cumplimiento automatizados',
    }}
    callToAction={{
      text: 'Conocer TrustAuto',
      href: '/es/productos/trustauto/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      TrustAuto es nuestra práctica de automatización. Mapeamos sus flujos de datos, identificamos dónde la IA puede asumir de forma segura tareas repetitivas y construimos automatizaciones que se ejecutan en local o en una configuración híbrida — para que los datos sensibles nunca salgan de su control.
    </Fragment>
  </Content>

  <!-- MedCore (TrustAuto para sanidad) -->

  <Content
    id="medcore"
    isReversed
    tagline="TrustAuto para Sanidad"
    title="MedCore — IA Privada para Organizaciones Sanitarias"
    items={[
      {
        title: 'Local por defecto',
        description:
          'Los datos de pacientes permanecen dentro de su organización; nada se envía a ninguna nube externa.',
      },
      {
        title: 'Integración basada en estándares',
        description:
          'Compatible con registros FHIR y OpenEHR y con los sistemas que ya utilizan sus equipos.',
      },
      {
        title: 'Mapeado a las obligaciones sanitarias',
        description:
          'RGPD, el Reglamento de IA de la UE y los requisitos de la AEPD, con documentación lista para inspección.',
      },
    ]}
    image={{
      src: '~/assets/images/medcore-private-ai.jpg',
      alt: 'Infraestructura de IA médica local de MedCore',
    }}
    callToAction={{
      text: 'Conocer MedCore',
      href: '/es/medcore-ia-privada/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      MedCore es la oferta de TrustAuto para hospitales, clínicas y grupos médicos: infraestructura de IA de grado médico que se ejecuta íntegramente en sus instalaciones, construida sobre HAPI FHIR y OpenEHR con modelos clínicos que funcionan en local. Para más contexto, lea nuestro análisis de la <a href="/es/es-retirada-openevidence-ue-reino-unido-sanidad-on-premise-nube-soberana/" class="underline">retirada de OpenEvidence de la UE y el Reino Unido</a> y lo que implica para la arquitectura de IA clínica.
    </Fragment>
  </Content>

  <!-- FAQs -->

  <FAQs
    title="Preguntas Frecuentes"
    subtitle="Cómo nuestras herramientas y automatización mantienen los datos sensibles dentro del propio perímetro."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Qué hace Futurion Solutions?',
        description:
          'Desarrollamos herramientas de IA privada — TrustPrompt y TrustCore — y gestionamos una práctica de automatización, TrustAuto, para organizaciones que trabajan con datos sensibles o regulados. Todo está diseñado para funcionar en infraestructura bajo su control, no en un servicio cloud compartido.',
      },
      {
        title: '¿Salen los datos de nuestra propia infraestructura?',
        description:
          'No. TrustPrompt analiza el texto en el navegador, TrustCore responde a partir de documentos en su propia máquina, y las automatizaciones de TrustAuto se ejecutan en local o en una configuración híbrida. Los datos sensibles permanecen dentro de su perímetro.',
      },
      {
        title: '¿A qué marcos de cumplimiento se mapean?',
        description:
          'RGPD, el Reglamento de IA de la UE, ISO 27001 y SOC 2, además de HIPAA y los requisitos de la AEPD para el sector sanitario. Cada despliegue se documenta frente a las obligaciones que le aplican.',
      },
      {
        title: '¿Pueden los productos funcionar completamente en local?',
        description:
          'Sí. TrustPrompt y TrustCore funcionan en local por defecto; para cargas de trabajo más intensas se apuntan a endpoints que ya gestiona usted mismo. MedCore se ejecuta íntegramente en sus instalaciones.',
      },
      {
        title: '¿En qué se diferencia TrustPrompt de un proxy DLP de red?',
        description:
          'Un proxy necesita recibir el texto para inspeccionarlo, lo que añade una parte que ahora posee los datos y falla con el tráfico cifrado o desde dispositivos personales. TrustPrompt elimina los datos personales en el navegador antes de que se envíe el prompt, de modo que ningún elemento nuevo en la cadena llega a ver el texto original.',
      },
      {
        title: '¿Qué es la hoja de ruta de automatización gratuita?',
        description:
          'Una evaluación breve de sus flujos de datos y su postura de cumplimiento. Recibirá un informe escrito con puntuaciones de riesgo y las automatizaciones más prioritarias. Es una hoja de ruta sobre la que puede actuar de forma independiente, sin ningún compromiso.',
      },
      {
        title: '¿Cuánto cuesta?',
        description:
          'La hoja de ruta es gratuita. TrustPrompt y TrustCore se ofrecen en planes por puesto con un nivel local gratuito; los proyectos de automatización se dimensionan a partir de la hoja de ruta. Los planes siguen las bandas de tamaño de pyme de la UE.',
      },
      {
        title: '¿Se integran con nuestros sistemas existentes?',
        description:
          'Sí. Las automatizaciones y herramientas funcionan junto al software y los registros actuales — incluidos FHIR y OpenEHR en sanidad — en lugar de reemplazarlos.',
      },
    ]}
  />

  <!-- Últimas Entradas del Blog -->

  <BlogLatestPosts
    title="Cumplimiento e IA: notas de trabajo"
    lang="es"
  />

  <!-- CTA Final -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Solicite su hoja de ruta gratuita',
        href: '/es/hoja-de-ruta-de-automatizacion/',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Vea dónde encaja la IA — sin mover sus datos</Fragment>

    <Fragment slot="subtitle">
      Comience con una hoja de ruta gratuita de sus flujos de datos y oportunidades de automatización, mapeada a las regulaciones que le aplican. Sin compromiso.
    </Fragment>
  </CallToAction>
</Layout>
