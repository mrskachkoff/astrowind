---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Note from '~/components/widgets/Note.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import MedicalChat from '~/components/widgets/MedicalChat.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'MedCore: IA Médica Local para Sanidad',
  description: 'MedCore Private AI: infraestructura de IA local y de grado médico para sanidad. Cumplimiento RGPD e HIPAA, soberanía de datos, ajuste fino y RAG.',
  openGraph: {
    images: [{ url: '~/assets/images/server-network.jpg' }],
  },
};
---

<Layout metadata={metadata}>
  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "MedCore Private AI",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Linux, On-Premise",
    "description": "Infraestructura de IA completamente local y de grado médico para organizaciones sanitarias medianas. Cumplimiento con RGPD, HIPAA y soberanía de datos. Ajuste fino, RAG y soporte multilingüe incluidos.",
    "url": "https://solutions.futurion.es/es/medcore-ia-privada/",
    "inLanguage": "es",
    "featureList": [
      "Despliegue completamente local",
      "Cumplimiento RGPD por arquitectura",
      "Modelos de lenguaje de grado médico",
      "Soporte para ajuste fino y RAG",
      "Multilingüe — español e inglés",
      "Cumplimiento HIPAA y soberanía de datos"
    ],
    "author": { "@id": "https://solutions.futurion.es/#organization" },
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": "25000",
        "priceCurrency": "EUR"
      },
      "availability": "https://schema.org/InStock"
    }
  }} />
  <!-- Section 1: Hero -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Reservar Cita',
        href: 'https://outlook.office.com/book/FuturionSolutions@futurion.es/',
        target: '_blank',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">
      MedCore Private AI<br />
      <span class="text-accent dark:text-white">Infraestructura de IA de Grado Médico para Sanidad con Soberanía de Datos</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Despliega grandes modelos de lenguaje de grado médico completamente en tu propia infraestructura. Ningún dato de pacientes sale de tus instalaciones. Diseñado específicamente para redes de clínicas, centros sanitarios especializados y organizaciones críticas en cumplimiento en toda la UE.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-green-700">IA médica local. Tus datos nunca salen.</span>
      Cumplimiento total con RGPD, HIPAA y soberanía de datos por arquitectura — no por política.
    </Fragment>
  </Hero>

  <!-- Embedded Medical AI Demo Chat -->

  <MedicalChat />

  <!-- Section 5: Capabilities — Deep Dives -->

  <Content
    tagline="Capacidades"
    title="Inteligencia Médica Que Entiende Tu Dominio"
    items={[
      {
        title: 'Asistencia en documentación clínica',
        description:
          'Genera, resume y estructura notas clínicas, informes de alta y cartas de derivación — fundamentados en tus plantillas y terminología.',
      },
      {
        title: 'Recuperación de conocimiento médico',
        description:
          'Consulta interacciones de medicamentos, protocolos de tratamiento y directrices clínicas usando la base de conocimiento verificada de tu institución vía RAG.',
      },
      {
        title: 'Comunicación multilingüe con pacientes',
        description:
          'Genere materiales orientados al paciente en español, inglés, francés, alemán y otros idiomas de la UE — culturalmente apropiados y médicamente precisos.',
      },
      {
        title: 'Automatización administrativa',
        description:
          'Automatice codificación, preparación de facturación, clasificación de citas y enrutamiento de derivaciones con IA que entiende el contexto médico.',
      },
    ]}
    image={{
      src: '~/assets/images/healthcare-tech.jpg',
      alt: 'Profesional médico usando tecnología asistida por IA',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Inteligencia Médica
      </h3>
      IA que habla medicina — no una IA a la que le han dicho qué es la medicina. Todas las salidas son solo asistivas; la validación clínica sigue siendo responsabilidad de profesionales sanitarios cualificados.
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Opción de despliegue aislado',
        description:
          'Para máxima seguridad, despliegue en entornos completamente aislados sin conectividad a internet. Aislamiento completo para las cargas de trabajo más sensibles.',
      },
      {
        title: 'Cifrado de extremo a extremo',
        description:
          'Datos cifrados en reposo (AES-256) y en tránsito (TLS 1.3). Claves de cifrado gestionadas localmente — nunca compartidas con ninguna parte externa.',
      },
      {
        title: 'Control de acceso basado en roles',
        description:
          'Permisos granulares alineados con roles sanitarios. Registros de auditoría para cada interacción de IA, consulta y evento de acceso a datos.',
      },
      {
        title: 'Documentación de cumplimiento incluida',
        description:
          'Evaluaciones de Impacto de Protección de Datos RGPD preconstruidas, registros de procesamiento y documentación de cumplimiento para tu despliegue específico.',
      },
    ]}
    image={{
      src: '~/assets/images/server-typing.jpg',
      alt: 'Infraestructura de datos segura',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Arquitectura de Privacidad
      </h3>
      La seguridad no es una característica — es la arquitectura. Cada capa de MedCore está diseñada para garantizar la soberanía de datos de pacientes.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'Ajuste fino específico del dominio',
        description:
          'Entrena modelos en tu especialidad — cardiología, oncología, odontología, farmacia — usando tus propios conjuntos de datos desidentificados y protocolos clínicos.',
      },
      {
        title: 'Generación Aumentada por Recuperación (RAG)',
        description:
          'Conecta la IA a tus formularios, guías de tratamiento y bases de conocimiento institucionales. Las respuestas se fundamentan en tus datos verificados.',
      },
      {
        title: 'Pipeline de aprendizaje continuo',
        description:
          'Los modelos mejoran con el tiempo a medida que tu equipo valida salidas y proporciona retroalimentación — todo dentro de tu entorno local seguro.',
      },
      {
        title: 'Versionado y reversión de modelos',
        description:
          'Control de versión completo para todas las configuraciones de modelos. Prueba nuevas versiones antes del despliegue en producción. Revierte instantáneamente si es necesario.',
      },
    ]}
    image={{
      src: '~/assets/images/data-analytics.jpg',
      alt: 'Personalización y ajuste fino de modelos de IA',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Motor de Personalización
      </h3>
      Tu IA, tu especialidad, tus datos. MedCore se adapta a cómo tu organización practica la medicina — no al revés.
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Configuraciones de servidor optimizadas para GPU',
        description:
          'Especificamos, obtenemos y configuramos hardware preparado para IA adaptado a tu carga de trabajo — desde configuraciones de un solo servidor hasta clústeres multinodo.',
      },
      {
        title: 'Arquitectura escalable',
        description:
          'Comienza con un único despliegue y escala horizontalmente a medida que crece el uso. Arquitectura diseñada para 10 a más de 10.000 usuarios concurrentes.',
      },
      {
        title: 'Integración con infraestructura existente',
        description:
          'MedCore se integra con tus sistemas EMR/EHR, bases de datos existentes y flujos de trabajo clínicos a través de APIs estándar e interfaces HL7/FHIR.',
      },
      {
        title: 'Redundancia y recuperación ante desastres',
        description:
          'Configuraciones de alta disponibilidad con conmutación por error automática. Respaldo local y planes de recuperación ante desastres incluidos en cada despliegue.',
      },
    ]}
    image={{
      src: '~/assets/images/server-room.jpg',
      alt: 'Infraestructura de hardware de servidores',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Hardware e Infraestructura
      </h3>
      Manejamos la pila completa — desde la especificación de hardware GPU hasta el despliegue en producción. Tú te enfocas en la atención al paciente.
    </Fragment>
  </Content>


  <!-- Section 7: Target Customers -->

  <Features
    columns={3}
    tagline="A Quién Sirve MedCore"
    title="Diseñado para organizaciones sanitarias medianas"
    subtitle="MedCore Private AI está diseñado para organizaciones que procesan volúmenes significativos de datos de pacientes y requieren capacidades de IA de grado institucional."
    items={[
      {
        title: 'Redes de Clínicas',
        description:
          'Grupos de clínicas dentales, médicas o especializadas con múltiples ubicaciones que necesitan capacidades de IA consistentes en todos los sitios con gobernanza de datos centralizada.',
        icon: 'tabler:building-hospital',
      },
      {
        title: 'Centros Sanitarios Especializados',
        description:
          'Centros de oncología, prácticas de cardiología, clínicas de fertilidad y otros grupos especializados con requisitos de IA específicos del dominio.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Grupos Sanitarios Internacionales',
        description:
          'Organizaciones que operan en estados miembros de la UE que necesitan IA multilingüe con cumplimiento consistente de soberanía de datos en cada jurisdicción.',
        icon: 'tabler:world',
      },
      {
        title: 'Hospitales Activos en Investigación',
        description:
          'Instituciones sanitarias que realizan investigación clínica y necesitan capacidades de IA sin exponer datos de investigación a plataformas externas.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Proveedores de TI Sanitarias',
        description:
          'Proveedores de servicios gestionados y empresas de TI sanitarias que desean ofrecer capacidades de IA privada a sus clientes.',
        icon: 'tabler:device-desktop-analytics',
      },
      {
        title: 'Organizaciones Críticas en Cumplimiento',
        description:
          'Cualquier entidad sanitaria donde los requisitos de residencia de datos, auditorías regulatorias o política institucional prohíben el uso de IA basada en la nube.',
        icon: 'tabler:shield-lock',
      },
    ]}
  />

  <!-- Section 8: Differentiators -->

  <Features2
    tagline="Por Qué MedCore"
    title="Qué distingue a MedCore Private AI"
    subtitle="No es otro envoltorio de IA en la nube. MedCore es fundamentalmente diferente en arquitectura, propósito y filosofía."
    columns={2}
    items={[
      {
        title: 'Verdaderamente Local — Sin Excepciones',
        description:
          'Cada componente se ejecuta en tu infraestructura. Sin soluciones alternativas de "nube híbrida", sin llamadas de telemetría a casa, sin dependencias de API externas. Tus datos son soberanos.',
        icon: 'tabler:server',
      },
      {
        title: 'Modelos de Lenguaje Específicos de Medicina',
        description:
          'Modelos entrenados en literatura médica y datos clínicos — no modelos de propósito general con un prompt médico. Mayor precisión para terminología médica, interacciones de medicamentos y flujos de trabajo clínicos.',
        icon: 'tabler:brain',
      },
      {
        title: 'Arquitectura Que Prioriza la Privacidad',
        description:
          'La seguridad es la arquitectura, no un complemento. Opciones de despliegue aislado, cifrado AES-256, acceso basado en roles y registros de auditoría completos desde el primer día.',
        icon: 'tabler:lock',
      },
      {
        title: 'Flexibilidad de Ajuste Fino',
        description:
          'Personaliza modelos para tu especialidad, tus protocolos y tu conocimiento institucional. La integración RAG fundamenta la IA en tus datos médicos verificados.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Hardware + Software + Cumplimiento',
        description:
          'Entregamos la pila completa: hardware preparado para IA, software optimizado y documentación de cumplimiento. Un solo socio para todo el ciclo de vida.',
        icon: 'tabler:stack-2',
      },
      {
        title: 'Sin Bloqueo de Proveedor',
        description:
          'Estándares abiertos, APIs estándar y tus datos en tu hardware. Si alguna vez deseas cambiar de dirección, todo permanece contigo.',
        icon: 'tabler:key',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Section 9: Process -->

  <Steps
    title="Cómo desplegamos MedCore"
    subtitle="Un proceso estructurado de 6 pasos desde la evaluación inicial hasta el despliegue en producción y la optimización continua."
    items={[
      {
        title: 'Paso 1: <span class="font-medium">Evaluación de Infraestructura</span>',
        description:
          'Evaluamos tu infraestructura existente, volúmenes de datos, requisitos de cumplimiento y casos de uso para diseñar la arquitectura de despliegue óptima de MedCore.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Paso 2: <span class="font-medium">Diseño de Arquitectura</span>',
        description:
          'Arquitectura personalizada adaptada a tu organización — especificaciones de hardware, topología de red, controles de seguridad y puntos de integración con sistemas existentes.',
        icon: 'tabler:layout-board',
      },
      {
        title: 'Paso 3: <span class="font-medium">Selección y Personalización de Modelos</span>',
        description:
          'Selecciona y configura LLMs médicos para tu especialidad. Ajuste fino con tus conjuntos de datos desidentificados. Construye pipelines RAG conectados a tus bases de conocimiento.',
        icon: 'tabler:brain',
      },
      {
        title: 'Paso 4: <span class="font-medium">Despliegue Local</span>',
        description:
          'Adquisición de hardware, instalación y despliegue completo de software en tu infraestructura. Pruebas completas en tu entorno antes de la puesta en marcha.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Paso 5: <span class="font-medium">Validación Clínica</span>',
        description:
          'Tu equipo clínico valida las salidas de IA frente a escenarios del mundo real. Iteramos en la configuración del modelo hasta que la precisión cumple tus estándares institucionales.',
        icon: 'tabler:stethoscope',
      },
      {
        title: 'Paso 6: <span class="font-medium">Soporte y Optimización Continuos</span>',
        description:
          'Soporte mensual, actualizaciones de modelos, monitorización de cumplimiento y optimización continua. Tu socio dedicado en operaciones de IA a largo plazo.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: '~/assets/images/business-meeting.jpg',
      alt: 'Equipo profesional planificando despliegue',
    }}
  />

  <!-- Section 10: Pricing Note -->

  <Note
    icon="tabler:info-circle"
    title="Precios Basados en Proyecto."
    description='Los despliegues de MedCore Private AI se cotizan por proyecto según el alcance de infraestructura, requisitos de modelos y tamaño de organización. Los compromisos típicos van desde &euro;25,000 hasta más de &euro;150,000, con planes de soporte mensuales disponibles. <a href="/es/contacto/" class="underline font-bold">Contáctanos para una evaluación detallada y presupuesto</a>.'
  />

  <!-- Section 11: FAQs -->

  <FAQs
    title="MedCore Private AI — Preguntas Frecuentes"
    subtitle="Respuestas orientadas a empresas para líderes de TI sanitario, responsables de cumplimiento y directores clínicos."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Cómo se compara MedCore con Azure OpenAI o AWS Bedrock para sanidad?',
        description:
          'Los servicios de IA en la nube como Azure OpenAI y AWS Bedrock aún envían datos a infraestructura externa gestionada por el proveedor de la nube. Incluso con "endpoints privados", estás confiando en un tercero con la residencia de datos de pacientes. MedCore se ejecuta completamente en tu hardware — cero transferencia de datos externa, cero requisitos de confianza en terceros. Para organizaciones con mandatos estrictos de soberanía de datos, este es el único enfoque conforme.',
      },
      {
        title: '¿Se integra MedCore con nuestro sistema EMR/EHR?',
        description:
          'Sí. MedCore se integra con los principales sistemas EMR/EHR a través de APIs estándar, HL7 e interfaces FHIR. Durante la fase de evaluación, mapeamos tus requisitos de integración específicos y diseñamos la arquitectura de conexión. Tenemos experiencia integrando con sistemas comúnmente usados en organizaciones sanitarias de la UE.',
      },
      {
        title: '¿Qué hardware necesitamos?',
        description:
          'Los requisitos de hardware dependen de tu caso de uso, número de usuarios y selección de modelos. Los despliegues típicos usan servidores acelerados por GPU (clase NVIDIA A100 o H100). Especificamos, obtenemos y configuramos todo el hardware como parte del despliegue — no necesitas infraestructura de IA existente. También podemos trabajar con hardware que ya tengas.',
      },
      {
        title: '¿Cuánto tiempo lleva el despliegue?',
        description:
          'Los despliegues típicos llevan entre 8 y 16 semanas desde la evaluación hasta la producción, dependiendo de la complejidad de la infraestructura, los requisitos de ajuste fino personalizado y los plazos de adquisición. Proporcionamos un cronograma detallado durante la fase de diseño de arquitectura. Los despliegues piloto para evaluación pueden estar operativos en 4-6 semanas.',
      },
      {
        title: '¿Qué certificaciones de cumplimiento admite MedCore?',
        description:
          'Los despliegues de MedCore están diseñados para admitir RGPD (incluidas disposiciones específicas sobre sanidad), HIPAA, SOC2, ISO 27001 y la Ley de IA de la UE. Proporcionamos Evaluaciones de Impacto de Protección de Datos preconstruidas, registros de procesamiento y documentación de cumplimiento específica para tu despliegue. Tu equipo de cumplimiento revisa y aprueba toda la documentación antes de la puesta en marcha.',
      },
      {
        title: '¿Podemos ejecutar un piloto antes de comprometernos con el despliegue completo?',
        description:
          'Por supuesto. Recomendamos comenzar con un piloto acotado — normalmente un solo caso de uso o departamento — para validar la tecnología en tu entorno. Los despliegues piloto incluyen todas las capacidades principales a menor escala, y pueden ampliarse a producción completa cuando estés listo.',
      },
      {
        title: '¿Qué sucede si queremos cambiar modelos de IA más adelante?',
        description:
          'MedCore usa una arquitectura abierta sin bloqueo de proveedor. Puedes intercambiar modelos subyacentes, añadir nuevas capacidades o ajustar configuraciones en cualquier momento. Todos tus datos de ajuste fino, bases de conocimiento RAG y configuraciones personalizadas permanecen en tu infraestructura y son completamente portables.',
      },
      {
        title: '¿Quién es responsable de la validación clínica de las salidas de IA?',
        description:
          'MedCore Private AI es una tecnología asistiva. Todas las salidas de IA deben ser revisadas y validadas por profesionales sanitarios cualificados antes del uso clínico. Proporcionamos las herramientas e infraestructura para flujos de trabajo de validación clínica, pero la responsabilidad de las decisiones clínicas permanece con tu personal médico colegiado. Esto es coherente con los requisitos de la Ley de IA de la UE para sistemas de IA de alto riesgo en sanidad.',
      },
    ]}
  />

  <!-- Contenido de /servicios/ -->

  <!-- Hero -->

  <Hero
    tagline="Nuestros Servicios"
    title="Automatización IA Que Prioriza el Cumplimiento"
    subtitle="Desde tu Hoja de Ruta de Automatización hasta el soporte continuo, entregamos soluciones IA diseñadas con la privacidad de los datos sanitarios como eje central. Servicios que se complementan para transformar tu consulta de forma segura — con opciones de nivel empresarial para organizaciones más grandes."
    actions={[
      { variant: 'primary', text: 'Comenzar con la Hoja de Ruta Gratuita', href: '/es/hoja-de-ruta-de-automatizacion/', icon: 'tabler:clipboard-check' },
    ]}
    image={{
      src: '~/assets/images/team-working.jpg',
      alt: 'Equipo profesional trabajando juntos',
    }}
  />

  <!-- Resumen de Servicios: 3 Pilares -->

  <Features2
    title="Nuestros pilares de servicio"
    subtitle="Cada servicio se basa en el anterior, creando un sistema completo de automatización centrado en cumplimiento para tu consulta — con opciones empresariales para organizaciones más grandes."
    columns={2}
    items={[
      {
        title: 'Hoja de Ruta de Automatización Gratuita',
        description: 'Una evaluación de 5-7 días de tus flujos de datos, postura de cumplimiento y oportunidades de automatización. Recibes un informe detallado con puntuaciones de riesgo y una hoja de ruta clara.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Implementación Conforme',
        description: 'Construimos y desplegamos automatizaciones IA usando arquitecturas locales o híbridas. Cada solución está diseñada con principios RGPD desde el primer día.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Soporte y Monitorización Continuos',
        description: 'Optimización continua, actualizaciones de cumplimiento conforme evolucionan las regulaciones y monitorización del rendimiento. Tu socio de cumplimiento IA a largo plazo.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'MedCore Private AI (Empresarial)',
        description: 'Infraestructura IA de grado médico completamente local para organizaciones sanitarias medianas. LLMs especializados, ajuste fino y soberanía completa de datos.',
        icon: 'tabler:server-2',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Features2>

  <!-- Servicio 1: Hoja de Ruta de Automatización Gratuita (Detalle) -->

  <Content
    isReversed
    tagline="Servicio 1"
    title="Hoja de Ruta de Automatización Gratuita"
    items={[
      {
        title: 'Perfil de clínica y evaluación de riesgos',
        description: 'Evaluamos el tamaño de tu clínica, volumen de pacientes, madurez digital y herramientas existentes para determinar tu nivel de riesgo.',
      },
      {
        title: 'Mapeo completo de flujos de datos',
        description: 'Admisión de pacientes, registros, imagen, facturación, comunicaciones — cada flujo de datos mapeado y clasificado por sensibilidad.',
      },
      {
        title: 'Análisis de cuellos de botella de procesos',
        description: 'Cada flujo de trabajo puntuado por esfuerzo manual, riesgo de error, sensibilidad de datos y potencial de automatización.',
      },
      {
        title: 'Recomendaciones de arquitectura IA',
        description: 'Nube, híbrida o local — determinamos el enfoque seguro para cada proceso con justificación RGPD.',
      },
    ]}
    image={{
      src: '~/assets/images/business-planning.jpg',
      alt: 'Profesional analizando documentos',
    }}
  >
    <Fragment slot="content">
