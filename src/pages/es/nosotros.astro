---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Nosotros',
  description:
    'Futurion Solutions, Valencia. TrustPrompt, TrustCore y TrustAuto para equipos jurídicos, de cumplimiento y finanzas que guardan sus datos en casa.',
  openGraph: {
    images: [{ url: '~/assets/images/team-meeting.jpg' }],
  },
};

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    '@id': 'https://solutions.futurion.es/es/nosotros/#webpage',
    url: 'https://solutions.futurion.es/es/nosotros/',
    name: 'Sobre Futurion Solutions',
    description:
      'Futurion Solutions desarrolla herramientas de IA privada — TrustPrompt, TrustCore y TrustAuto — para equipos de asesoría jurídica, cumplimiento, finanzas y sanidad, diseñadas para ejecutarse en la infraestructura que controla el cliente, no en un servicio compartido en la nube.',
    inLanguage: 'es',
    publisher: { '@id': 'https://solutions.futurion.es/#organization' },
    mainEntity: { '@id': 'https://solutions.futurion.es/#organization' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Ivan Skachkov',
    jobTitle: 'Fundador',
    worksFor: { '@id': 'https://solutions.futurion.es/#organization' },
    knowsAbout: ['RGPD', 'Ley de IA de la UE', 'ISO 27001', 'SOC 2', 'Protección de Datos', 'IA Privada', 'Diseño de Procesos Empresariales'],
    url: 'https://solutions.futurion.es/es/nosotros/',
  },
];
---

<Layout metadata={metadata}>
  {aboutSchema.map((s) => <JsonLd schema={s} />)}

  <!-- Hero -->

  <Hero
    tagline="Sobre Futurion Solutions"
    image={{
      src: '~/assets/images/team-collaboration.jpg',
      alt: 'El equipo de Futurion Solutions trabajando',
    }}
  >
    <Fragment slot="title">
      Desarrollamos IA que permanece<br />
      <span class="text-accent dark:text-white">dentro de tu propio perímetro</span>
    </Fragment>

    <Fragment slot="subtitle">
      Desarrollamos soluciones para equipos de asesoría jurídica, cumplimiento, finanzas y sanidad que velan por la privacidad de sus clientes.
    </Fragment>
  </Hero>

  <!-- Por qué existimos -->

  <Content
    tagline="Por qué existimos"
    title="Usar IA no debería crear un nuevo lugar donde vivan tus datos"
    items={[
      {
        title: 'Qué desarrollamos',
        description:
          'TrustPrompt elimina los datos personales en el navegador antes de enviar una consulta a un LLM público. TrustCore responde preguntas sobre tus propios documentos en tu propio hardware. TrustAuto automatiza procesos empresariales repetitivos — recordatorios, seguimientos, gestión de entradas, facturación, aprobaciones y transferencia de datos entre sistemas — construido sobre Microsoft Power Automate o n8n alojado en tus propias instalaciones, que funciona en tu propia infraestructura o en una configuración híbrida, como una capa sobre los sistemas que ya utilizas.',
      },
      {
        title: 'Dónde se ejecuta',
        description:
          'En tu propio hardware o en tu propia cuenta en la nube. No existe ningún servidor de Futurion que almacene tus documentos, y nada se nos envía a nosotros para que el software funcione.',
      },
      {
        title: 'Cómo trabajamos',
        description:
          'Cada despliegue se documenta conforme a las obligaciones que te son exigibles — RGPD, la Ley de IA de la UE, ISO 27001 y SOC 2, además de los requisitos HIPAA y AEPD en el ámbito sanitario.',
      },
    ]}
    image={{
      src: '~/assets/images/abstract-light.jpg',
      alt: 'Datos mantenidos dentro de un perímetro definido',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Creado para eliminar un problema de protección de datos, no para añadir uno nuevo
      </h3>
      El trabajo jurídico, clínico y financiero se sustenta en documentos que son privilegiados, confidenciales o datos personales sujetos al RGPD. En el momento en que ese texto se envía a un servicio de IA compartido, pasa a estar en manos de un tercero que puede registrarlo o conservarlo — y para muchos de estos equipos eso solo ya es razón suficiente para descartarlo. Desarrollamos software para que el uso de la IA no mueva los datos a ningún lugar nuevo.
    </Fragment>
  </Content>

  <!-- Cómo desarrollamos -->

  <Features2
    title="Los mismos compromisos en todo lo que entregamos"
    subtitle="Estas son propiedades de cómo está construido el software, no promesas añadidas por encima."
    tagline="Cómo desarrollamos"
    items={[
      {
        title: 'Sin servidor del que preocuparse',
        description:
          'No existe ningún servicio alojado que reciba tus datos. El trabajo se ejecuta en tu navegador o en tu propia máquina, de modo que no hay ningún tercero en el flujo de datos que pueda filtrar un documento.',
        icon: 'tabler:server-off',
      },
      {
        title: 'En infraestructura que tú controlas',
        description:
          'Todo se ejecuta en tu hardware o en tu cuenta en la nube. Para cargas de trabajo más exigentes, apuntas las herramientas a los endpoints que ya gestionas tú, no a los que nosotros introduciríamos.',
        icon: 'tabler:lock',
      },
      {
        title: 'Evidencia que puedes verificar',
        description:
          'Las respuestas están vinculadas al fragmento y página exactos de los que proceden, y los datos que entran en conflicto entre documentos se señalan con sus fuentes — de modo que un resultado puede verificarse, no solo aceptarse.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Mapeado a tus obligaciones',
        description:
          'Cada despliegue se documenta conforme a las normativas que te son exigibles, con los registros listos para cualquier inspección.',
        icon: 'tabler:shield-check',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Features2>

  <!-- Quién hay detrás -->

  <Content
    isReversed
    tagline="Quién hay detrás"
    title="Experiencia en cumplimiento y diseño de procesos, aplicada al software"
    items={[
      {
        title: 'Cumplimiento antes que código',
        description:
          'Los productos parten de las obligaciones que asumen estos equipos — RGPD, la Ley de IA de la UE, ISO 27001, SOC 2 — y están diseñados para satisfacerlas por construcción, no documentados alrededor de ellas a posteriori.',
      },
      {
        title: 'Proceso antes que automatización',
        description:
          'Analizamos cómo fluye realmente el trabajo antes de automatizar nada, de modo que el resultado elimina esfuerzo en lugar de digitalizar un proceso que ya estaba roto.',
      },
      {
        title: 'Respuestas claras',
        description:
          'Explicamos qué hace el software con tus datos en términos comprensibles — y también qué es lo que deliberadamente no hace.',
      },
    ]}
    image={{
      src: '~/assets/images/business-meeting.jpg',
      alt: 'Sesión de trabajo en Futurion Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Fundada por Ivan Skachkov</h3>
      Futurion Solutions fue fundada por Ivan Skachkov, especialista en protección de datos y diseño de procesos empresariales. La empresa tiene su sede en Valencia y trabaja con organizaciones de toda España y la UE.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- Experiencia -->

  <Features
    title="Nuestra experiencia"
    subtitle="Una combinación de conocimiento en protección de datos, diseño de procesos e ingeniería de IA aplicada."
    columns={3}
    items={[
      {
        title: 'RGPD y Privacidad de Datos',
        description:
          'Normativa europea de protección de datos, requisitos de la AEPD española y las obligaciones de tratamiento que conllevan los datos confidenciales y de categoría especial.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'ISO 27001 y SOC 2',
        description:
          'Controles de marcos de seguridad aplicados a una escala manejable — salvaguardas adecuadas sin la carga de un programa de cumplimiento para grandes corporaciones.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Ley de IA de la UE y Gobernanza de la IA',
        description:
          'Las obligaciones que se aplican a los sistemas de IA que tratan datos personales o sensibles, mapeadas en cada despliegue para que el uso de la IA sea siempre trazable y responsable.',
        icon: 'tabler:scale',
      },
      {
        title: 'Diseño y Optimización de Procesos',
        description:
          'Años analizando y rediseñando flujos de trabajo. Identificamos los cuellos de botella, eliminamos lo que sobra y arreglamos el proceso antes de automatizar nada.',
        icon: 'tabler:arrows-sort',
      },
      {
        title: 'Arquitectura de IA Privada',
        description:
          'Diseño de sistemas de IA que se ejecutan on-premise o en configuración híbrida — modelos locales, recuperación de información e incrustaciones en infraestructura que tú controlas.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Operaciones en Sectores Regulados',
        description:
          'Conocimiento práctico de cómo operan los equipos de asesoría jurídica, cumplimiento, finanzas y sanidad, y las normativas de datos a las que responde cada uno.',
        icon: 'tabler:building-bank',
      },
    ]}
  />

  <!-- CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Habla con nosotros',
        href: '/es/contacto/',
        icon: 'tabler:arrow-right',
      },
    ]}
    title="¿Trabajas con datos que no pueden salir de tu control?"
    subtitle="Cuéntanos con qué trabajas y las normativas bajo las que operas. Te mostramos qué puede ejecutarse en tu propia infraestructura."
  />
</Layout>
