---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

import imgTrustAuto from '~/assets/images/trustauto.png';

const metadata = {
  title: 'TrustAuto — Cumplimiento On-Premise',
  description:
    'Centro de control de cumplimiento on-premise, sin SaaS, conectado a tus sistemas. Verifica SOC 2, ISO 27001, HIPAA y RGPD continuamente. Próximamente.',
  openGraph: {
    images: [{ url: '~/assets/images/trustauto.png' }],
  },
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Próximamente">
    <Fragment slot="title">
      <img
        src={imgTrustAuto.src}
        alt="Logo TrustAuto"
        width="120"
        height="120"
        class="mx-auto mb-6 object-contain"
      />
      TrustAuto
    </Fragment>

    <Fragment slot="subtitle">
      Un centro de control de cumplimiento normativo sin SaaS, completamente on-premise. TrustAuto se conecta a sus
      sistemas existentes y verifica de forma continua si su organización está cumpliendo los controles de seguridad
      y los estándares de privacidad a los que está sujeta — SOC&nbsp;2, ISO&nbsp;27001, HIPAA y RGPD.
    </Fragment>
  </HeroText>
</Layout>
