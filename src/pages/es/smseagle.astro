---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import FeaturesCarousel from '~/components/widgets/FeaturesCarousel.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import imgSmsEagleLogo from '~/assets/images/smseagle.png';
import imgSmsEagleDevice from '~/assets/images/smseagle-device.jpg';

const metadata = {
  title: 'SMSEagle en España — Pasarela SMS hardware para automatizar',
  description:
    'Futurion Solutions es Technology Partner oficial de SMSEagle en España. Pasarela SMS hardware on-premise como componente de mensajería de tus flujos de trabajo: n8n, Power Automate, chatbots, códigos 2FA, notificaciones a clientes y alertas de TI — suministro, integración y servicio gestionado.',
  openGraph: {
    images: [{ url: '~/assets/images/smseagle-device.jpg' }],
  },
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Pasarela SMS Hardware SMSEagle',
  brand: { '@type': 'Organization', name: 'SMSEagle', url: 'https://www.smseagle.eu/' },
  manufacturer: { '@type': 'Organization', name: 'SMSEagle', url: 'https://www.smseagle.eu/' },
  description:
    'Pasarela SMS hardware on-premise: un dispositivo de rack con tarjetas SIM propias que envía y recibe SMS, MMS, WhatsApp, Signal y voz a través de la red móvil. Una REST API, webhooks, servidor SMPP, MQTT y email-to-SMS lo convierten en el componente de mensajería de flujos de trabajo automatizados (n8n, Power Automate, chatbots, envío de códigos OTP) y de rutas de alerta de monitorización. Compra única, sin suscripción SaaS de mensajería. Futurion Solutions suministra, instala, integra y puede gestionar el dispositivo como Technology Partner oficial de SMSEagle para España.',
  url: 'https://solutions.futurion.es/es/smseagle/',
  inLanguage: 'es',
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: '989',
    highPrice: '2694',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    seller: { '@id': 'https://solutions.futurion.es/#organization' },
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Integración de pasarela SMS y automatización de mensajería',
  name: 'Suministro, Instalación e Integración de SMSEagle',
  description:
    'Dimensionamiento, suministro, instalación e integración de pasarelas SMS hardware SMSEagle con plataformas de flujos de trabajo, sistemas de negocio y monitorización, más servicio gestionado opcional.',
  provider: { '@id': 'https://solutions.futurion.es/#organization' },
  areaServed: {
    '@type': 'Country',
    name: 'España',
  },
  url: 'https://solutions.futurion.es/es/smseagle/',
  inLanguage: 'es',
};

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Paquetes de Suministro e Integración SMSEagle — Futurion Solutions',
  description: 'Paquetes para suministrar, instalar, integrar y gestionar pasarelas SMS hardware SMSEagle en España.',
  inLanguage: 'es',
  provider: { '@id': 'https://solutions.futurion.es/#organization' },
  url: 'https://solutions.futurion.es/es/smseagle/',
  itemListElement: [
    {
      '@type': 'Offer',
      name: 'Suministro e Instalación',
      description:
        'Dimensionamiento y adquisición del dispositivo al precio de lista del fabricante, instalación en rack, configuración de red/SIM, hardening LDAP/MFA, configuración de email-to-SMS, una integración (monitorización o flujo de trabajo) y un informe de prueba de entrega.',
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'Proyecto de Integración',
      description:
        'Todo lo incluido en Suministro e Instalación, más diseño del flujo de mensajes (enrutamiento, webhooks, listas de opt-in, escalado) e integración con tus flujos de trabajo (n8n, Power Automate, REST o SMPP a medida), pruebas de aceptación y documentación.',
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'Configuración Crítica / Alta Disponibilidad',
      description:
        'Dos dispositivos en failover MASTER/BACKUP, failover de módem, diseño de escalado y guardias, runbook y evidencia de entrega.',
      availability: 'https://schema.org/InStock',
    },
    {
      '@type': 'Offer',
      name: 'Servicio Gestionado',
      description:
        'Actualizaciones de firmware y seguridad, cambios en reglas y flujos de trabajo, prueba mensual de entrega extremo a extremo con informe, gestión de SIM y plan, respuesta prioritaria.',
      availability: 'https://schema.org/InStock',
    },
  ],
};
---

<Layout metadata={metadata}>
  <JsonLd schema={productSchema} />
  <JsonLd schema={serviceSchema} />

  <!-- Hero -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Contáctanos',
        href: '/es/contacto/',
        icon: 'tabler:arrow-right',
      },
      {
        variant: 'secondary',
        text: 'Ver paquetes',
        href: '#pricing',
      },
    ]}
  >
    <Fragment slot="title">
      <img
        src={imgSmsEagleLogo.src}
        alt="Logotipo de SMSEagle"
        width="180"
        height="64"
        class="mx-auto mb-4 object-contain drop-shadow-lg"
      />
      <span class="text-accent dark:text-white highlight">El Hardware de Mensajería Dentro de tus Automatizaciones</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        SMSEagle es una pasarela SMS hardware fabricada en la UE: un dispositivo en tu rack con tarjetas SIM propias y
        una REST API completa. Tus flujos de trabajo — n8n, Power Automate, un chatbot, tu ERP, tu propio código — lo
        llaman para enviar mensajes de SMS, WhatsApp, Signal y voz, y cada mensaje entrante activa un webhook de vuelta
        hacia ellos. <span class="font-medium"
          >Compras el dispositivo una sola vez — sin suscripción SaaS mensual, sin tarifas por mensaje, sin proveedor
          de SMS en la nube en la ruta, sin terceros que custodien tus números de teléfono.</span
        > Nosotros suministramos el dispositivo, lo integramos en tus flujos de trabajo, y podemos gestionarlo por ti
        como <span class="font-medium">Technology Partner</span> oficial de SMSEagle para España.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-green-700"
        >Compra única. Los mensajes salen por la SIM, no por un proveedor SaaS.</span
      >
      Un dispositivo en tu rack. Tus flujos de trabajo llaman a su API; los mensajes entrantes activan webhooks de vuelta.
    </Fragment>
  </Hero>

  <!-- Device photo -->

  <section class="px-4 md:px-6 -mt-6 md:-mt-10">
    <div class="max-w-xs mx-auto">
      <img
        src={imgSmsEagleDevice.src}
        alt="Pasarela SMS hardware SMSEagle NXS-9700"
        width={imgSmsEagleDevice.width}
        height={imgSmsEagleDevice.height}
        class="w-full h-auto object-contain rounded-lg"
      />
    </div>
  </section>

  <!-- Scenarios -->

  <FeaturesCarousel
    id="features"
    tagline="Qué Construyen las Empresas con Él"
    title="Un Solo Dispositivo, Muchos Flujos de Mensajes"
    subtitle="Cada uno de estos casos se ejecuta en el mismo equipo: tus sistemas hablan con su REST API y sus webhooks; las SIM hablan con la red móvil."
    items={[
      {
        title: 'Comunicación con Clientes',
        description:
          'Confirmaciones de cita, actualizaciones de pedido y entrega, recordatorios de pago — enviados desde tu ERP o CRM mediante REST API o email-to-SMS, con callbacks de estado de entrega que informan de vuelta al flujo de trabajo. Las listas de palabras clave de opt-in/opt-out gestionan los grupos de destinatarios en el propio dispositivo.',
        icon: 'tabler:messages',
      },
      {
        title: 'Chatbots y Conversaciones Bidireccionales',
        description:
          'Cada SMS, WhatsApp o Signal entrante activa un webhook — con condiciones de remitente y contenido, reintentado hasta 24 horas — hacia n8n, Power Automate o tu propio código; el flujo de trabajo decide y responde a través de la API. Las autorespuestas simples por palabra clave se ejecutan en el propio dispositivo.',
        icon: 'tabler:message-chatbot',
      },
      {
        title: '2FA y Códigos de Un Solo Uso',
        description:
          'Tu aplicación envía códigos OTP a través de la REST API del dispositivo mediante tus propias SIM — ningún proveedor de SMS en la nube gestiona los números de teléfono de tus usuarios.',
        icon: 'tabler:lock-check',
      },
      {
        title: 'Un LLM en el Bucle',
        description:
          'Mensaje entrante → webhook → tu flujo de trabajo → un modelo de lenguaje — incluido uno alojado en tus propios servidores → respuesta a través de la API. El dispositivo no tiene lógica de bot: es el canal de envío/recepción on-premise, y la inteligencia permanece en tu capa de flujo de trabajo.',
        icon: 'tabler:cpu',
      },
      {
        title: 'Alertas de TI/OT',
        description:
          'Sondas integradas ICMP, TCP/UDP, SNMP y Modbus TCP, ~80 plugins de monitorización — Zabbix, PRTG, Nagios, Icinga, Checkmk, Pandora FMS — grupos de escalado, turnos de guardia, llamadas de voz de aviso y alta disponibilidad MASTER/BACKUP.',
        icon: 'tabler:activity-heartbeat',
      },
      {
        title: 'Reglas Entre Canales Sin Código',
        description:
          'Reglas en el propio dispositivo con condiciones AND/OR/NOT y regex enrutan mensajes entre canales — de correo a SMS, de SMS a WhatsApp, de SMS a MQTT — configuradas en la interfaz web.',
        icon: 'tabler:sitemap',
      },
    ]}
  />

  <!-- How it connects -->

  <Features2
    tagline="Interfaces"
    title="Cómo se Comunican tus Sistemas con Él"
    subtitle="Elige la interfaz que tu stack ya utilice — todas se ejecutan en el propio dispositivo, en tu red."
    columns={3}
    items={[
      {
        title: 'REST API',
        description:
          'Una API HTTP completa — el propio dispositivo publica la especificación OpenAPI — para enviar y leer SMS, MMS, WhatsApp y Signal, gestionar la agenda y comprobar el estado de entrega.',
        icon: 'tabler:api',
      },
      {
        title: 'Webhooks',
        description:
          'Cada mensaje entrante puede llamar a cualquier URL (GET/POST) en tiempo real, con reglas condicionales y reintentos durante hasta 24 horas — más callbacks cuando cambia el estado de un mensaje saliente.',
        icon: 'tabler:webhook',
      },
      {
        title: 'n8n y Power Automate',
        description:
          'Un nodo de n8n ya preparado y flujos de Power Automate basados en HTTP — entre los ~80 plugins que publica SMSEagle, incluido Zapier.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Email-to-SMS / SMS-to-Email',
        description: 'Cualquier sistema que pueda enviar un correo puede enviar un SMS — y los SMS entrantes pueden llegar a una bandeja de entrada.',
        icon: 'tabler:mail-forward',
      },
      {
        title: 'Servidor SMPP',
        description: 'Un servidor SMPP integrado para sistemas que hablan directamente el protocolo de telecomunicaciones.',
        icon: 'tabler:server',
      },
      {
        title: 'MQTT',
        description: 'SMS a MQTT y MQTT a SMS para brokers IoT y OT.',
        icon: 'tabler:antenna',
      },
      {
        title: 'WhatsApp y Signal con Reserva por SMS',
        description: 'Si un número no es alcanzable en la aplicación, el mensaje se envía automáticamente por SMS en su lugar.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Voz y Texto a Voz',
        description: 'Llamadas de voz, llamadas de aviso y texto a voz para los mensajes que necesitan sonar, no solo notificar.',
        icon: 'tabler:phone-call',
      },
    ]}
  />

  <!-- Why hardware, on your premises -->

  <Content
    columns={2}
    tagline="Por Qué Hardware, en tus Instalaciones"
    title="Ningún Proveedor Cloud en la Ruta del Mensaje"
    items={[
      {
        title: 'La ruta es corta',
        description:
          'Tu sistema → el dispositivo en tu rack → la red móvil del operador. Ningún proveedor de SMS en la nube se interpone, por lo que ningún subencargado retiene el contenido de los mensajes ni los números de teléfono.',
      },
      {
        title: 'WhatsApp y Signal, con honestidad',
        description:
          'Esos mensajes viajan por las propias redes de Meta o Signal, por la propia naturaleza del canal: SMSEagle no añade ningún proveedor cloud adicional a esa ruta, y recurre automáticamente al SMS normal como reserva.',
      },
      {
        title: 'Sigue alertando aunque falle tu Internet',
        description:
          'Enlace caído, DNS roto, VPN inactiva, incidente del proveedor cloud: el SMS sigue saliendo por la SIM. Un apagón nacional prolongado también degrada las redes móviles; el decreto de resiliencia pendiente en España exigirá a los operadores mantener cuatro horas de cobertura móvil para el 75% de la población durante los cortes.',
      },
      {
        title: 'Una compra única, no una suscripción',
        description:
          'Dispositivo más plan de SIM, sin medición por mensaje, sin licencias por usuario. SMSEagle publica una comparativa de punto de equilibrio frente a las API de SMS en la nube en torno a los 10.000 mensajes/mes: es una afirmación del propio fabricante, que conviene contrastar con tus propios volúmenes.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Fabricado en la UE, Certificado, Alineado con el RGPD por Arquitectura
      </h3>
      Los dispositivos SMSEagle se fabrican en la UE por una empresa certificada en ISO 27001, cuentan con certificación
      CE, FCC y UKCA, y están alineados con el RGPD por diseño, porque de entrada no hay ningún servicio en la nube en
      la ruta, no por una declaración de cumplimiento añadida encima.
    </Fragment>
  </Content>

  <!-- What we do as your integrator -->

  <Content
    isAfterContent
    tagline="Qué Hacemos Como tu Integrador"
    title="Cinco Pasos del Dispositivo a un Flujo de Mensajes Funcionando"
    items={[
      {
        title: 'Dimensionamiento y suministro',
        description:
          'Qué modelo — uno, dos u ocho módems — más el complemento de voz, la garantía y el plan de SIM. Cotizamos al precio de lista del fabricante.',
      },
      {
        title: 'Instalación',
        description: 'Montaje en rack o carril DIN, configuración de red, activación de la SIM, hardening LDAP/MFA, y un plan de pruebas con evidencia de entrega.',
      },
      {
        title: 'Integración',
        description:
          'Tus flujos de trabajo — n8n, Power Automate, un chatbot, tu ERP o CRM — tu stack de monitorización — Zabbix, PRTG, Nagios, Icinga, Checkmk, Pandora FMS — o un desarrollo a medida a partir de la REST API, los webhooks, SMPP, email-to-SMS o MQTT del dispositivo.',
      },
      {
        title: 'Diseño del flujo de mensajes',
        description:
          'Quién recibe qué mensaje por qué canal — enrutamiento, listas de opt-in, autorespuestas y escalado con reserva cuando es una alerta que nadie ha confirmado.',
      },
      {
        title: 'Servicio gestionado (opcional)',
        description: 'Actualizaciones, mantenimiento de reglas, pruebas mensuales de entrega y gestión de SIM — consulta los paquetes más abajo.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        La Tienda Vende el Hardware — Esta es la Parte que no Puede Enviarte
      </h3>
      El dispositivo es el mismo que vende SMSEagle directamente, al mismo precio de lista. Lo que aporta un integrador
      es soporte en español, un técnico que realiza la instalación, una integración que realmente se comunica con tus
      sistemas, y un único interlocutor local responsable de toda la ruta del mensaje.
    </Fragment>
  </Content>

  <!-- Pricing -->

  <JsonLd schema={pricingSchema} />

  <Prices
    id="pricing"
    tagline="Paquetes"
    title="Suministro, Instalación, Integración y Servicio Gestionado"
    subtitle="El hardware siempre se cotiza al precio de lista público de SMSEagle. Nuestros honorarios cubren dimensionamiento, instalación, integración y gestión continua — ajustados a lo que realmente necesitas."
    prices={[
      {
        title: 'Suministro e Instalación',
        subtitle: 'Pon en marcha un dispositivo',
        price: 'A medida',
        period: 'Contacta para presupuesto',
        items: [
          { description: 'Dimensionamiento y adquisición del dispositivo al precio de lista' },
          { description: 'Instalación en rack y configuración de red/SIM' },
          { description: 'Hardening LDAP/MFA' },
          { description: 'Una integración (monitorización o flujo de trabajo)' },
          { description: 'Informe de prueba de entrega' },
        ],
        callToAction: {
          text: 'Contáctanos',
          href: '/es/contacto/',
        },
      },
      {
        title: 'Proyecto de Integración',
        subtitle: 'Conéctalo a tus flujos de trabajo',
        price: 'A medida',
        period: 'Contacta para presupuesto',
        items: [
          { description: 'Todo lo incluido en Suministro e Instalación' },
          { description: 'Diseño del flujo de mensajes (enrutamiento, webhooks, listas de opt-in, escalado)' },
          { description: 'Integración con n8n / Power Automate / REST / SMPP' },
          { description: 'Pruebas de aceptación y documentación' },
        ],
        callToAction: {
          text: 'Contáctanos',
          href: '/es/contacto/',
        },
        hasRibbon: true,
        ribbonTitle: 'más habitual',
      },
      {
        title: 'Configuración Crítica / Alta Disponibilidad',
        subtitle: 'Para rutas que no pueden fallar',
        price: 'A medida',
        period: 'Contacta para presupuesto',
        items: [
          { description: 'Dos dispositivos, failover MASTER/BACKUP' },
          { description: 'Failover de módem' },
          { description: 'Diseño de escalado y guardias' },
          { description: 'Runbook y evidencia de entrega' },
        ],
        callToAction: {
          text: 'Contáctanos',
          href: '/es/contacto/',
        },
      },
      {
        title: 'Servicio Gestionado',
        subtitle: 'Nosotros lo mantenemos en marcha',
        price: 'A medida',
        period: 'Contacta para presupuesto',
        items: [
          { description: 'Actualizaciones de firmware y seguridad' },
          { description: 'Mantenimiento de reglas y flujos de trabajo' },
          { description: 'Prueba mensual de entrega con informe' },
          { description: 'Gestión de SIM y plan' },
          { description: 'Respuesta prioritaria' },
        ],
        callToAction: {
          text: 'Contáctanos',
          href: '/es/contacto/',
        },
      },
    ]}
  />

  <!-- FAQs -->

  <FAQs
    title="SMSEagle — Preguntas Frecuentes"
    subtitle="Respuestas directas sobre el dispositivo, los canales y lo que hacemos como tu integrador."
    tagline="Preguntas Frecuentes"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Puede alimentar un chatbot o una conversación bidireccional?',
        description:
          'Sí, como canal de envío/recepción. Cada SMS, WhatsApp o Signal entrante activa un webhook hacia n8n, Power Automate o tu propio código; tu flujo de trabajo decide qué responder y contesta a través de la REST API. El dispositivo en sí solo hace autorespuestas simples por palabra clave — la lógica de la conversación vive en tu capa de flujo de trabajo.',
      },
      {
        title: '¿Puede funcionar con un LLM, incluido uno que alojemos nosotros mismos?',
        description:
          'Sí. El patrón es: mensaje entrante → webhook → tu flujo de trabajo → un modelo de lenguaje → respuesta a través de la REST API. El modelo puede ejecutarse en un servicio en la nube o en tus propios servidores — también desplegamos IA on-premise — de modo que todo el ciclo conversacional, modelo incluido, puede quedarse dentro de tu organización.',
      },
      {
        title: '¿Podemos usarlo para 2FA / contraseñas de un solo uso?',
        description:
          'Sí — tu aplicación envía los códigos OTP a través de la REST API y salen por tus propias SIM, de modo que ningún proveedor de SMS en la nube ve los números de teléfono de tus usuarios. El propio dispositivo también exige MFA para su acceso de administración.',
      },
      {
        title: '¿Necesita conexión a Internet?',
        description:
          'No para enviar SMS o voz: los mensajes salen por la SIM a través de la red móvil. Internet/LAN se usa para recibir activaciones desde tus sistemas y para la interfaz web/API en tu red. Email-to-SMS necesita que tu flujo de correo llegue al dispositivo.',
      },
      {
        title: '¿Funciona durante un apagón eléctrico?',
        description:
          'El dispositivo funciona con un SAI, como el resto de tu rack. Las propias redes móviles se degradaron entre dos y ocho horas durante el apagón de abril de 2025, y el decreto de resiliencia pendiente en España exigirá a los operadores mantener cuatro horas de cobertura para el 75% de la población. Es un canal de alertas fuera de banda para el caso habitual: que falle tu conectividad, no la red eléctrica nacional.',
      },
      {
        title: '¿Enviáis nuestros datos a través de un proveedor de SMS en la nube?',
        description:
          'No. El SMS normal y la voz van del dispositivo al operador directamente. Los mensajes de WhatsApp y Signal viajan por esas redes por la propia naturaleza del canal, con reserva automática por SMS: no se añade ningún proveedor cloud adicional a la ruta.',
      },
      {
        title: '¿Cuánto cuesta el dispositivo?',
        description:
          'Los precios de lista del fabricante van desde 989 € (un solo módem 4G) hasta 2.694 € (ocho módems), sin IVA, pago único: sin licencia de software, sin coste por mensaje, sin suscripción SaaS mensual. Cotizamos los mismos precios de lista; nuestros honorarios son por la instalación, la integración y el servicio gestionado.',
      },
      {
        title: '¿Con qué se integra?',
        description:
          'Primero, herramientas de flujo de trabajo: n8n, Zapier y Power Automate vía HTTP. Después, monitorización: SMSEagle publica alrededor de 80 plugins listos para usar — Zabbix, Nagios, PRTG, Icinga, Checkmk, Centreon, LibreNMS, SolarWinds, SCOM y más. Cualquier otro sistema se integra mediante REST API, webhooks, SMPP, email-to-SMS o MQTT.',
      },
      {
        title: '¿Esto ayuda con NIS2, ENS o DORA?',
        description:
          'Esos marcos normativos esperan que detectes, reacciones y notifiques a tiempo, y DORA exige explícitamente canales de comunicación alternativos cuando fallan los principales. Una ruta de alertas fuera de banda respalda esas obligaciones — por sí sola no te hace cumplir la normativa.',
      },
      {
        title: '¿Podéis gestionarlo vosotros?',
        description:
          'Sí — el servicio gestionado incluye actualizaciones de firmware, mantenimiento de reglas y flujos de trabajo, pruebas mensuales de entrega y gestión de SIM, facturado por dispositivo y mes.',
      },
      {
        title: '¿Por qué trabajar con Futurion en lugar de comprar directamente en la tienda de SMSEagle?',
        description:
          'El mismo precio de lista para el hardware. Como Technology Partner de SMSEagle, nuestro trabajo es la parte que la tienda no puede enviarte: desplegar el dispositivo de forma eficiente en tu infraestructura — soporte en español, instalación, integración con tus sistemas, diseño del flujo de mensajes, y un único interlocutor local responsable de toda la ruta del mensaje.',
      },
    ]}
  />

  <!-- CTA -->

  <CallToAction
    actions={[
