---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Note from '~/components/widgets/Note.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Futurion Solutions — Compliance-First AI Automation for Healthcare',
  ignoreTitleTemplate: true,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a compliance-first AI audit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our free audit assesses your clinic's data handling, identifies where AI can safely automate tasks, and flags compliance gaps. It is a risk and process audit with an AI feasibility overlay — not a sales pitch. You receive a detailed report you can act on independently."
      }
    },
    {
      "@type": "Question",
      "name": "Will patient data be sent to the cloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We design hybrid and on-premise AI solutions that keep patient data within your clinic's infrastructure. Most cloud-based AI tools are unsuitable for healthcare data under GDPR. We use architectures that keep sensitive data local."
      }
    },
    {
      "@type": "Question",
      "name": "How much does implementation cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our quick-win implementations start at around €1,500-3,000 for 1-2 automations. Comprehensive automation packages range from €5,000-15,000. Monthly support starts at €200/month. The free audit gives you a clear picture before any commitment."
      }
    },
    {
      "@type": "Question",
      "name": "We're a small clinic — is this for us?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We specialize in small healthcare businesses: dental clinics, pharmacies, and practices with 1-10 employees. Our solutions are designed to be affordable and impactful for practices that don't have dedicated IT teams."
      }
    },
    {
      "@type": "Question",
      "name": "What GDPR and compliance frameworks do you follow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We work with GDPR, HIPAA, SOC2, and ISO 27001 frameworks. Every automation includes proper data processing agreements, audit trails, consent management, and documentation required by EU and Spanish (AEPD) regulations."
      }
    },
    {
      "@type": "Question",
      "name": "How long does implementation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The free audit takes 5-7 business days. Quick-win implementations can be completed in 2-4 weeks. Full automation transformations typically take 6-12 weeks, depending on complexity. You see results from week one."
      }
    },
    {
      "@type": "Question",
      "name": "What if we already use a practice management system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We integrate with your existing tools. Our automations work alongside your current practice management software, EHR systems, and workflows — we enhance what you have rather than replacing it."
      }
    },
    {
      "@type": "Question",
      "name": "Is the audit really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The 5-7 day AI compliance audit is completely free with no obligations. You receive a full report with risk scores, automation recommendations, and a compliance roadmap. About 40-60% of audited clinics choose to proceed with implementation, but there is zero pressure."
      }
    },
    {
      "@type": "Question",
      "name": "What does your appointment automation include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Smart scheduling, reminders, and follow-ups that reduce no-shows by up to 30% — all GDPR compliant."
      }
    },
    {
      "@type": "Question",
      "name": "How do you handle patient communications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Automated but personal communications through compliant channels, replacing risky WhatsApp and personal email usage."
      }
    },
    {
      "@type": "Question",
      "name": "Can you automate billing and insurance processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Streamlined billing workflows that reduce errors and save hours of manual administrative work each week."
      }
    },
    {
      "@type": "Question",
      "name": "What compliance documentation do you provide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Automated audit trails, data processing records, and compliance reports that keep you inspection-ready at all times. Every automation is architected with GDPR principles at its core — data minimisation, purpose limitation, security controls, and audit trails from day one."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <JsonLd schema={faqSchema} />

  <!-- Hero Banner -->
  <div class="relative w-full overflow-hidden" style="height: 480px;">
    <img
      src="/images/2025/08/colab3_banner.jpg"
      alt="Compliance-First AI Automation for Healthcare Providers"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/0 flex items-center justify-center">
      <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter text-white text-center px-8">
        Compliance-First AI Automation<br />for Healthcare Providers
      </h1>
    </div>
  </div>

  <!-- Hero Subtitle -->
  <div class="max-w-3xl mx-auto text-center px-6 py-6 text-muted">
    <p class="text-xl">
      We help medical practices, pharmacies, and dental clinics save 10-15 hours per week through AI automation — without compromising patient data security or GDPR compliance. Enterprise-level compliance expertise, built for healthcare SMBs in Spain and the EU.
    </p>
  </div>

  <!-- Trust Stats -->

  <Stats
    stats={[
      { title: 'Compliance Frameworks', amount: '4+', icon: 'tabler:shield-check' },
      { title: 'Hours Saved Weekly', amount: '10-15', icon: 'tabler:clock' },
      { title: 'Data Risk Reduction', amount: '90%', icon: 'tabler:lock' },
      { title: 'Audit Conversion', amount: '40-60%', icon: 'tabler:chart-arrows' },
    ]}
  />

  <!-- Problem / Pain Points -->

  <Content
    isReversed
    tagline="The Challenge"
    title="Healthcare Compliance Is Complex — AI Makes It Harder"
    items={[
      {
        title: 'GDPR complexity for small practices',
        description:
          'You face the same data protection requirements as large hospitals, but without dedicated IT teams or compliance officers.',
      },
      {
        title: 'Cloud AI risks with patient data',
        description:
          'Most AI tools send patient data to external cloud servers — a potential GDPR violation that puts your practice at risk.',
      },
      {
        title: 'Administrative overload stealing patient time',
        description:
          'Appointment scheduling, follow-ups, billing, and paperwork consume hours that should be spent on patient care.',
      },
    ]}
    image={{
      src: '~/assets/images/data-dashboard.jpg',
      alt: 'Person overwhelmed by administrative work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Sound familiar?</h3>
      Most AI agencies don't understand healthcare regulations. Most compliance consultants don't understand AI. You need both.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Differentiators -->

  <Features
    id="features"
    tagline="Why Futurion Solutions"
    title="What makes us different"
    subtitle="We bridge the gap between AI automation and healthcare compliance — so you don't have to choose between efficiency and data protection."
    columns={3}
    items={[
      {
        title: 'Compliance-First Approach',
        description:
          'Every automation is built with GDPR, HIPAA, and data privacy requirements at its core — not added as an afterthought.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Hybrid & On-Prem AI',
        description:
          'Patient data stays in your clinic. We design solutions that work locally or in hybrid setups, never sending sensitive data to external clouds. For larger organizations, MedCore Private AI delivers fully on-premise medical-grade AI infrastructure.',
        icon: 'tabler:server',
      },
      {
        title: 'Enterprise Security for SMBs',
        description:
          'SOC2, ISO 27001, and enterprise-grade security practices — scaled and priced for small healthcare businesses.',
        icon: 'tabler:lock',
      },
    ]}
  />

  <!-- How It Works -->

  <Steps
    title="How it works"
    subtitle="From initial audit to ongoing support, we make AI adoption safe and simple for your practice."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Free AI Compliance Audit</span>',
        description:
          'We assess your clinic\'s data flows, compliance posture, and automation opportunities in a free 5-7 day audit. You receive a detailed report with risk scores and safe automation recommendations.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Step 2: <span class="font-medium">Compliant Implementation</span>',
        description:
          'We build and deploy AI automations designed with data privacy at their core. On-prem or hybrid architecture ensures patient data never leaves your control.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Step 3: <span class="font-medium">Ongoing Support & Monitoring</span>',
        description:
          'We monitor your automations, update compliance controls as regulations evolve, and optimize performance. Your trusted AI partner, month after month.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Results: Save 10-15 hours per week',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '~/assets/images/team-working.jpg',
      alt: 'Team collaborating on a project',
    }}
  />

  <!-- CTA Banner -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Automation Roadmap',
        href: '/automation-roadmap',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Start with a Free 5-7 Day AI Compliance Audit</Fragment>

    <Fragment slot="subtitle">
      We assess your clinic's data flows, identify safe automation opportunities, and deliver a clear compliance roadmap — at no cost. Limited to 8 audits per month.
    </Fragment>
  </CallToAction>

  <!-- MedCore Note -->

  <Note
    icon="tabler:server"
    title="For Medium Healthcare Organizations:"
    description='Explore <a href="/medcore-private-ai" class="underline font-bold">MedCore Private AI</a> — fully on-premise, medical-grade AI infrastructure with complete data sovereignty.'
  />

  <!-- FAQs -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about compliance-first AI automation for your healthcare practice."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is a compliance-first AI audit?',
        description:
          'Our free audit assesses your clinic\'s data handling, identifies where AI can safely automate tasks, and flags compliance gaps. It is a risk and process audit with an AI feasibility overlay — not a sales pitch. You receive a detailed report you can act on independently.',
      },
      {
        title: 'Will patient data be sent to the cloud?',
        description:
          'No. We design hybrid and on-premise AI solutions that keep patient data within your clinic\'s infrastructure. Most cloud-based AI tools are unsuitable for healthcare data under GDPR. We use architectures that keep sensitive data local.',
      },
      {
        title: 'How much does implementation cost?',
        description:
          'Our quick-win implementations start at around €1,500-3,000 for 1-2 automations. Comprehensive automation packages range from €5,000-15,000. Monthly support starts at €200/month. The free audit gives you a clear picture before any commitment.',
      },
      {
        title: 'We\'re a small clinic — is this for us?',
        description:
          'Absolutely. We specialize in small healthcare businesses: dental clinics, pharmacies, and practices with 1-10 employees. Our solutions are designed to be affordable and impactful for practices that don\'t have dedicated IT teams.',
      },
      {
        title: 'What GDPR and compliance frameworks do you follow?',
        description:
          'We work with GDPR, HIPAA, SOC2, and ISO 27001 frameworks. Every automation includes proper data processing agreements, audit trails, consent management, and documentation required by EU and Spanish (AEPD) regulations.',
      },
      {
        title: 'How long does implementation take?',
        description:
          'The free audit takes 5-7 business days. Quick-win implementations can be completed in 2-4 weeks. Full automation transformations typically take 6-12 weeks, depending on complexity. You see results from week one.',
      },
      {
        title: 'What if we already use a practice management system?',
        description:
          'We integrate with your existing tools. Our automations work alongside your current practice management software, EHR systems, and workflows — we enhance what you have rather than replacing it.',
      },
      {
        title: 'Is the audit really free?',
        description:
          'Yes. The 5-7 day AI compliance audit is completely free with no obligations. You receive a full report with risk scores, automation recommendations, and a compliance roadmap. About 40-60% of audited clinics choose to proceed with implementation, but there is zero pressure.',
      },
      {
        title: 'What does your appointment automation include?',
        description:
          'Smart scheduling, reminders, and follow-ups that reduce no-shows by up to 30% — all GDPR compliant.',
      },
      {
        title: 'How do you handle patient communications?',
        description:
          'Automated but personal communications through compliant channels, replacing risky WhatsApp and personal email usage.',
      },
      {
        title: 'Can you automate billing and insurance processing?',
        description:
          'Streamlined billing workflows that reduce errors and save hours of manual administrative work each week.',
      },
      {
        title: 'What compliance documentation do you provide?',
        description:
          'Automated audit trails, data processing records, and compliance reports that keep you inspection-ready at all times. Every automation is architected with GDPR principles at its core — data minimisation, purpose limitation, security controls, and audit trails from day one.',
      },
    ]}
  />

  <!-- Latest Blog Posts -->

  <BlogLatestPosts
    title="Compliance & AI Insights"
    information="Stay informed about healthcare compliance, AI automation best practices, and regulatory updates for small healthcare providers in Spain and the EU."
    lang="en"
  />

  <!-- Final CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Automation Roadmap',
        href: '/automation-roadmap',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Ready to Automate Compliantly?</Fragment>

    <Fragment slot="subtitle">
      Join healthcare practices across Spain that are saving 10-15 hours per week with AI automation — without compromising patient data or compliance. Start with a free audit today.
    </Fragment>
  </CallToAction>
</Layout>
