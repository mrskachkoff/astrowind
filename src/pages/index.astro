---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { Image as AstroImage } from 'astro:assets';
import colab3Banner from '~/assets/images/colab3_banner.jpg';
import ComplianceAutomationMap from '~/components/widgets/ComplianceAutomationMap.astro';
import TrustCoreGraph from '~/components/widgets/TrustCoreGraph.astro';

const metadata = {
  title: 'Futurion Solutions — Private AI for Regulated Organisations',
  description: 'Private AI tools and automation that keep sensitive data inside your own boundary — on your hardware or your cloud account. Mapped to GDPR, the EU AI Act, ISO 27001 and SOC 2.',
  ignoreTitleTemplate: true,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does Futurion Solutions do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We build private AI tools — TrustPrompt and TrustCore — and run an automation practice, TrustAuto, for organisations that work with sensitive or regulated data. Everything is designed to run on infrastructure you control rather than a shared cloud service."
      }
    },
    {
      "@type": "Question",
      "name": "Does our data leave our own infrastructure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. TrustPrompt analyses text in the browser, TrustCore answers from documents on your own machine, and TrustAuto automations run on-premise or in a hybrid setup. Sensitive data stays inside your boundary."
      }
    },
    {
      "@type": "Question",
      "name": "Which compliance frameworks do you map to?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GDPR, the EU AI Act, ISO 27001 and SOC 2, plus HIPAA and Spanish AEPD requirements for healthcare. Each deployment is documented against the obligations you answer to."
      }
    },
    {
      "@type": "Question",
      "name": "Can the products run fully on-premise?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. TrustPrompt and TrustCore work locally by default; for heavier workloads you point them at endpoints you already run. MedCore runs entirely on your premises."
      }
    },
    {
      "@type": "Question",
      "name": "How is TrustPrompt different from a network DLP proxy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A proxy has to receive your text to inspect it, which adds a party that now holds the data and breaks on encrypted or personal-device traffic. TrustPrompt removes personal data in the browser before the prompt is sent, so nothing new in the path ever sees the original text."
      }
    },
    {
      "@type": "Question",
      "name": "What is the free automation roadmap?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A short assessment of your data flows and compliance posture. You receive a written report with risk scores and the automations worth doing first. It is a roadmap you can act on independently, with no obligation."
      }
    },
    {
      "@type": "Question",
      "name": "What does this cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The roadmap is free. TrustPrompt and TrustCore are offered as per-seat plans with a free local tier; automation engagements are scoped from the roadmap. Plans follow the EU SME size bands."
      }
    },
    {
      "@type": "Question",
      "name": "Do you integrate with our existing systems?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Automations and tools work alongside your current software and records — including FHIR and OpenEHR in healthcare — rather than replacing them."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <JsonLd schema={faqSchema} />

  <!-- Hero Banner -->
  <div class="relative w-full overflow-hidden" style="height: 480px;">
    <AstroImage
      src={colab3Banner}
      alt="Private AI for regulated organisations"
      class="absolute inset-0 w-full h-full object-cover"
      widths={[768, 1024, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/0 flex items-center justify-center">
      <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter text-white text-center px-8">
        Private AI for<br />Regulated Organisations
      </h1>
    </div>
  </div>

  <!-- Hero Subtitle -->
  <div class="max-w-3xl mx-auto text-center px-6 py-6 text-muted">
    <p class="text-xl">
      Futurion Solutions builds AI tools and automation that keep sensitive data inside your own boundary — on your hardware or your cloud account. We work with legal, compliance, finance and healthcare teams across Spain and the EU, mapping every deployment to GDPR, the EU AI Act, ISO 27001 and SOC&nbsp;2.
    </p>
  </div>

  <!-- Compliance Automation Map -->

  <ComplianceAutomationMap
    heroTitle="Your Compliance Automation Services"
    servicesLabel="Our Services"
    frameworks={[
      {
        badge: 'GDPR',
        name: 'GDPR',
        accent: 'var(--fds-acc-blue)',
        items: [
          { text: 'Art. 46 - Appropriate safeguards - PII / sensitive data', tip: 'Requires safeguards such as SCCs, BCRs, codes of conduct, or certification where no adequacy decision exists.' },
          { text: 'Art. 35 - Data Protection Impact Assessment - High-risk / sensitive data', tip: 'DPIAs are required for high-risk sharing activities, especially involving sensitive data.' },
          { text: 'Art. 32(1)(b) - Confidentiality, integrity, availability, resilience - PII / sensitive data', tip: 'Requires security controls to prevent unauthorised sharing or leakage.' },
          { text: 'Art. 32(1)(a) - Pseudonymisation and encryption - PII / sensitive data', tip: 'Shared data should be protected through appropriate technical measures.' },
          { text: 'Art. 9 - Special categories of personal data - Sensitive data', tip: 'Sharing sensitive data is prohibited unless a specific Art. 9 exception applies, such as explicit consent or substantial public interest.' },
          { text: 'Art. 5(1)(c) - Data minimisation - PII', tip: 'Only the minimum personal data necessary may be shared.' },
        ],
      },
      {
        badge: 'HIPAA',
        name: 'HIPAA',
        accent: 'var(--fds-acc-pink)',
        items: [
          { text: '45 CFR § 164.502(b) - Minimum necessary standard - PHI / sensitive health information', tip: 'Requires covered entities and business associates to make reasonable efforts to limit uses, disclosures, and requests for PHI to the minimum necessary to accomplish the intended purpose.' },
          { text: '45 CFR § 164.530(c) - Safeguards - PHI', tip: 'Requires appropriate administrative, technical, and physical safeguards to protect PHI from intentional or unintentional unauthorised use or disclosure.' },
          { text: '45 CFR § 164.312(a) - Access control - ePHI', tip: 'Requires technical controls that allow access only to authorised users and systems.' },
          { text: '45 CFR § 164.312(b) - Audit controls - ePHI', tip: 'Requires mechanisms to record and examine activity in systems that contain or use ePHI.' },
        ],
      },
      {
        badge: 'AI',
        name: 'AI Act',
        accent: 'var(--fds-acc-lime)',
        items: [
          { text: 'Art. 10(5) - Processing special categories of personal data for bias detection and correction - Sensitive data', tip: 'Allows processing of special category data only where strictly necessary, with safeguards such as reuse limitations, security and privacy-preserving measures, access restrictions, and confidentiality obligations.' },
          { text: 'Art. 15 - Accuracy, robustness and cybersecurity - PII / sensitive data', tip: 'Requires high-risk AI systems to be resilient against unauthorised access, misuse, or manipulation that could expose or compromise sensitive information.' },
          { text: 'Art. 78 - Confidentiality - PII / sensitive data / confidential information', tip: 'Requires authorities and involved bodies to protect confidential information and request only data strictly necessary for risk assessment and regulatory powers.' },
        ],
      },
      {
        badge: 'ISO',
        name: 'ISO 27001',
        accent: 'var(--fds-acc-purple)',
        items: [
          { text: 'Annex A 5.14 - Information transfer - PII / sensitive data', tip: 'Requires rules, procedures, and agreements to protect information transferred electronically, physically, or verbally.' },
          { text: 'Annex A 8.12 - Data leakage prevention - PII / sensitive data', tip: 'Requires measures to detect and prevent unauthorised disclosure, transmission, or extraction of sensitive information.' },
          { text: 'Annex A 8.11 - Data masking - PII / sensitive data', tip: 'Requires masking techniques such as pseudonymisation, anonymisation, or redaction to limit exposure of sensitive information.' },
          { text: 'Annex A 5.15 - Access control - PII / sensitive data', tip: 'Requires access to information and systems to be restricted according to business and security requirements.' },
        ],
      },
      {
        badge: 'SOC2',
        name: 'SOC2',
        accent: 'var(--fds-acc-royal)',
        items: [
          { text: 'CC6.6 - Prevention of unauthorised access - PII / sensitive data', tip: 'Requires controls to prevent or detect unauthorised access to systems, data, and protected information.' },
          { text: 'CC6.7 - Restriction of data transmission, movement, and removal - PII / sensitive data', tip: 'Requires controls over transmission, movement, and removal of information to prevent unauthorised sharing or leakage.' },
          { text: 'CC7.2 - Monitoring for security events - PII / sensitive data', tip: 'Requires monitoring to detect events that could result in unauthorised disclosure or compromise of protected information.' },
          { text: 'C1.1 - Identification and protection of confidential information - Confidential information / sensitive data', tip: 'Requires confidential information to be identified, classified, retained, and protected according to confidentiality commitments and requirements.' },
          { text: 'P4.1 - Personal information use limitation - PII', tip: 'Requires personal information to be used only for purposes identified in notices or otherwise authorised.' },
          { text: 'P6.1 - Disclosure to third parties - PII', tip: 'Requires personal information disclosed to third parties to be limited to authorised purposes and consistent with privacy commitments.' },
        ],
      },
    ]}
    services={[
      { name: 'TrustPrompt', logo: 'trustprompt', href: '/products/trustprompt/' },
      { name: 'TrustCore',   logo: 'trustcore',   href: '/products/trustcore/' },
      { name: 'TrustAuto',   logo: 'trustauto',   href: '/products/trustauto/' },
    ]}
    rows={[
      {
        label: 'Protect Sensitive Information',
        pills: [
          { mini: 'DLP',  label: 'DLP',  sub: 'Data loss prevention' },
          { mini: 'GRC',  label: 'GRC',  sub: 'Governance, Risk, and Compliance' },
          { mini: 'PII',  label: 'PII',  sub: 'Personally Identifiable Information' },
          { mini: 'PHI',  label: 'PHI',  sub: 'Protected Health Information' },
          { mini: 'AIG',  label: 'AIG',  sub: 'AI Governance' },
        ],
      },
      {
        label: 'Your Infrastructure — Your Rules',
        pills: [
          { mini: 'On', label: 'On-Prem', logo: 'onprem' },
          { mini: 'Cl', label: 'Cloud',   logo: 'cloud' },
        ],
      },
      {
        label: 'Our Stack',
        pills: [
          { mini: 'RAG',  label: 'RAG + embeddings', logo: 'rag' },
          { mini: 'VDB',  label: 'Vector Database' },
          { mini: 'OC',   label: 'OCR', logo: 'ocr' },
          { mini: 'TP',   label: 'TrustPrompt', logo: 'trustprompt' },
          { mini: 'OW',   label: 'Open WebUI',  logo: 'openwebui' },
          { mini: 'FHIR', label: 'HAPI FHIR',   logo: 'hapifhir', break: true },
          { mini: 'EHR',  label: 'OpenEHR',     logo: 'openehr' },
        ],
      },
      {
        label: 'Local LLMs',
        pills: [
          { mini: 'OL', label: 'OLLAMA', logo: 'ollama' },
          { mini: 'G',  label: 'GEMMA',    logo: 'gemma' },
          { mini: 'MG', label: 'MEDGEMMA' },
          { mini: 'M',  label: 'MISTRAL',  logo: 'mistral' },
          { mini: 'DS', label: 'DEEPSEEK', logo: 'deepseek' },
        ],
      },
    ]}
  />

  <!-- TrustPrompt -->

  <Content
    id="trustprompt"
    tagline="TrustPrompt"
    title="Redact Personal Data Before It Reaches a Public LLM"
    items={[
      {
        title: 'On-device detection',
        description:
          'A 560-million-parameter NER model and 40 checksum-validated rules run in the browser. Detection works offline after install — there is no detection server to send text to.',
      },
      {
        title: 'Custom rules for your own identifiers',
        description:
          'Add regex rules for the identifiers only your organisation uses — employee IDs, internal ticket numbers, patient IDs. Organisation rules run in an isolated worker with a timeout, so a bad pattern can never hang the page.',
      },
      {
        title: 'Central control for teams',
        description:
          'Push policy through Group Policy, Intune or Jamf, with audit logging that records metadata only — never the prompt text.',
      },
    ]}
    image={{
      src: '~/assets/images/trustprompt.png',
      alt: 'TrustPrompt browser extension',
    }}
    callToAction={{
      text: 'Explore TrustPrompt',
      href: '/products/trustprompt/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      A Chrome and Edge extension that detects and removes personal data in the browser, before a prompt is sent to ChatGPT, Claude, Gemini and six other services. The text you type is analysed on your own machine; the detection model ships inside the extension.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- TrustCore -->

  <Content
    id="trustcore"
    isReversed
    tagline="TrustCore"
    title="Answer Questions About Your Own Documents, On Your Own Hardware"
    items={[
      {
        title: 'Graph RAG, not similarity alone',
        description:
          'TrustCore builds a graph of the entities and relationships in your documents and reasons over it, surfacing connections that no single document states on its own.',
      },
      {
        title: 'Answers you can trace',
        description:
          'Every answer is tied to the exact passage and page it came from, and clauses that conflict across documents are flagged with both sources.',
      },
      {
        title: 'Sovereign by default',
        description:
          'Documents, the index and the graph stay on your device or on infrastructure you control. No SaaS, and no subprocessor on the local path.',
      },
    ]}
    callToAction={{
      text: 'Explore TrustCore',
      href: '/products/trustcore/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="image">
      <TrustCoreGraph />
    </Fragment>
    <Fragment slot="content">
      A browser extension with an optional local companion that indexes your documents and answers questions about them on your machine. Questions are answered from your indexed documents, and stay on your machine — there is no TrustCore cloud they pass through.
    </Fragment>
  </Content>

  <!-- TrustAuto -->

  <Content
    id="trustauto"
    tagline="TrustAuto"
    title="Compliance Automation, Built on Infrastructure You Control"
    items={[
      {
        title: 'Start with a roadmap',
        description:
          'A short assessment of your data flows and compliance posture, returning a written report with risk scores and the automations worth doing first.',
      },
      {
        title: 'Compliant implementation',
        description:
          'Document handling, scheduling, communications and billing workflows, designed around data minimisation and audit trails rather than added afterwards. On-premise or hybrid, so sensitive data stays within your boundary.',
      },
      {
        title: 'Ongoing monitoring',
        description:
          'We maintain the automations and update controls as GDPR, the EU AI Act and sector rules change.',
      },
    ]}
    image={{
      src: '~/assets/images/team-collaboration.jpg',
      alt: 'Team reviewing automated compliance workflows',
    }}
    callToAction={{
      text: 'Explore TrustAuto',
      href: '/products/trustauto/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      TrustAuto is our automation practice. We map your data flows, identify where AI can safely take over repetitive work, and build automations that run on-premise or in a hybrid setup — so sensitive data never leaves your control.
    </Fragment>
  </Content>

  <!-- MedCore (TrustAuto for healthcare) -->

  <Content
    id="medcore"
    isReversed
    tagline="TrustAuto for Healthcare"
    title="MedCore — Private AI for Medical Organisations"
    items={[
      {
        title: 'On-premise by default',
        description:
          'Patient data stays within your organisation; nothing is sent to an external cloud.',
      },
      {
        title: 'Standards-based integration',
        description:
          'Works with FHIR and OpenEHR records and the systems your teams already use.',
      },
      {
        title: 'Mapped to healthcare obligations',
        description:
          'GDPR, the EU AI Act and AEPD requirements, with documentation kept inspection-ready.',
      },
    ]}
    image={{
      src: '~/assets/images/medcore-private-ai.jpg',
      alt: 'MedCore on-premise medical AI infrastructure',
    }}
    callToAction={{
      text: 'Explore MedCore',
      href: '/medcore-private-ai/',
      icon: 'tabler:chevron-right',
    }}
  >
    <Fragment slot="content">
      MedCore is the TrustAuto offering for hospitals, clinics and medical groups: medical-grade AI infrastructure that runs entirely on your premises, built on HAPI FHIR and OpenEHR with clinical models that run locally. For context, read our analysis of <a href="/openevidence-eu-uk-withdrawal-private-on-prem-sovereign-cloud/" class="underline">OpenEvidence&apos;s EU/UK withdrawal</a> and what it means for clinical AI architecture.
    </Fragment>
  </Content>

  <!-- FAQs -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="How our tools and automation keep sensitive data inside your own boundary."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What does Futurion Solutions do?',
        description:
          'We build private AI tools — TrustPrompt and TrustCore — and run an automation practice, TrustAuto, for organisations that work with sensitive or regulated data. Everything is designed to run on infrastructure you control rather than a shared cloud service.',
      },
      {
        title: 'Does our data leave our own infrastructure?',
        description:
          'No. TrustPrompt analyses text in the browser, TrustCore answers from documents on your own machine, and TrustAuto automations run on-premise or in a hybrid setup. Sensitive data stays inside your boundary.',
      },
      {
        title: 'Which compliance frameworks do you map to?',
        description:
          'GDPR, the EU AI Act, ISO 27001 and SOC 2, plus HIPAA and Spanish AEPD requirements for healthcare. Each deployment is documented against the obligations you answer to.',
      },
      {
        title: 'Can the products run fully on-premise?',
        description:
          'Yes. TrustPrompt and TrustCore work locally by default; for heavier workloads you point them at endpoints you already run. MedCore runs entirely on your premises.',
      },
      {
        title: 'How is TrustPrompt different from a network DLP proxy?',
        description:
          'A proxy has to receive your text to inspect it, which adds a party that now holds the data and breaks on encrypted or personal-device traffic. TrustPrompt removes personal data in the browser before the prompt is sent, so nothing new in the path ever sees the original text.',
      },
      {
        title: 'What is the free automation roadmap?',
        description:
          'A short assessment of your data flows and compliance posture. You receive a written report with risk scores and the automations worth doing first. It is a roadmap you can act on independently, with no obligation.',
      },
      {
        title: 'What does this cost?',
        description:
          'The roadmap is free. TrustPrompt and TrustCore are offered as per-seat plans with a free local tier; automation engagements are scoped from the roadmap. Plans follow the EU SME size bands.',
      },
      {
        title: 'Do you integrate with our existing systems?',
        description:
          'Yes. Automations and tools work alongside your current software and records — including FHIR and OpenEHR in healthcare — rather than replacing them.',
      },
    ]}
  />

  <!-- Latest Blog Posts -->

  <BlogLatestPosts
    title="Compliance & AI Insights"
    lang="en"
  />

  <!-- Final CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Roadmap',
        href: '/automation-roadmap/',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">See Where AI Fits — Without Moving Your Data</Fragment>

    <Fragment slot="subtitle">
      Start with a free roadmap of your data flows and automation opportunities, mapped to the regulations you answer to. No obligation.
    </Fragment>
  </CallToAction>
</Layout>
