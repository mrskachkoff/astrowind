---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Note from '~/components/widgets/Note.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { Image as AstroImage } from 'astro:assets';
import colab3Banner from '~/assets/images/colab3_banner.jpg';
import ComplianceAutomationMap from '~/components/widgets/ComplianceAutomationMap.astro';

const metadata = {
  title: 'Futurion Solutions — Compliance-First AI Automation for Healthcare',
  description: 'Compliance-first AI automation for small healthcare practices in Spain and the EU. Free GDPR Automation Roadmap for dental clinics and pharmacies.',
  ignoreTitleTemplate: true,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a compliance-first automation roadmap?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our free roadmap assesses your clinic's data handling, identifies where AI can safely automate tasks, and flags compliance gaps. It is a risk and process roadmap with an AI feasibility overlay — not a sales pitch. You receive a detailed report you can act on independently."
      }
    },
    {
      "@type": "Question",
      "name": "Will patient data be sent to the cloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We design hybrid and on-premise AI solutions that keep patient data within your clinic's infrastructure. Most cloud-based AI tools are unsuitable for healthcare data under GDPR. We use architectures that keep sensitive data local."
      }
    },
    {
      "@type": "Question",
      "name": "How much does implementation cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our quick-win implementations start at around €1,500-3,000 for 1-2 automations. Comprehensive automation packages range from €5,000-15,000. Monthly support starts at €200/month. The free roadmap gives you a clear picture before any commitment."
      }
    },
    {
      "@type": "Question",
      "name": "We're a small clinic — is this for us?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We specialize in small healthcare businesses: dental clinics, pharmacies, and practices with 1-10 employees. Our solutions are designed to be affordable and impactful for practices that don't have dedicated IT teams."
      }
    },
    {
      "@type": "Question",
      "name": "What GDPR and compliance frameworks do you follow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We work with GDPR, HIPAA, SOC2, and ISO 27001 frameworks. Every automation includes proper data processing agreements, audit trails, consent management, and documentation required by EU and Spanish (AEPD) regulations."
      }
    },
    {
      "@type": "Question",
      "name": "How long does implementation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The free roadmap takes 5-7 business days. Quick-win implementations can be completed in 2-4 weeks. Full automation transformations typically take 6-12 weeks, depending on complexity. You see results from week one."
      }
    },
    {
      "@type": "Question",
      "name": "What if we already use a practice management system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We integrate with your existing tools. Our automations work alongside your current practice management software, EHR systems, and workflows — we enhance what you have rather than replacing it."
      }
    },
    {
      "@type": "Question",
      "name": "Is the roadmap really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The 5-7 day automation roadmap is completely free with no obligations. You receive a full report with risk scores, automation recommendations, and a compliance roadmap. About 40-60% of clinics that complete a roadmap choose to proceed with implementation, but there is zero pressure."
      }
    },
    {
      "@type": "Question",
      "name": "What does your appointment automation include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Smart scheduling, reminders, and follow-ups that reduce no-shows by up to 30% — all GDPR compliant."
      }
    },
    {
      "@type": "Question",
      "name": "How do you handle patient communications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Automated but personal communications through compliant channels, replacing risky WhatsApp and personal email usage."
      }
    },
    {
      "@type": "Question",
      "name": "Can you automate billing and insurance processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Streamlined billing workflows that reduce errors and save hours of manual administrative work each week."
      }
    },
    {
      "@type": "Question",
      "name": "What compliance documentation do you provide?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Automated audit trails, data processing records, and compliance reports that keep you inspection-ready at all times. Every automation is architected with GDPR principles at its core — data minimisation, purpose limitation, security controls, and audit trails from day one."
      }
    }
  ]
};
---

<Layout metadata={metadata}>
  <JsonLd schema={faqSchema} />

  <!-- Hero Banner -->
  <div class="relative w-full overflow-hidden" style="height: 480px;">
    <AstroImage
      src={colab3Banner}
      alt="Compliance-First AI Automation for Healthcare Providers"
      class="absolute inset-0 w-full h-full object-cover"
      widths={[768, 1024, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/0 flex items-center justify-center">
      <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter text-white text-center px-8">
        Compliance-First AI Automation<br />for Healthcare Providers
      </h1>
    </div>
  </div>

  <!-- Hero Subtitle -->
  <div class="max-w-3xl mx-auto text-center px-6 py-6 text-muted">
    <p class="text-xl">
      We help medical practices, pharmacies, and dental clinics save 10-15 hours per week through AI automation — without compromising patient data security or GDPR compliance. Enterprise-level compliance expertise, built for healthcare SMBs in Spain and the EU.
    </p>
  </div>

  <!-- Compliance Automation Map -->

  <ComplianceAutomationMap
    heroTitle="Your Compliance Automation Services"
    servicesLabel="Our Services"
    frameworks={[
      {
        badge: 'GDPR',
        name: 'GDPR',
        accent: 'var(--fds-acc-blue)',
        items: [
          { text: 'Art. 46 - Appropriate safeguards - PII / sensitive data', tip: 'Requires safeguards such as SCCs, BCRs, codes of conduct, or certification where no adequacy decision exists.' },
          { text: 'Art. 35 - Data Protection Impact Assessment - High-risk / sensitive data', tip: 'DPIAs are required for high-risk sharing activities, especially involving sensitive data.' },
          { text: 'Art. 32(1)(b) - Confidentiality, integrity, availability, resilience - PII / sensitive data', tip: 'Requires security controls to prevent unauthorised sharing or leakage.' },
          { text: 'Art. 32(1)(a) - Pseudonymisation and encryption - PII / sensitive data', tip: 'Shared data should be protected through appropriate technical measures.' },
          { text: 'Art. 9 - Special categories of personal data - Sensitive data', tip: 'Sharing sensitive data is prohibited unless a specific Art. 9 exception applies, such as explicit consent or substantial public interest.' },
          { text: 'Art. 5(1)(c) - Data minimisation - PII', tip: 'Only the minimum personal data necessary may be shared.' },
        ],
      },
      {
        badge: 'ISO',
        name: 'ISO 27001',
        accent: 'var(--fds-acc-purple)',
        items: [
          { text: 'Annex A 5.14 - Information transfer - PII / sensitive data', tip: 'Requires rules, procedures, and agreements to protect information transferred electronically, physically, or verbally.' },
          { text: 'Annex A 8.12 - Data leakage prevention - PII / sensitive data', tip: 'Requires measures to detect and prevent unauthorised disclosure, transmission, or extraction of sensitive information.' },
          { text: 'Annex A 8.11 - Data masking - PII / sensitive data', tip: 'Requires masking techniques such as pseudonymisation, anonymisation, or redaction to limit exposure of sensitive information.' },
          { text: 'Annex A 5.15 - Access control - PII / sensitive data', tip: 'Requires access to information and systems to be restricted according to business and security requirements.' },
        ],
      },
      {
        badge: 'AI',
        name: 'AI Act',
        accent: 'var(--fds-acc-lime)',
        items: [
          { text: 'Art. 10(5) - Processing special categories of personal data for bias detection and correction - Sensitive data', tip: 'Allows processing of special category data only where strictly necessary, with safeguards such as reuse limitations, security and privacy-preserving measures, access restrictions, and confidentiality obligations.' },
          { text: 'Art. 15 - Accuracy, robustness and cybersecurity - PII / sensitive data', tip: 'Requires high-risk AI systems to be resilient against unauthorised access, misuse, or manipulation that could expose or compromise sensitive information.' },
          { text: 'Art. 78 - Confidentiality - PII / sensitive data / confidential information', tip: 'Requires authorities and involved bodies to protect confidential information and request only data strictly necessary for risk assessment and regulatory powers.' },
        ],
      },
      {
        badge: 'HIPAA',
        name: 'HIPAA',
        accent: 'var(--fds-acc-pink)',
        items: [
          { text: '45 CFR § 164.502(b) - Minimum necessary standard - PHI / sensitive health information', tip: 'Requires covered entities and business associates to make reasonable efforts to limit uses, disclosures, and requests for PHI to the minimum necessary to accomplish the intended purpose.' },
          { text: '45 CFR § 164.530(c) - Safeguards - PHI', tip: 'Requires appropriate administrative, technical, and physical safeguards to protect PHI from intentional or unintentional unauthorised use or disclosure.' },
          { text: '45 CFR § 164.312(a) - Access control - ePHI', tip: 'Requires technical controls that allow access only to authorised users and systems.' },
          { text: '45 CFR § 164.312(b) - Audit controls - ePHI', tip: 'Requires mechanisms to record and examine activity in systems that contain or use ePHI.' },
          { text: '45 CFR § 164.312(c) - Integrity controls - ePHI', tip: 'Requires controls to protect ePHI from improper alteration or destruction.' },
        ],
      },
      {
        badge: 'SOC2',
        name: 'SOC2',
        accent: 'var(--fds-acc-royal)',
        items: [
          { text: 'CC6.6 - Prevention of unauthorised access - PII / sensitive data', tip: 'Requires controls to prevent or detect unauthorised access to systems, data, and protected information.' },
          { text: 'CC6.7 - Restriction of data transmission, movement, and removal - PII / sensitive data', tip: 'Requires controls over transmission, movement, and removal of information to prevent unauthorised sharing or leakage.' },
          { text: 'CC7.2 - Monitoring for security events - PII / sensitive data', tip: 'Requires monitoring to detect events that could result in unauthorised disclosure or compromise of protected information.' },
          { text: 'C1.1 - Identification and protection of confidential information - Confidential information / sensitive data', tip: 'Requires confidential information to be identified, classified, retained, and protected according to confidentiality commitments and requirements.' },
          { text: 'P4.1 - Personal information use limitation - PII', tip: 'Requires personal information to be used only for purposes identified in notices or otherwise authorised.' },
          { text: 'P6.1 - Disclosure to third parties - PII', tip: 'Requires personal information disclosed to third parties to be limited to authorised purposes and consistent with privacy commitments.' },
        ],
      },
    ]}
    services={[
      { name: 'TrustPrompt', logo: 'trustprompt' },
      { name: 'TrustCore',   logo: 'trustcore' },
      { name: 'TrustAuto',   logo: 'trustauto' },
    ]}
    rows={[
      {
        label: 'Protect Sensitive Information',
        pills: [
          { mini: 'DLP',  label: 'DLP',  sub: 'Data loss prevention' },
          { mini: 'GRC',  label: 'GRC',  sub: 'Governance, Risk, and Compliance' },
          { mini: 'PII',  label: 'PII',  sub: 'Personally Identifiable Information' },
          { mini: 'PHI',  label: 'PHI',  sub: 'Protected Health Information' },
          { mini: 'AIG',  label: 'AIG',  sub: 'AI Governance' },
        ],
      },
      {
        label: 'Your Infrastructure — Your Rules',
        pills: [
          { mini: 'On', label: 'On-Prem', logo: 'onprem' },
          { mini: 'Cl', label: 'Cloud',   logo: 'cloud' },
        ],
      },
      {
        label: 'No Data Sharing',
        pills: [
          { mini: 'RAG',  label: 'RAG + embeddings', logo: 'rag' },
          { mini: 'VDB',  label: 'Vector Database' },
          { mini: 'OCR',  label: 'OCR' },
          { mini: 'TP',   label: 'TrustPrompt', logo: 'trustprompt' },
          { mini: 'OW',   label: 'Open WebUI',  logo: 'openwebui' },
          { mini: 'EHR',  label: 'OpenEHR',     logo: 'openehr' },
          { mini: 'FHIR', label: 'HAPI FHIR',   logo: 'hapifhir' },
        ],
      },
      {
        label: 'Local LLMs',
        pills: [
          { mini: 'LL', label: 'LLAMA' },
          { mini: 'G',  label: 'GEMMA',    logo: 'gemma' },
          { mini: 'MG', label: 'MEDGEMMA' },
          { mini: 'M',  label: 'MISTRAL',  logo: 'mistral' },
          { mini: 'DS', label: 'DEEPSEEK', logo: 'deepseek' },
        ],
      },
    ]}
  />

  <!-- Trust Stats -->

  <Stats
    stats={[
      { title: 'Compliance Frameworks', amount: '4+', icon: 'tabler:shield-check' },
      { title: 'Hours Saved Weekly', amount: '10-15', icon: 'tabler:clock' },
      { title: 'Data Risk Reduction', amount: '90%', icon: 'tabler:lock' },
      { title: 'Roadmap Conversion', amount: '40-60%', icon: 'tabler:chart-arrows' },
    ]}
  />

  <!-- Problem / Pain Points -->

  <Content
    isReversed
    tagline="The Challenge"
    title="Incorrect Automation: A Fast Track to Compliance Failures and Costly Penalties"
    items={[
      {
        title: 'GDPR complexity for small practices',
        description:
          'You face the same data protection requirements as large hospitals, but without dedicated IT teams or compliance officers.',
      },
      {
        title: 'Cloud AI risks with patient data',
        description:
          'Most AI tools send patient data to external cloud servers — a potential GDPR violation that puts your practice at risk.',
      },
      {
        title: 'Administrative overload stealing patient time',
        description:
          'Appointment scheduling, follow-ups, billing, and paperwork consume hours that should be spent on patient care.',
      },
    ]}
    image={{
      src: '~/assets/images/data-dashboard.jpg',
      alt: 'Person overwhelmed by administrative work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Sound familiar?</h3>
      Most AI agencies don't understand healthcare regulations. Most compliance consultants don't understand AI. You need both.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent" style="background-image: var(--grad-lilac);"></div>
    </Fragment>
  </Content>

  <!-- Differentiators -->

  <Features
    id="features"
    tagline="Why Futurion Solutions"
    title="What makes us different"
    subtitle="We bridge the gap between AI automation and healthcare compliance — so you don't have to choose between efficiency and data protection."
    columns={3}
    items={[
      {
        title: 'Compliance-First Approach',
        description:
          'Every automation is built with GDPR, HIPAA, and data privacy requirements at its core — not added as an afterthought.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Hybrid & On-Prem AI',
        description:
          'Patient data stays in your clinic. We design solutions that work locally or in hybrid setups, never sending sensitive data to external clouds. For larger organizations, MedCore Private AI delivers fully on-premise medical-grade AI infrastructure.',
        icon: 'tabler:server',
      },
      {
        title: 'Enterprise Security for SMBs',
        description:
          'SOC2, ISO 27001, and enterprise-grade security practices — scaled and priced for small healthcare businesses.',
        icon: 'tabler:lock',
      },
    ]}
  />

  <!-- How It Works -->

  <Steps
    title="How it works"
    subtitle="From initial roadmap to ongoing support, we make AI adoption safe and simple for your practice."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Free Automation Roadmap</span>',
        description:
          'We assess your clinic\'s data flows, compliance posture, and automation opportunities in a free 5-7 day roadmap. You receive a detailed report with risk scores and safe automation recommendations.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Step 2: <span class="font-medium">Compliant Implementation</span>',
        description:
          'We build and deploy AI automations designed with data privacy at their core. On-prem or hybrid architecture ensures patient data never leaves your control.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Step 3: <span class="font-medium">Ongoing Support & Monitoring</span>',
        description:
          'We monitor your automations, update compliance controls as regulations evolve, and optimize performance. Your trusted AI partner, month after month.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Results: Save 10-15 hours per week',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '~/assets/images/team-working.jpg',
      alt: 'Team collaborating on a project',
    }}
  />

  <!-- CTA Banner -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Automation Roadmap',
        href: '/automation-roadmap/',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Start with a Free 5-7 Day Automation Roadmap</Fragment>

    <Fragment slot="subtitle">
      We assess your clinic's data flows, identify safe automation opportunities, and deliver a clear compliance roadmap — at no cost. Limited to 8 roadmaps per month.
    </Fragment>
  </CallToAction>

  <!-- MedCore Note -->

  <Note
    icon="tabler:server"
    title="For Medium Healthcare Organizations:"
    description='Explore <a href="/medcore-private-ai/" class="underline font-bold">MedCore Private AI</a> — fully on-premise, medical-grade AI infrastructure with complete data sovereignty. For context, read our analysis of <a href="/openevidence-eu-uk-withdrawal-private-on-prem-sovereign-cloud/" class="underline font-bold">OpenEvidence&apos;s EU/UK withdrawal</a> and what it means for clinical AI architecture.'
  />

  <!-- FAQs -->

  <FAQs
    title="Frequently Asked Questions"
    subtitle="Everything you need to know about compliance-first AI automation for your healthcare practice."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is a compliance-first automation roadmap?',
        description:
          'Our free roadmap assesses your clinic\'s data handling, identifies where AI can safely automate tasks, and flags compliance gaps. It is a risk and process roadmap with an AI feasibility overlay — not a sales pitch. You receive a detailed report you can act on independently.',
      },
      {
        title: 'Will patient data be sent to the cloud?',
        description:
          'No. We design hybrid and on-premise AI solutions that keep patient data within your clinic\'s infrastructure. Most cloud-based AI tools are unsuitable for healthcare data under GDPR. We use architectures that keep sensitive data local.',
      },
      {
        title: 'How much does implementation cost?',
        description:
          'Our quick-win implementations start at around €1,500-3,000 for 1-2 automations. Comprehensive automation packages range from €5,000-15,000. Monthly support starts at €200/month. The free roadmap gives you a clear picture before any commitment.',
      },
      {
        title: 'We\'re a small clinic — is this for us?',
        description:
          'Absolutely. We specialize in small healthcare businesses: dental clinics, pharmacies, and practices with 1-10 employees. Our solutions are designed to be affordable and impactful for practices that don\'t have dedicated IT teams.',
      },
      {
        title: 'What GDPR and compliance frameworks do you follow?',
        description:
          'We work with GDPR, HIPAA, SOC2, and ISO 27001 frameworks. Every automation includes proper data processing agreements, audit trails, consent management, and documentation required by EU and Spanish (AEPD) regulations.',
      },
      {
        title: 'How long does implementation take?',
        description:
          'The free roadmap takes 5-7 business days. Quick-win implementations can be completed in 2-4 weeks. Full automation transformations typically take 6-12 weeks, depending on complexity. You see results from week one.',
      },
      {
        title: 'What if we already use a practice management system?',
        description:
          'We integrate with your existing tools. Our automations work alongside your current practice management software, EHR systems, and workflows — we enhance what you have rather than replacing it.',
      },
      {
        title: 'Is the roadmap really free?',
        description:
          'Yes. The 5-7 day automation roadmap is completely free with no obligations. You receive a full report with risk scores, automation recommendations, and a compliance roadmap. About 40-60% of clinics that complete a roadmap choose to proceed with implementation, but there is zero pressure.',
      },
      {
        title: 'What does your appointment automation include?',
        description:
          'Smart scheduling, reminders, and follow-ups that reduce no-shows by up to 30% — all GDPR compliant.',
      },
      {
        title: 'How do you handle patient communications?',
        description:
          'Automated but personal communications through compliant channels, replacing risky WhatsApp and personal email usage.',
      },
      {
        title: 'Can you automate billing and insurance processing?',
        description:
          'Streamlined billing workflows that reduce errors and save hours of manual administrative work each week.',
      },
      {
        title: 'What compliance documentation do you provide?',
        description:
          'Automated audit trails, data processing records, and compliance reports that keep you inspection-ready at all times. Every automation is architected with GDPR principles at its core — data minimisation, purpose limitation, security controls, and audit trails from day one.',
      },
    ]}
  />

  <!-- Latest Blog Posts -->

  <BlogLatestPosts
    title="Compliance & AI Insights"
    information="Stay informed about healthcare compliance, AI automation best practices, and regulatory updates for small healthcare providers in Spain and the EU."
    lang="en"
  />

  <!-- Final CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Your Free Automation Roadmap',
        href: '/automation-roadmap/',
        icon: 'tabler:clipboard-check',
      },
    ]}
  >
    <Fragment slot="title">Ready to Automate Compliantly?</Fragment>

    <Fragment slot="subtitle">
      Join healthcare practices across Spain that are saving 10-15 hours per week with AI automation — without compromising patient data or compliance. Start with a free roadmap today.
    </Fragment>
  </CallToAction>
</Layout>
