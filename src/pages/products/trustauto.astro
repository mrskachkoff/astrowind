---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

import imgTrustAuto from '~/assets/images/trustauto.png';

const metadata = {
  title: 'TrustAuto — On-Premises Compliance Control Center (Coming Soon)',
  description:
    'TrustAuto is a non-SaaS, fully on-premises compliance control center that connects to your existing systems and continuously checks whether you are meeting SOC 2, ISO 27001, HIPAA, and GDPR controls. Coming soon.',
  openGraph: {
    images: [{ url: '~/assets/images/trustauto.png' }],
  },
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Coming soon">
    <Fragment slot="title">
      <img
        src={imgTrustAuto.src}
        alt="TrustAuto logo"
        width="120"
        height="120"
        class="mx-auto mb-6 object-contain"
      />
      TrustAuto
    </Fragment>

    <Fragment slot="subtitle">
      A non-SaaS, fully on-premises compliance control center. TrustAuto connects to your existing systems and
      continuously checks whether your organization is meeting the security controls and privacy standards it's held to
      — SOC&nbsp;2, ISO&nbsp;27001, HIPAA, and GDPR.
    </Fragment>
  </HeroText>
</Layout>
