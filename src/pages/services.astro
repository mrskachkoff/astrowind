---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'AI Automation Services for Healthcare',
  description: 'Compliance-first AI automation services for healthcare providers. Free Automation Roadmap, GDPR-safe implementation, and ongoing support.',
  openGraph: {
    images: [{ url: '~/assets/images/data-dashboard.jpg' }],
  },
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Compliance-First AI Automation for Healthcare",
  "description": "Compliance-first AI automation services for dental clinics, pharmacies, and small medical practices in Spain and the EU. Includes Free Automation Roadmap, GDPR-safe implementation, and ongoing support.",
  "provider": { "@id": "https://solutions.futurion.es/#organization" },
  "areaServed": [
    { "@type": "Country", "name": "Spain" },
    { "@type": "Place", "name": "European Union" }
  ],
  "serviceType": "AI Automation Consulting",
  "audience": {
    "@type": "Audience",
    "audienceType": "Healthcare Providers"
  },
  "url": "https://solutions.futurion.es/services/"
};
---

<Layout metadata={metadata}>
  <JsonLd schema={serviceSchema} />

  <!-- MedCore Private AI — Enterprise Option -->

  <Content
    tagline="Enterprise Solution"
    title="MedCore Private AI — For Medium Healthcare Organizations"
    items={[
      {
        title: 'Fully on-premise medical AI',
        description: 'Deploy medical-grade language models entirely on your infrastructure. No patient data ever leaves your premises.',
      },
      {
        title: 'Purpose-built for medicine',
        description: 'Models trained on medical literature and clinical data — not general-purpose AI with a medical prompt.',
      },
      {
        title: 'Fine-tuning & RAG',
        description: 'Customize AI for your specialty, protocols, and institutional knowledge using your own verified data.',
      },
      {
        title: 'Complete compliance stack',
        description: 'GDPR, HIPAA, SOC2, and EU AI Act compliance documentation included. Hardware, software, and compliance — one partner.',
      },
    ]}
    image={{
      src: '~/assets/images/server-network.jpg',
      alt: 'On-premise server infrastructure for healthcare AI',
    }}
    callToAction={{
      text: 'Explore MedCore Private AI',
      href: '/medcore-private-ai/',
      icon: 'tabler:arrow-right',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Beyond small practice automation</h3>
      For clinic networks, specialized healthcare centers, and compliance-critical organizations that need institutional-grade AI with complete data sovereignty.
      The same need is visible in <a href="/openevidence-eu-uk-withdrawal-private-on-prem-sovereign-cloud/" class="underline font-bold">OpenEvidence's EU/UK withdrawal</a>, where clinical AI availability depends on infrastructure, subprocessors, and jurisdictional control.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-green-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Why Choose Futurion -->

  <Features
    title="Why healthcare practices choose us"
    subtitle="The combination of compliance expertise and AI automation knowledge that sets us apart."
    columns={3}
    items={[
      {
        title: 'Compliance + AI Expertise',
        description: 'Most AI agencies don\'t understand GDPR. Most compliance consultants don\'t understand AI. We bridge both worlds.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Process-First Approach',
        description: 'We optimize before automating. We fix broken workflows first, then automate them — so efficiency gains actually stick.',
        icon: 'tabler:arrows-sort',
      },
      {
        title: 'Enterprise Experience, SMB Pricing',
        description: 'Years of enterprise process optimization, now applied to small healthcare businesses at accessible price points.',
        icon: 'tabler:building',
      },
      {
        title: 'Data Privacy by Design',
        description: 'Data minimization, purpose limitation, security controls, and audit trails — built in from architecture, not bolted on later.',
        icon: 'tabler:lock',
      },
      {
        title: 'No-Nonsense Results',
        description: 'We skip the AI buzzwords and focus on outcomes: 10-15 hours saved per week, reduced compliance risk, better patient care.',
        icon: 'tabler:target',
      },
      {
        title: 'Risk-Aware Implementation',
        description: 'We don\'t just ask "Can AI do this?" — we ask "Should it, and how do we implement it safely?" SOC2 and ISO 27001 thinking applied.',
        icon: 'tabler:alert-triangle',
      },
    ]}
  />

  <!-- Process Overview -->

  <Steps
    title="Our engagement process"
    subtitle="A clear path from first contact to long-term partnership."
    isReversed={true}
    items={[
      {
        title: 'Free consultation',
        description: 'We discuss your practice, understand your pain points, and determine if an Automation Roadmap is right for you.',
        icon: 'tabler:phone',
      },
      {
        title: 'Automation Roadmap (5-7 days)',
        description: 'Thorough assessment of data flows, compliance posture, and automation opportunities. Free, no obligations.',
        icon: 'tabler:clipboard-check',
      },
      {
        title: 'Implementation proposal',
        description: 'Based on your Roadmap findings, we present a fixed-price proposal for the automations that will deliver the most impact.',
        icon: 'tabler:file-invoice',
      },
      {
        title: 'Build & deploy',
        description: 'We implement automations with compliance controls built in. Quick wins in 2-4 weeks, full transformations in 6-12 weeks.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Ongoing partnership',
        description: 'Monthly support, compliance updates, performance monitoring, and identification of new automation opportunities.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: '~/assets/images/business-meeting.jpg',
      alt: 'Professional business engagement',
    }}
  />

  <!-- CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Automation Roadmap',
        href: '/automation-roadmap/',
        icon: 'tabler:clipboard-check',
      },
    ]}
    title="Ready to see where AI can help your practice?"
    subtitle="Start with your free 5-7 day Automation Roadmap. No obligations, no pressure — just honest recommendations based on your unique situation."
  />
</Layout>
